// Unit 9: Geometry
_mergeUnitData(8, {"lessons":[{"points":["2D shapes are FLAT","They have SIDES (straight lines) and VERTICES (corners)","Circle = 0 sides, 0 corners","Triangle = 3 sides, 3 corners","Square = 4 equal sides, 4 corners","Pentagon = 5 sides, Hexagon = 6 sides"],"examples":[{"c":"#6c3483","tag":"Shape Families","p":"2D Shapes to know:","s":"<div class=\"shape-grid\"><div class=\"shape-tile\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\"><circle cx=\"35\" cy=\"35\" r=\"30\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"4\"/></svg><div class=\"shape-lbl\">Circle</div><div class=\"shape-sub\">0 sides</div></div><div class=\"shape-tile\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\"><polygon points=\"35,5 65,65 5,65\" fill=\"none\" stroke=\"#e67e22\" stroke-width=\"4\"/></svg><div class=\"shape-lbl\">Triangle</div><div class=\"shape-sub\">3 sides</div></div><div class=\"shape-tile\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\"><rect x=\"8\" y=\"8\" width=\"54\" height=\"54\" fill=\"none\" stroke=\"#27ae60\" stroke-width=\"4\"/></svg><div class=\"shape-lbl\">Square</div><div class=\"shape-sub\">4 equal sides</div></div><div class=\"shape-tile\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\"><rect x=\"4\" y=\"16\" width=\"62\" height=\"38\" fill=\"none\" stroke=\"#6c3483\" stroke-width=\"4\"/></svg><div class=\"shape-lbl\">Rectangle</div><div class=\"shape-sub\">4 sides</div></div><div class=\"shape-tile\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\"><polygon points=\"35,5 62,24 52,58 18,58 8,24\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"4\"/></svg><div class=\"shape-lbl\">Pentagon</div><div class=\"shape-sub\">5 sides</div></div><div class=\"shape-tile\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\"><polygon points=\"35,5 62,20 62,50 35,65 8,50 8,20\" fill=\"none\" stroke=\"#27ae60\" stroke-width=\"4\"/></svg><div class=\"shape-lbl\">Hexagon</div><div class=\"shape-sub\">6 sides</div></div></div>","a":"Know your 2D shapes! ✅"},{"c":"#6c3483","tag":"Square vs Rectangle","p":"What makes them different?","s":"Both have 4 sides and 4 corners\nSQUARE: all 4 sides are EQUAL length\nRECTANGLE: opposite sides are equal (2 long, 2 short)","a":"Square = all sides equal ✅"},{"c":"#6c3483","tag":"Counting Sides","p":"Count the sides carefully:","s":"Triangle → 3 sides\nSquare → 4 sides\nPentagon → 5 sides\nHexagon → 6 sides","a":"Count each straight line! ✅"}],"practice":[{"q":"How many sides does a triangle have?","a":"3 sides","h":"Tri means 3! Triangle = 3 sides and 3 corners.","e":"🔺"},{"q":"How many sides does a hexagon have?","a":"6 sides","h":"Hex means 6! Hexagon = 6 sides and 6 corners.","e":"⬡"},{"q":"A shape with 4 equal sides is called?","a":"Square","h":"All 4 sides the same length = square!","e":"⬛"}],"qBank":[{"t":"How many sides does a hexagon have?","o":["4","5","6","8"],"a":2,"e":"Hexagon=6 sides.","d":"e"},{"t":"Which shape has no sides and no corners at all?","o":["Triangle","Square","Circle","Pentagon"],"a":2,"e":"Circle has no sides.","d":"m"},{"t":"A shape has 3 sides and 3 corners. What shape is it?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,49.5 9.9,49.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Square","Triangle","Rectangle","Pentagon"],"a":1,"e":"Triangle=3 sides.","d":"h"},{"t":"How many sides does a pentagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 62.6,26.0 52.0,58.5 18.0,58.5 7.4,26.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","7"],"a":1,"e":"Pentagon=5 sides.","d":"h"},{"t":"Which shape has all 4 sides the same length?","o":["Rectangle","Rhombus","Square","Trapezoid"],"a":2,"e":"Square has 4 equal sides.","d":"m"},{"t":"Square and rectangle both have how many sides?","o":["3","4","5","6"],"a":1,"e":"Both have 4 sides.","d":"e"},{"t":"What is the name of a shape that has 8 sides?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 55.5,14.5 64.0,35.0 55.5,55.5 35.0,64.0 14.5,55.5 6.0,35.0 14.5,14.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Hexagon","Heptagon","Octagon","Nonagon"],"a":2,"e":"Octagon=8 sides.","d":"h"},{"t":"How many corners does a triangle have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,49.5 9.9,49.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["2","3","4","5"],"a":1,"e":"3 corners=3 vertices.","d":"h"},{"t":"What is the difference between a square and a rectangle?","o":["Fewer sides","All 4 equal","More corners","No corners"],"a":1,"e":"Square=all 4 equal. Rectangle=2 pairs.","d":"e"},{"t":"What shape has exactly 6 sides and 6 corners?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,20.5 60.1,49.5 35.0,64.0 9.9,49.5 9.9,20.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Pentagon","Hexagon","Heptagon","Octagon"],"a":1,"e":"Hexagon.","d":"h"},{"t":"How many vertices does a triangle have?","o":["2","3","4","5"],"a":1,"e":"3 vertices.","d":"e"},{"t":"Which is a quadrilateral?","o":["Triangle","Pentagon","Square","Hexagon"],"a":2,"e":"Square has 4 sides=quadrilateral.","d":"e"},{"t":"Rectangle has how many right angles?","o":["2","3","4","5"],"a":2,"e":"All 4 corners of a rectangle are right angles.","d":"m"},{"t":"Which shape has 5 sides and 5 corners?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 62.6,26.0 52.0,58.5 18.0,58.5 7.4,26.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Pentagon","Hexagon","Square","Octagon"],"a":0,"e":"Pentagon.","d":"h"},{"t":"Which shape has no corners?","o":["Square","Circle","Triangle","Pentagon"],"a":1,"e":"Circle has no corners.","d":"e"},{"t":"Rhombus has how many sides?","o":["3","4","5","6"],"a":1,"e":"4 sides.","d":"e"},{"t":"Which shapes have 4 sides?","o":["Square and circle","Triangle and square","Square and rectangle","Circle and triangle"],"a":2,"e":"Square and rectangle both have 4 sides.","d":"e"},{"t":"Which shape has 4 sides and all 4 angles are equal right angles?","o":["Rhombus","Rectangle","Pentagon","Trapezoid"],"a":1,"e":"Rectangle has 4 right angles.","d":"h"},{"t":"How many corners does a hexagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,20.5 60.1,49.5 35.0,64.0 9.9,49.5 9.9,20.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","8"],"a":2,"e":"Hexagon=6 corners.","d":"h"},{"t":"Which of the following shapes is a polygon? Polygons have only straight sides.","o":["Circle","Oval","Triangle","Sphere"],"a":2,"e":"Triangle has straight sides.","d":"e"},{"t":"How many sides does an octagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 55.5,14.5 64.0,35.0 55.5,55.5 35.0,64.0 14.5,55.5 6.0,35.0 14.5,14.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["6","7","8","9"],"a":2,"e":"Octagon=8.","d":"h"},{"t":"A square has 4 sides and a triangle has 3 sides. How many sides do they have altogether?","o":["6","7","8","9"],"a":1,"e":"4+3=7.","d":"h"},{"t":"What is the name for a polygon that has exactly 3 sides?","o":["Quadrilateral","Pentagon","Triangle","Hexagon"],"a":2,"e":"Triangle.","d":"m"},{"t":"A pentagon has 5 corners and a hexagon has 6 corners. How many corners do they have altogether?","o":["9","10","11","12"],"a":2,"e":"5+6=11.","d":"h"},{"t":"Which has more sides: hexagon or octagon?","o":["A hexagon","An octagon","They are equal","Neither"],"a":1,"e":"Octagon has 8>6.","d":"m"},{"t":"A square is a special type of which shape?","o":["Triangle","Circle","Rectangle","Pentagon"],"a":2,"e":"A square is a special rectangle with all equal sides.","d":"e"},{"t":"Which shape has 4 sides but the sides are not all the same length?","o":["Square","Rectangle","Rhombus","Circle"],"a":1,"e":"Rectangle has 2 long + 2 short sides.","d":"m"},{"t":"A hexagon has 6 sides and a pentagon has 5 sides. How many sides do they have altogether?","o":["9","10","11","12"],"a":2,"e":"6+5=11.","d":"h"},{"t":"A polygon always has which of the following features?","o":["Curves","Straight sides","Circles inside","No sides"],"a":1,"e":"Polygons have straight sides.","d":"m"},{"t":"Which quadrilateral has exactly one pair of parallel sides?","o":["Square","Rectangle","Trapezoid","Rhombus"],"a":2,"e":"Trapezoid has 1 pair of parallel sides.","d":"m"},{"t":"A triangle has 3 sides. A pentagon has 5 sides. How many sides altogether?","o":["6","7","8","9"],"a":2,"e":"3 + 5 = 8 sides altogether.","d":"h"},{"t":"A rectangle has sides of 5 in and 3 in. What is the distance all the way around?","o":["8 in","15 in","16 in","20 in"],"a":2,"e":"5 + 3 + 5 + 3 = 16 inches all the way around.","d":"h"},{"t":"A square has 4 vertices. A triangle has 3 vertices. How many vertices in all?","o":["5","6","7","8"],"a":2,"e":"4 + 3 = 7 vertices total.","d":"h"},{"t":"How many sides does a triangle have?","o":["2","3","4","5"],"a":1,"e":"A triangle always has exactly 3 sides. 'Tri' means three!","d":"e"},{"t":"What shape has 4 equal sides and 4 square corners?","o":["Triangle","Circle","Square","Pentagon"],"a":2,"e":"A square has 4 equal sides and 4 square corners (right angles).","d":"m"},{"t":"How many corners (vertices) does a rectangle have?","o":["3","2","5","4"],"a":3,"e":"A rectangle has 4 corners. Count them: top-left, top-right, bottom-left, bottom-right.","d":"e"},{"t":"Which shape is round with no sides and no corners?","o":["Square","Circle","Hexagon","Triangle"],"a":1,"e":"A circle is perfectly round. It has 0 sides and 0 corners.","d":"e"},{"t":"What is the name of a shape with 5 sides?","o":["Hexagon","Pentagon","Octagon","Quadrilateral"],"a":1,"e":"A pentagon has 5 sides. 'Penta' means five!","d":"e"},{"t":"How many corners does a triangle have?","o":["4","2","3","1"],"a":2,"e":"A triangle has 3 corners (vertices) -- one at each point where two sides meet.","d":"e"},{"t":"Which of these is NOT a polygon?","o":["Square","Triangle","Circle","Rectangle"],"a":2,"e":"A circle is NOT a polygon. Polygons have straight sides, but a circle is curved.","d":"e"},{"t":"How many sides does an octagon have?","o":["6","7","8","10"],"a":2,"e":"An octagon has 8 sides. A stop sign is shaped like an octagon!","d":"e"},{"t":"A square is a special kind of ___.","o":["Triangle","Circle","Rectangle","Pentagon"],"a":2,"e":"A square is a special rectangle -- it has 4 right angles AND 4 equal sides.","d":"e"},{"t":"True or false: A rectangle always has 4 sides.","o":["True","False","Only sometimes","It depends on size"],"a":0,"e":"True! Every rectangle has exactly 4 sides and 4 right angles.","d":"h"},{"t":"What shape is a door most like?","o":["Triangle","Circle","Rectangle","Hexagon"],"a":2,"e":"A door is shaped like a rectangle -- it has 4 sides and 4 square corners.","d":"e"},{"t":"How many sides does a square have?","o":["3","4","5","6"],"a":1,"e":"A square has exactly 4 sides, and all 4 sides are the same length.","d":"e"},{"t":"Which shape looks like a stop sign?","o":["Hexagon","Pentagon","Octagon","Square"],"a":2,"e":"A stop sign is an octagon -- it has 8 sides.","d":"e"},{"t":"Does a triangle have more sides or more corners?","o":["More sides","More corners","They are equal","It has no corners"],"a":2,"e":"A triangle has 3 sides and 3 corners -- they are equal!","d":"e"},{"t":"What shape has 0 sides?","o":["Square","Triangle","Pentagon","Circle"],"a":3,"e":"A circle has 0 straight sides. It is a curved shape, not a polygon.","d":"m"},{"t":"Which of these shapes has the fewest sides?","o":["Square","Pentagon","Triangle","Hexagon"],"a":2,"e":"A triangle has 3 sides. That is fewer than a square (4), pentagon (5), or hexagon (6).","d":"m"},{"t":"A rectangle has 2 long sides and 2 short sides. How many sides is that in all?","o":["2","3","4","6"],"a":2,"e":"2 long sides + 2 short sides = 4 sides in all.","d":"h"},{"t":"What do we call any shape with 4 sides?","o":["Triangle","Quadrilateral","Pentagon","Hexagon"],"a":1,"e":"A quadrilateral is any shape with exactly 4 sides. 'Quad' means four!","d":"e"},{"t":"What shape has 3 sides and 3 corners?","o":["Rectangle","Triangle","Square","Circle"],"a":1,"e":"A triangle has 3 sides and 3 corners. It is the polygon with the fewest sides.","d":"m"},{"t":"A shape has 4 sides but they are NOT all equal. It has 4 square corners. What could it be?","o":["Square","Rectangle","Triangle","Pentagon"],"a":1,"e":"A rectangle has 4 sides and 4 square corners, but its sides do not all have to be equal. A square would need all 4 sides equal.","d":"h"},{"t":"Which of these shapes are quadrilaterals? (Shapes with exactly 4 sides.)","o":["Triangle and hexagon","Square and rectangle","Circle and oval","Pentagon and octagon"],"a":1,"e":"Squares and rectangles both have exactly 4 sides, so they are both quadrilaterals.","d":"m"},{"t":"A polygon has 5 sides. It is called a ___.","o":["Hexagon","Pentagon","Octagon","Quadrilateral"],"a":1,"e":"A polygon with 5 sides is called a pentagon. 'Penta' means five.","d":"m"},{"t":"How many more sides does a hexagon have than a triangle?","o":["2","3","4","6"],"a":1,"e":"A hexagon has 6 sides and a triangle has 3 sides. 6 - 3 = 3 more sides.","d":"e"},{"t":"I have 4 sides. Two of my sides are long and two are short. All my corners are square corners. What am I?","o":["Square","Triangle","Rectangle","Trapezoid"],"a":2,"e":"A rectangle has 4 square corners, with 2 long sides and 2 short sides.","d":"m"},{"t":"Which shape has MORE corners: a pentagon or a square?","o":["Pentagon","Square","They are equal","Neither has corners"],"a":0,"e":"A pentagon has 5 corners and a square has 4 corners. 5 > 4, so the pentagon has more.","d":"m"},{"t":"A ___ has 8 sides and 8 corners.","o":["Hexagon","Pentagon","Heptagon","Octagon"],"a":3,"e":"An octagon has 8 sides and 8 corners. 'Octa' means eight.","d":"h"},{"t":"Jake says a circle is a polygon because it is a flat shape. Is he correct?","o":["Yes, all flat shapes are polygons","No, polygons must have straight sides","Yes, circles have curved sides","No, polygons must be round"],"a":1,"e":"Jake is wrong. A polygon must have straight sides. A circle has a curved edge, so it is NOT a polygon.","d":"e"},{"t":"How many more sides does an octagon have than a rectangle?","o":["2","3","4","6"],"a":2,"e":"An octagon has 8 sides and a rectangle has 4 sides. 8 - 4 = 4 more sides.","d":"e"},{"t":"Which of these is TRUE about every square?","o":["It has 3 sides","It has sides of different lengths","It is also a rectangle","It has no corners"],"a":2,"e":"Every square is also a rectangle because it has 4 sides and 4 right angles. But a square's sides are all the same length.","d":"e"},{"t":"Sort these from fewest sides to most: hexagon, triangle, square.","o":["Triangle, square, hexagon","Square, triangle, hexagon","Hexagon, square, triangle","Triangle, hexagon, square"],"a":0,"e":"Triangle has 3, square has 4, hexagon has 6. So the order is triangle, square, hexagon.","d":"m"},{"t":"A shape has fewer than 5 sides but more than 3 sides. It has 4 equal sides. What is it?","o":["Triangle","Rectangle","Square","Pentagon"],"a":2,"e":"More than 3 and fewer than 5 means it has 4 sides. With 4 equal sides, it must be a square.","d":"h"},{"t":"What is the same about a square and a rectangle?","o":["All sides are equal","They both have 4 sides and 4 right angles","They both have 3 corners","They are both round"],"a":1,"e":"Both a square and a rectangle have 4 sides and 4 right angles. The difference is a square's sides are all equal.","d":"e"},{"t":"If you put 2 triangles together along one side, how many sides could the new shape have?","o":["3","4","6","2"],"a":1,"e":"When you join 2 triangles along one side, the joined sides disappear inside. You can make a shape with 4 sides (like a parallelogram).","d":"m"},{"t":"Emma drew a shape with more sides than a square but fewer sides than a hexagon. What shape could she have drawn?","o":["Triangle","Rectangle","Pentagon","Octagon"],"a":2,"e":"A square has 4 sides and a hexagon has 6. A pentagon has 5 sides, which is between 4 and 6.","d":"m"},{"t":"A shape has the same number of sides as corners. Is this always true for polygons?","o":["Yes, always","No, never","Only for triangles","Only for squares"],"a":0,"e":"Yes! Every polygon has the same number of sides and corners. A triangle has 3 of each, a square has 4 of each, and so on.","d":"h"},{"t":"Which shape does NOT belong: square, rectangle, triangle, rhombus?","o":["Square","Rectangle","Triangle","Rhombus"],"a":2,"e":"The triangle does not belong. The square, rectangle, and rhombus are all quadrilaterals (4 sides). A triangle has only 3 sides.","d":"m"},{"t":"How many sides do 2 separate triangles have in all?","o":["3","4","5","6"],"a":3,"e":"Each triangle has 3 sides. 3 + 3 = 6 sides in all.","d":"e"},{"t":"I am a polygon. I have more sides than a pentagon but fewer sides than an octagon. I could be a ___.","o":["Square","Hexagon","Triangle","Rectangle"],"a":1,"e":"A pentagon has 5 sides and an octagon has 8. A hexagon has 6 sides (or a heptagon has 7). Both fit between 5 and 8.","d":"m"},{"t":"Lily says a rectangle has 2 pairs of equal sides. Is she right?","o":["Yes -- 2 long sides match and 2 short sides match","No -- all 4 sides are equal","No -- no sides are equal","Yes -- but only if it is big"],"a":0,"e":"Lily is correct! A rectangle has 2 pairs of equal sides: the 2 long sides are equal and the 2 short sides are equal.","d":"h"},{"t":"Tom says all rectangles are squares. Sara says all squares are rectangles. Who is correct?","o":["Tom is correct","Sara is correct","Both are correct","Neither is correct"],"a":1,"e":"Sara is correct. Every square IS a rectangle (4 sides, 4 right angles). But not every rectangle is a square -- rectangles can have sides of different lengths.","d":"m"},{"t":"A shape has more than 4 sides and fewer than 7 sides. All its sides are equal length. What shape could it be?","o":["Square","Regular pentagon or regular hexagon","Triangle","Octagon"],"a":1,"e":"More than 4 and fewer than 7 means 5 or 6 sides. With all sides equal, it could be a regular pentagon (5) or regular hexagon (6).","d":"h"},{"t":"You cut a square in half with a straight diagonal line from corner to corner. What 2 shapes do you get?","o":["2 squares","2 rectangles","2 triangles","1 triangle and 1 rectangle"],"a":2,"e":"Cutting a square diagonally makes 2 triangles. Each triangle has 3 sides: 2 sides from the square and 1 from the cut.","d":"m"},{"t":"Ben says a triangle can have 4 corners if you make it big enough. What is wrong with his thinking?","o":["He is actually correct","A triangle always has 3 corners no matter the size","Bigger triangles have 5 corners","Only small triangles have 3 corners"],"a":1,"e":"Size does not change the number of corners. A triangle ALWAYS has exactly 3 sides and 3 corners, whether it is tiny or huge.","d":"h"},{"t":"How many total sides do a triangle, a square, and a pentagon have together?","o":["10","11","12","13"],"a":2,"e":"Triangle = 3, square = 4, pentagon = 5. Add them: 3 + 4 + 5 = 12 sides total.","d":"m"},{"t":"Mia drew a quadrilateral with NO sides equal. Which shape did she definitely NOT draw?","o":["Trapezoid","Square","Irregular quadrilateral","Any 4-sided shape"],"a":1,"e":"A square has all 4 sides equal, so Mia definitely did NOT draw a square. Her shape has no equal sides.","d":"m"},{"t":"If you remove one side from a square and close the shape, what polygon do you get?","o":["Rectangle","Triangle","Pentagon","It is not possible"],"a":1,"e":"If you remove one side of a square and connect the remaining corners, you get a triangle with 3 sides.","d":"m"},{"t":"Kai says a circle has 1 side because it has 1 curved edge. Emma says it has 0 sides because sides must be straight. Who is correct for polygons?","o":["Kai is correct","Emma is correct","Both are correct","Neither is correct"],"a":1,"e":"In geometry, polygon sides must be straight line segments. Since a circle has no straight sides, Emma is correct -- it has 0 polygon sides.","d":"h"},{"t":"A shape has twice as many sides as a triangle. What shape is it?","o":["Square","Pentagon","Hexagon","Octagon"],"a":2,"e":"A triangle has 3 sides. Twice as many: 3 x 2 = 6 sides. A hexagon has 6 sides.","d":"m"},{"t":"Sam drew a polygon. It has 2 more sides than a square but 2 fewer sides than an octagon. What did he draw?","o":["Pentagon","Hexagon","Heptagon","Triangle"],"a":1,"e":"A square has 4 sides. 4 + 2 = 6. An octagon has 8 sides. 8 - 2 = 6. Sam drew a hexagon (6 sides). Both clues match!","d":"h"},{"t":"Rosa says a rectangle can never be a square. Is she right? Explain.","o":["Yes, they are completely different shapes","No -- when all 4 sides are equal, a rectangle IS a square","Yes, squares have more sides","No -- rectangles always have 5 sides"],"a":1,"e":"Rosa is wrong. A rectangle CAN be a square! When a rectangle has all 4 sides the same length, it is also a square. A square is a special rectangle.","d":"m"},{"t":"You put 2 identical squares side by side touching along one full side. What shape do you make?","o":["A bigger square","A rectangle","A triangle","A hexagon"],"a":1,"e":"Two squares side by side make a rectangle. The new shape is twice as long as it is tall, with 4 sides and 4 right angles.","d":"m"},{"t":"Jaya drew a shape with 3 fewer sides than an octagon. How many corners does her shape have?","o":["3","4","5","6"],"a":2,"e":"An octagon has 8 sides. 8 - 3 = 5 sides. A polygon with 5 sides (pentagon) has 5 corners. Sides and corners are always equal!","d":"m"},{"t":"Which statement is FALSE?","o":["All squares are rectangles","All rectangles are quadrilaterals","All quadrilaterals are squares","All squares are quadrilaterals"],"a":2,"e":"'All quadrilaterals are squares' is FALSE. A quadrilateral is any 4-sided shape. Many quadrilaterals (like rectangles and trapezoids) are NOT squares.","d":"e"},{"t":"You cut a rectangle in half with a straight line from the middle of the top to the middle of the bottom. What 2 shapes do you get?","o":["2 triangles","2 smaller rectangles","1 square and 1 rectangle","2 pentagons"],"a":1,"e":"Cutting a rectangle straight down the middle gives you 2 smaller rectangles, each with 4 sides and 4 right angles.","d":"h"},{"t":"Leo says: 'I drew a polygon with no corners.' Is this possible?","o":["Yes, a circle","Yes, an oval","No -- every polygon has corners","Yes, if it is very small"],"a":2,"e":"Every polygon must have corners (vertices). If a shape has no corners, it is not a polygon. A circle has no corners, but it is NOT a polygon.","d":"m"},{"t":"A hexagon has how many more sides than a triangle, and how many fewer sides than an octagon?","o":["3 more and 2 fewer","2 more and 3 fewer","4 more and 1 fewer","3 more and 3 fewer"],"a":0,"e":"Hexagon = 6. Triangle = 3. 6 - 3 = 3 more. Octagon = 8. 8 - 6 = 2 fewer. So 3 more than a triangle and 2 fewer than an octagon.","d":"h"},{"t":"Ava traced around a square tile 3 times without overlapping. She made a new shape. How many sides could it have if the squares share full sides?","o":["8","12","6","4"],"a":0,"e":"Three squares in an L-shape make a polygon with 8 sides. Shared sides become interior and do not count as outside edges.","d":"h"},{"t":"What is the DIFFERENCE between the number of sides on a pentagon and the number of corners on a hexagon?","o":["0","1","2","3"],"a":1,"e":"A pentagon has 5 sides. A hexagon has 6 corners. 6 - 5 = 1. The difference is 1.","d":"m"},{"t":"Maya and Alex each draw a quadrilateral. Maya's has all equal sides. Alex's has NO equal sides. Can they both be correct?","o":["No -- quadrilaterals must have equal sides","No -- quadrilaterals never have equal sides","Yes -- a quadrilateral just needs 4 sides","Yes -- but only if they are rectangles"],"a":2,"e":"Yes! A quadrilateral is ANY shape with 4 sides. Maya could draw a square (all equal) and Alex could draw an irregular quadrilateral (no equal sides). Both are valid.","d":"h"}],"quiz":[{"t":"How many sides does a hexagon have?","o":["4","5","6","8"],"a":2,"e":"Hexagon = 6 sides and 6 corners."},{"t":"Which 2D shape has 0 sides?","o":["Triangle","Square","Circle","Pentagon"],"a":2,"e":"A circle has no straight sides and no corners."},{"t":"3 sides and 3 corners — what shape?","o":["Square","Triangle","Rectangle","Pentagon"],"a":1,"e":"3 sides + 3 corners = triangle!"},{"t":"How many sides does a pentagon have?","o":["4","5","6","7"],"a":1,"e":"Pentagon = 5 sides and 5 corners."},{"t":"What makes a square different from a rectangle?","o":["Fewer sides","All 4 sides equal length","More corners","No corners"],"a":1,"e":"A square has 4 EQUAL sides. A rectangle has 2 long and 2 short."},{"t":"Square and rectangle both have how many sides?","o":["3","4","5","6"],"a":1,"e":"Both have 4 sides and 4 corners."}]},{"points":["3D shapes are SOLID (not flat)","FACES = the flat surfaces","EDGES = where two faces meet","VERTICES = corners (points)","Cube: 6 faces, 12 edges, 8 vertices"],"examples":[{"c":"#6c3483","tag":"3D Shapes to Know","p":"Common solid shapes:","s":"📦 Cube — 6 faces, 12 edges, 8 vertices\n🔮 Sphere — 1 curved face, 0 edges, 0 vertices\n🥫 Cylinder — 3 faces, 2 edges, 0 vertices\n🍦 Cone — 2 faces, 1 edge, 1 vertex\n🔺 Pyramid — 5 faces, 8 edges, 5 vertices","a":"Solid shapes are everywhere! ✅"},{"c":"#6c3483","tag":"Real Life 3D Shapes","p":"Find them around you:","s":"Box of cereal = Rectangular Prism\nBasketball = Sphere\nSoup can = Cylinder\nIce cream cone = Cone\nDie (dice) = Cube","a":"3D shapes are in your home! ✅"},{"c":"#6c3483","tag":"Counting Parts","p":"For a cube:","s":"Faces: count the flat sides → 6\nEdges: count the lines where faces meet → 12\nVertices: count the corners → 8","a":"Cube: F=6, E=12, V=8 ✅"}],"practice":[{"q":"How many faces does a cube have?","a":"6 faces","h":"Top, bottom, front, back, left, right = 6 faces!","e":"📦"},{"q":"How many edges does a sphere have?","a":"0 edges","h":"A sphere is perfectly round with no edges at all!","e":"🔮"},{"q":"What 3D shape looks like a soup can?","a":"Cylinder","h":"Cylinder has 2 round ends and a curved side!","e":"🥫"}],"qBank":[{"t":"How many faces does a cube have?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["4","5","6","8"],"a":2,"e":"Cube=6 faces.","d":"h"},{"t":"A soup can is shaped like which 3D shape?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"9\" y=\"24\" width=\"54\" height=\"44\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"68\" rx=\"27\" ry=\"10\" fill=\"#85c1e9\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"24\" rx=\"27\" ry=\"10\" fill=\"#d6eaf8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["Cube","Sphere","Cone","Cylinder"],"a":3,"e":"Cylinder.","d":"h"},{"t":"An ice cream cone is shaped like which 3D shape?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"36,4 7,70 65,70\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"70\" rx=\"29\" ry=\"9\" fill=\"#f7dc6f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg>","o":["Cube","Sphere","Cone","Cylinder"],"a":2,"e":"Cone.","d":"h"},{"t":"How many edges does a sphere have?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><circle cx=\"36\" cy=\"36\" r=\"30\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"36\" rx=\"30\" ry=\"10\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/><ellipse cx=\"36\" cy=\"36\" rx=\"10\" ry=\"30\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/></svg>","o":["0","1","2","3"],"a":0,"e":"Sphere=0 edges.","d":"h"},{"t":"How many vertices does a cube have?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["4","6","8","12"],"a":2,"e":"Cube=8 vertices.","d":"h"},{"t":"A cereal box is shaped like which 3D shape?","o":["Cube","Sphere","Rectangular prism","Pyramid"],"a":2,"e":"Rectangular prism.","d":"e"},{"t":"How many edges does a cube have?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["6","8","10","12"],"a":3,"e":"Cube=12 edges.","d":"h"},{"t":"A basketball is shaped like which 3D shape?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><circle cx=\"36\" cy=\"36\" r=\"30\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"36\" rx=\"30\" ry=\"10\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/><ellipse cx=\"36\" cy=\"36\" rx=\"10\" ry=\"30\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/></svg>","o":["Cube","Sphere","Cone","Cylinder"],"a":1,"e":"Sphere.","d":"h"},{"t":"How many faces does a square pyramid have?<svg width=\"82\" height=\"76\" viewBox=\"0 0 82 76\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"41,4 9,63 73,63\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 41,63 41,4\" fill=\"#7fb3d3\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 73,63 73,70 9,70\" fill=\"#5d8aa8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["3","4","5","6"],"a":2,"e":"Square pyramid=5 faces.","d":"h"},{"t":"How many vertices does a cone have?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"36,4 7,70 65,70\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"70\" rx=\"29\" ry=\"9\" fill=\"#f7dc6f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg>","o":["0","1","2","3"],"a":1,"e":"1 vertex (tip).","d":"h"},{"t":"How many faces does a cylinder have?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"9\" y=\"24\" width=\"54\" height=\"44\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"68\" rx=\"27\" ry=\"10\" fill=\"#85c1e9\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"24\" rx=\"27\" ry=\"10\" fill=\"#d6eaf8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["1","2","3","4"],"a":2,"e":"2 circular + 1 curved=3 faces.","d":"h"},{"t":"A dice is shaped like which 3D shape?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["Sphere","Cone","Cube","Cylinder"],"a":2,"e":"Cube.","d":"h"},{"t":"Which 3D shape has zero vertices?","o":["Cube","Cone","Sphere","Pyramid"],"a":2,"e":"Sphere has no vertices.","d":"m"},{"t":"How many faces does a rectangular prism have?","o":["4","6","8","12"],"a":1,"e":"6 faces.","d":"e"},{"t":"Which 3D shape has only one curved surface and no flat faces?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><circle cx=\"36\" cy=\"36\" r=\"30\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"36\" rx=\"30\" ry=\"10\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/><ellipse cx=\"36\" cy=\"36\" rx=\"10\" ry=\"30\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/></svg>","o":["Cube","Rectangular prism","Cylinder","Sphere"],"a":3,"e":"Sphere=1 curved surface.","d":"h"},{"t":"How many vertices does a square pyramid have?<svg width=\"82\" height=\"76\" viewBox=\"0 0 82 76\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"41,4 9,63 73,63\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 41,63 41,4\" fill=\"#7fb3d3\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 73,63 73,70 9,70\" fill=\"#5d8aa8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["4","5","6","8"],"a":1,"e":"Square pyramid=5 vertices (4 base + 1 apex).","d":"h"},{"t":"How many edges does a cylinder have?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"9\" y=\"24\" width=\"54\" height=\"44\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"68\" rx=\"27\" ry=\"10\" fill=\"#85c1e9\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"24\" rx=\"27\" ry=\"10\" fill=\"#d6eaf8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["0","1","2","3"],"a":2,"e":"Cylinder=2 circular edges.","d":"h"},{"t":"Which shape has more faces: a cube or a square pyramid?","o":["A cube","A square pyramid","They are equal","Neither has faces"],"a":0,"e":"A cube has 6 faces and a square pyramid has 5 faces.","d":"m"},{"t":"A camping tent is shaped most like which 3D shape?","o":["Cube","Sphere","Cone","Triangular prism"],"a":3,"e":"Tent=triangular prism.","d":"m"},{"t":"How many faces does a cylinder have?","o":["1","2","3","4"],"a":2,"e":"2 flat circles + 1 curved surface=3 faces.","d":"e"},{"t":"What are 3D shapes also called?","o":["Flat shapes","Polygons","Solid shapes","2D shapes"],"a":2,"e":"3D shapes=solid shapes.","d":"e"},{"t":"Each face of a cube is shaped like which flat shape?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["Triangle","Circle","Square","Rectangle"],"a":2,"e":"Each face of a cube is a square.","d":"h"},{"t":"A cube has 6 faces and 8 vertices. What is the total of faces plus vertices?","o":["12","14","16","18"],"a":1,"e":"6+8=14.","d":"h"},{"t":"Which is NOT a 3D shape?","o":["Cube","Cylinder","Pentagon","Sphere"],"a":2,"e":"Pentagon is a 2D shape.","d":"e"},{"t":"How many edges does a cone have?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"36,4 7,70 65,70\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"70\" rx=\"29\" ry=\"9\" fill=\"#f7dc6f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg>","o":["0","1","2","3"],"a":1,"e":"1 circular edge at base.","d":"h"},{"t":"A football is shaped most like which 3D shape?","o":["Cube","Sphere","Cylinder","Cone"],"a":1,"e":"Football is most like a sphere (elongated).","d":"m"},{"t":"How many edges does a square pyramid have?<svg width=\"82\" height=\"76\" viewBox=\"0 0 82 76\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"41,4 9,63 73,63\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 41,63 41,4\" fill=\"#7fb3d3\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 73,63 73,70 9,70\" fill=\"#5d8aa8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["4","6","8","12"],"a":2,"e":"Square pyramid=8 edges.","d":"h"},{"t":"Which 3D shape can roll most easily in any direction?","o":["Cube","Rectangular prism","Sphere","Pyramid"],"a":2,"e":"Sphere rolls in all directions.","d":"m"},{"t":"A cube has 6 faces and 12 edges. What is the total of faces plus edges?","o":["12","16","18","20"],"a":2,"e":"6+12=18.","d":"h"},{"t":"An oatmeal canister is shaped like which 3D shape?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"9\" y=\"24\" width=\"54\" height=\"44\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"68\" rx=\"27\" ry=\"10\" fill=\"#85c1e9\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"24\" rx=\"27\" ry=\"10\" fill=\"#d6eaf8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["Cube","Sphere","Cylinder","Pyramid"],"a":2,"e":"Cylinder.","d":"h"},{"t":"What shape is a ball?","o":["Cube","Cone","Sphere","Cylinder"],"a":2,"e":"A ball is shaped like a sphere -- it is perfectly round in every direction.","d":"e"},{"t":"What 3D shape does a soup can look like?","o":["Sphere","Cone","Cube","Cylinder"],"a":3,"e":"A soup can is shaped like a cylinder -- it has 2 flat circular faces and 1 curved surface.","d":"e"},{"t":"How many faces does a cube have?","o":["4","6","8","12"],"a":1,"e":"A cube has 6 faces. Think of a dice -- top, bottom, front, back, left, right.","d":"e"},{"t":"What 3D shape looks like an ice cream cone?","o":["Cylinder","Sphere","Cone","Rectangular prism"],"a":2,"e":"An ice cream cone is shaped like a cone -- it has a point at one end and a circle at the other.","d":"e"},{"t":"What 3D shape does a cereal box look like?","o":["Cube","Cone","Rectangular prism","Sphere"],"a":2,"e":"A cereal box is a rectangular prism -- it has 6 flat rectangular faces.","d":"e"},{"t":"How many flat faces does a sphere have?","o":["0","1","2","6"],"a":0,"e":"A sphere has 0 flat faces. It is completely curved all around, like a ball.","d":"e"},{"t":"Which 3D shape can roll AND slide?","o":["Cube","Cylinder","Rectangular prism","Triangular prism"],"a":1,"e":"A cylinder can roll (on its curved side) and slide (on its flat faces).","d":"e"},{"t":"How many vertices (corners) does a cube have?","o":["4","6","8","12"],"a":2,"e":"A cube has 8 vertices (corners). Think of 4 corners on top and 4 corners on bottom.","d":"e"},{"t":"What shape are all 6 faces of a cube?","o":["Rectangles","Triangles","Squares","Circles"],"a":2,"e":"All 6 faces of a cube are squares. Each face is the same size.","d":"m"},{"t":"Which solid shape has NO edges and NO vertices?","o":["Cube","Cone","Sphere","Rectangular prism"],"a":2,"e":"A sphere has no edges and no vertices. It is completely smooth and round.","d":"m"},{"t":"How many edges does a cube have?","o":["6","8","10","12"],"a":3,"e":"A cube has 12 edges -- the lines where two faces meet.","d":"e"},{"t":"What 3D shape does a basketball look like?","o":["Cylinder","Cube","Sphere","Cone"],"a":2,"e":"A basketball is shaped like a sphere -- round in every direction.","d":"e"},{"t":"A cone has how many flat faces?","o":["0","1","2","3"],"a":1,"e":"A cone has 1 flat face (the circular base) and 1 curved surface that goes up to a point.","d":"m"},{"t":"Which 3D shape can only roll (not slide on a flat face)?","o":["Cube","Cylinder","Sphere","Rectangular prism"],"a":2,"e":"A sphere can only roll because it has no flat faces to slide on.","d":"e"},{"t":"What 3D shape does a party hat look like?","o":["Sphere","Cylinder","Cone","Cube"],"a":2,"e":"A party hat is shaped like a cone -- wide at the bottom and pointed at the top.","d":"e"},{"t":"A rectangular prism has how many faces?","o":["4","5","6","8"],"a":2,"e":"A rectangular prism has 6 faces, just like a cube. But its faces can be rectangles of different sizes.","d":"m"},{"t":"Which shape has a point (apex) at the top?","o":["Cube","Cylinder","Sphere","Cone"],"a":3,"e":"A cone has a point (called the apex) at the top and a flat circular base.","d":"m"},{"t":"What 3D shape does a tissue box look like?","o":["Cube","Rectangular prism","Cylinder","Cone"],"a":1,"e":"A tissue box is shaped like a rectangular prism -- it has 6 rectangular faces.","d":"e"},{"t":"How many flat faces does a cylinder have?","o":["0","1","2","3"],"a":2,"e":"A cylinder has 2 flat circular faces -- one on the top and one on the bottom.","d":"e"},{"t":"True or false: A cube can stack on top of another cube.","o":["True","False","Only if they are the same size","Only small cubes"],"a":0,"e":"True! Cubes have flat faces, so they stack easily. Flat faces let shapes sit on top of each other.","d":"m"},{"t":"How many more edges does a rectangular prism have than a triangular prism?","o":["2","3","4","6"],"a":1,"e":"A rectangular prism has 12 edges. A triangular prism has 9 edges. 12 - 9 = 3 more edges.","d":"e"},{"t":"A shape has 6 faces, 8 vertices, and 12 edges. All faces are the same size. What is it?","o":["Rectangular prism","Cube","Triangular prism","Cylinder"],"a":1,"e":"A cube has 6 equal square faces, 8 vertices, and 12 edges. A rectangular prism also has 6 faces, 8 vertices, and 12 edges, but its faces are not all the same size.","d":"h"},{"t":"Which 3D shape has triangular faces? Choose the best answer.","o":["Cube","Cylinder","Triangular prism","Sphere"],"a":2,"e":"A triangular prism has 2 triangular faces (on the ends) and 3 rectangular faces (on the sides).","d":"m"},{"t":"What 2D shape would you see if you traced the bottom of a cylinder?","o":["Square","Triangle","Circle","Rectangle"],"a":2,"e":"The base of a cylinder is a circle. If you set it down and traced around the bottom, you would draw a circle.","d":"m"},{"t":"Which solid can slide but NOT roll?","o":["Sphere","Cylinder","Cube","Cone"],"a":2,"e":"A cube has only flat faces, so it can slide but cannot roll. You need a curved surface to roll.","d":"e"},{"t":"How many faces does a triangular prism have?","o":["3","4","5","6"],"a":2,"e":"A triangular prism has 5 faces: 2 triangles on the ends and 3 rectangles on the sides.","d":"e"},{"t":"Amy says a cone has 2 vertices. Is she correct?","o":["Yes, one on top and one on bottom","No, a cone has 1 vertex (the point)","No, a cone has 0 vertices","Yes, just like a cylinder"],"a":1,"e":"A cone has just 1 vertex -- the pointy tip at the top. The circular base has no corners.","d":"m"},{"t":"If you trace all the faces of a cube, what shapes do you draw?","o":["6 circles","6 squares","4 squares and 2 rectangles","6 triangles"],"a":1,"e":"A cube has 6 faces and each face is a square. So you would draw 6 squares.","d":"e"},{"t":"Which has MORE vertices: a cube or a triangular prism?","o":["Cube (8 vs 6)","Triangular prism (6 vs 8)","They are equal","Neither has vertices"],"a":0,"e":"A cube has 8 vertices and a triangular prism has 6 vertices. The cube has 2 more.","d":"m"},{"t":"What 2D shape do you see if you look straight at one end of a triangular prism?","o":["Square","Circle","Triangle","Rectangle"],"a":2,"e":"The end faces of a triangular prism are triangles. Looking straight at one end, you see a triangle.","d":"m"},{"t":"How are a cube and a rectangular prism ALIKE?","o":["Both have 6 faces, 8 vertices, 12 edges","Both have all square faces","Both can roll","Both have curved surfaces"],"a":0,"e":"Both a cube and a rectangular prism have 6 faces, 8 vertices, and 12 edges. The difference is a cube's faces are all squares.","d":"e"},{"t":"Which solid shape has exactly 1 curved surface and 0 flat faces?","o":["Cone","Cylinder","Sphere","Cube"],"a":2,"e":"A sphere has 1 curved surface and no flat faces at all. A cone has 1 flat face and a cylinder has 2.","d":"m"},{"t":"How many edges does a triangular prism have?","o":["6","8","9","12"],"a":2,"e":"A triangular prism has 9 edges: 3 on each triangular face (6 total) plus 3 edges connecting them.","d":"e"},{"t":"A ___ has 5 faces, 6 vertices, and 9 edges.","o":["Cube","Rectangular prism","Triangular prism","Cone"],"a":2,"e":"A triangular prism has 5 faces, 6 vertices, and 9 edges.","d":"h"},{"t":"Which 3D shape could you make by rolling a rectangle into a tube and adding 2 circle caps?","o":["Cone","Cube","Cylinder","Sphere"],"a":2,"e":"Rolling a rectangle into a tube gives a curved surface. Adding 2 circle caps on the ends makes a cylinder.","d":"m"},{"t":"How are a cone and a cylinder DIFFERENT?","o":["A cone has 1 flat face; a cylinder has 2","A cone has more edges","A cylinder has no curved surface","They are exactly the same"],"a":0,"e":"A cone has 1 flat circular face and comes to a point. A cylinder has 2 flat circular faces and no point.","d":"e"},{"t":"Which of these real objects is shaped most like a rectangular prism?","o":["A basketball","A brick","A funnel","A marble"],"a":1,"e":"A brick is shaped like a rectangular prism -- it has 6 flat rectangular faces.","d":"m"},{"t":"Sort from fewest faces to most: sphere, triangular prism, cube.","o":["Sphere, triangular prism, cube","Cube, triangular prism, sphere","Triangular prism, sphere, cube","Sphere, cube, triangular prism"],"a":0,"e":"Sphere has 0 flat faces, triangular prism has 5, cube has 6. Order: sphere, triangular prism, cube.","d":"m"},{"t":"What flat shape do you see if you look at the top of a cylinder?","o":["Square","Triangle","Rectangle","Circle"],"a":3,"e":"The top face of a cylinder is a circle. Looking straight down, you see a circle.","d":"e"},{"t":"If you stack 3 cubes in a tower, how many faces can you see from the outside? (Not counting the bottom or hidden faces.)","o":["12","13","14","18"],"a":1,"e":"Each cube shows 4 side faces (4 x 3 = 12). The top cube shows its top face too (12 + 1 = 13). The touching faces and the bottom are hidden.","d":"m"},{"t":"Tom says a cylinder has 2 faces and 0 vertices. Sara says it has 3 faces and 0 vertices. Who is closer to correct?","o":["Tom -- it has 2 flat faces and 0 vertices","Sara -- it has 3 surfaces total","Neither -- it has 6 faces","Both -- they said the same thing"],"a":0,"e":"A cylinder has 2 flat circular faces and 0 vertices. It also has 1 curved surface, but that is not a 'face.' Tom is correct about the 2 flat faces and 0 vertices.","d":"h"},{"t":"If you unfold a cube and lay it flat, how many squares do you see?","o":["4","5","6","8"],"a":2,"e":"A cube has 6 square faces. When you unfold (make a net of) a cube, you see all 6 squares laid flat.","d":"e"},{"t":"Maya says a sphere has 1 face because the whole outside is a face. Jake says it has 0 faces because faces must be flat. Who is correct?","o":["Maya","Jake","Both are correct","Neither is correct"],"a":1,"e":"Jake is correct. In geometry, a 'face' is a flat surface. A sphere has no flat surfaces, so it has 0 faces. It has 1 curved surface.","d":"h"},{"t":"How many more edges does a cube have than a triangular prism?","o":["1","2","3","4"],"a":2,"e":"A cube has 12 edges. A triangular prism has 9 edges. 12 - 9 = 3 more edges.","d":"e"},{"t":"A 3D shape has 5 faces. Two faces are triangles and three faces are rectangles. What is it?","o":["Cube","Rectangular prism","Triangular prism","Cone"],"a":2,"e":"A triangular prism has exactly 2 triangular faces (the ends) and 3 rectangular faces (the sides) = 5 faces total.","d":"h"},{"t":"Leo stacks a cone on top of a cylinder. How many flat faces are now hidden (touching each other)?","o":["0","1","2","3"],"a":2,"e":"The top circle of the cylinder and the bottom circle of the cone are pressed together. That is 2 flat faces hidden.","d":"m"},{"t":"Which has more vertices: 2 triangular prisms or 1 cube?","o":["2 triangular prisms (12 vs 8)","1 cube (8 vs 12)","They are equal","Neither has vertices"],"a":0,"e":"Each triangular prism has 6 vertices. Two of them: 6 + 6 = 12. A cube has 8 vertices. 12 > 8, so 2 triangular prisms have more.","d":"m"},{"t":"Ava says you can stack spheres as easily as cubes because both are 3D shapes. What is wrong with her thinking?","o":["Nothing -- she is correct","Spheres have no flat faces so they roll and do not stack well","Cubes are not 3D shapes","Spheres are heavier than cubes"],"a":1,"e":"Cubes stack easily because they have flat faces. Spheres have NO flat faces -- they roll! Being 3D does not mean a shape can stack.","d":"h"},{"t":"You trace every face of a rectangular prism. You get 4 rectangles and 2 squares. How many shapes did you trace in all?","o":["4","5","6","8"],"a":2,"e":"4 rectangles + 2 squares = 6 shapes. A rectangular prism always has 6 faces total.","d":"m"},{"t":"A shape has twice as many faces as a triangular prism. It has 2 more faces than a cube. Does such a shape exist among common solids?","o":["Yes -- a shape with 10 faces","No -- twice 5 is 10 but a cube has 6, and 6 + 2 = 8, not 10","Yes -- a shape with 8 faces","No -- no solid has 10 faces"],"a":1,"e":"Twice a triangular prism's faces = 2 x 5 = 10. But a cube has 6 faces, and 6 + 2 = 8. Since 10 does not equal 8, no single shape can satisfy both clues.","d":"h"},{"t":"You slice a cube straight through the middle, parallel to one face. What shape is the cut surface?","o":["Triangle","Circle","Square","Rectangle"],"a":2,"e":"Slicing a cube parallel to one of its faces gives a square cross-section, the same size as the face.","d":"m"},{"t":"Ben says a cone has 1 edge. Mia says it has 0 edges because edges must be straight. Who is correct for standard geometry?","o":["Ben","Mia","Both","Neither"],"a":0,"e":"In standard elementary geometry, a cone is said to have 1 edge -- the circular edge where the flat base meets the curved surface. Ben is correct.","d":"h"},{"t":"How many total faces do a cube and a triangular prism have together?","o":["10","11","12","13"],"a":1,"e":"A cube has 6 faces and a triangular prism has 5 faces. 6 + 5 = 11 faces total.","d":"e"},{"t":"A shape can roll, slide, AND has exactly 1 vertex. What is it?","o":["Sphere","Cylinder","Cone","Cube"],"a":2,"e":"A cone can roll (curved surface), slide (flat base), and has exactly 1 vertex (the point at the top).","d":"m"},{"t":"Rosa has 2 cubes. She glues them together on one full face. How many faces can you see on the outside now?","o":["8","10","12","6"],"a":1,"e":"Each cube has 6 faces = 12 total. The 2 glued faces are hidden inside. 12 - 2 = 10 faces visible on the outside.","d":"m"},{"t":"Which 3D shape has the MOST edges: cube, triangular prism, or cone?","o":["Cube (12 edges)","Triangular prism (9 edges)","Cone (1 edge)","They all have the same"],"a":0,"e":"Cube has 12 edges, triangular prism has 9, cone has 1. The cube has the most edges.","d":"h"},{"t":"Sam says if he cuts a rectangular prism in half, he gets 2 cubes. Is this always true?","o":["Yes, always","No -- only if the prism is exactly twice as long as it is wide","Yes, if you cut it straight","No -- you always get triangles"],"a":1,"e":"Only when the rectangular prism is exactly twice as long as it is wide and tall (and width equals height). Otherwise, you get 2 smaller rectangular prisms, not cubes.","d":"m"},{"t":"A triangular prism has ___ more faces than a cone.","o":["2","3","4","5"],"a":2,"e":"A triangular prism has 5 faces. A cone has 1 flat face. 5 - 1 = 4 more faces.","d":"m"},{"t":"If you look at a cube from directly above, what shape do you see?","o":["Rectangle","Triangle","Square","Circle"],"a":2,"e":"Looking straight down at a cube, you see only the top face, which is a square.","d":"m"},{"t":"Kai builds a shape using 1 rectangle and 2 triangles. He folds them into a 3D shape. What did he make?","o":["Cube","Rectangular prism","Triangular prism","Cone"],"a":2,"e":"A triangular prism has 2 triangular end faces and rectangular side faces. With 1 rectangle and 2 triangles as a start, Kai is building a triangular prism (he would need 3 rectangles total for all sides).","d":"h"}],"quiz":[{"t":"How many faces does a cube have?","o":["4","5","6","8"],"a":2,"e":"A cube has 6 flat square faces."},{"t":"A soup can is shaped like a?","o":["Cube","Sphere","Cone","Cylinder"],"a":3,"e":"Cylinder: circular ends and a curved side."},{"t":"An ice cream cone is shaped like a?","o":["Cube","Sphere","Cone","Cylinder"],"a":2,"e":"Cone: circular base, curved side, pointed top."},{"t":"Which 3D shape has 0 edges?","o":["Cube","Sphere","Cone","Cylinder"],"a":1,"e":"A sphere is perfectly round with no edges."},{"t":"How many vertices does a cube have?","o":["4","6","8","12"],"a":2,"e":"A cube has 8 corners (vertices)."},{"t":"A cereal box is shaped like a?","o":["Cube","Sphere","Rectangular prism","Pyramid"],"a":2,"e":"A cereal box has 6 rectangular faces = rectangular prism."},{"t":"How many edges does a cube have?","o":["6","8","10","12"],"a":3,"e":"A cube has 12 edges."}]},{"points":["A shape has SYMMETRY if you can fold it so both halves match","The fold line is the LINE OF SYMMETRY","Square = 4 lines of symmetry","Rectangle = 2 lines","Circle = unlimited lines!","Some shapes have NO symmetry"],"examples":[{"c":"#6c3483","tag":"What is Symmetry?","p":"A line of symmetry:","s":"<div style=\"display:flex;justify-content:center;align-items:flex-end;flex-wrap:wrap;gap:8px;margin:10px 0\"><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"36.0\" y1=\"3.0\" x2=\"36.0\" y2=\"69.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><polygon points=\"36.0,6.0 62.0,21.0 62.0,51.0 36.0,66.0 10.0,51.0 10.0,21.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#27ae60;margin-top:3px\">Fold the line... BOTH halves match!</div></div></div><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"78\" height=\"74\" viewBox=\"0 0 78 74\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"10,66 70,66 20,8\" fill=\"#fce4ec\" stroke=\"#c0392b\" stroke-width=\"2\"/><circle cx=\"64\" cy=\"14\" r=\"10\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"57\" y1=\"7\" x2=\"71\" y2=\"21\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#e74c3c;margin-top:3px\">Try any fold... halves do NOT match!</div></div></div></div><div style=\"text-align:center;font-size:13px;color:#555;margin-top:6px\">The fold line is called the <b style=\"color:#6c3483\">LINE OF SYMMETRY</b></div>","a":"Both halves must be mirror images ✅"},{"c":"#6c3483","tag":"Shapes & Lines","p":"How many lines of symmetry?","s":"<div style=\"display:flex;justify-content:center;align-items:flex-end;flex-wrap:wrap;gap:8px;margin:10px 0\"><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"36.0\" y1=\"3.0\" x2=\"36.0\" y2=\"69.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"59.3\" y1=\"12.7\" x2=\"12.7\" y2=\"59.3\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"69.0\" y1=\"36.0\" x2=\"3.0\" y2=\"36.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"59.3\" y1=\"59.3\" x2=\"12.7\" y2=\"12.7\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><polygon points=\"36.0,6.0 66.0,36.0 36.0,66.0 6.0,36.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#6c3483;margin-top:3px\">Square: 4 lines</div></div></div><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"110\" height=\"68\" viewBox=\"0 0 110 68\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"7\" y=\"10\" width=\"96\" height=\"48\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"55\" y1=\"4\" x2=\"55\" y2=\"64\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"34\" x2=\"108\" y2=\"34\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#6c3483;margin-top:3px\">Rectangle: 2 lines</div></div></div><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"72\" height=\"68\" viewBox=\"0 0 72 68\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"36.0\" y1=\"3.0\" x2=\"36.0\" y2=\"69.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"64.6\" y1=\"19.5\" x2=\"7.4\" y2=\"52.5\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"64.6\" y1=\"52.5\" x2=\"7.4\" y2=\"19.5\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><polygon points=\"36.0,6.0 62.0,51.0 10.0,51.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#6c3483;margin-top:3px\">Triangle: 3 lines</div></div></div><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"67.0\" y1=\"35.0\" x2=\"3.0\" y2=\"35.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"57.6\" y1=\"57.6\" x2=\"12.4\" y2=\"12.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"35.0\" y1=\"67.0\" x2=\"35.0\" y2=\"3.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"12.4\" y1=\"57.6\" x2=\"57.6\" y2=\"12.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><circle cx=\"35\" cy=\"35\" r=\"30\" fill=\"#dff0f8\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><text x=\"35\" y=\"40\" text-anchor=\"middle\" font-size=\"11\" fill=\"#2980b9\" font-weight=\"bold\">∞</text></svg><div style=\"font-size:12px;font-weight:bold;color:#2980b9;margin-top:3px\">Circle: unlimited!</div></div></div></div><div style=\"text-align:center;font-size:12px;color:#777;margin-top:4px\">More equal sides = more lines of symmetry</div>","a":"Count carefully! ✅"},{"c":"#6c3483","tag":"Real Life","p":"Symmetry in nature:","s":"<div style=\"display:flex;justify-content:center;align-items:flex-end;flex-wrap:wrap;gap:8px;margin:10px 0\"><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"100\" height=\"84\" viewBox=\"0 0 100 84\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><ellipse cx=\"25\" cy=\"28\" rx=\"23\" ry=\"17\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(-18 25 28)\"/><ellipse cx=\"75\" cy=\"28\" rx=\"23\" ry=\"17\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(18 75 28)\"/><ellipse cx=\"22\" cy=\"57\" rx=\"17\" ry=\"12\" fill=\"#c39bd3\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(12 22 57)\"/><ellipse cx=\"78\" cy=\"57\" rx=\"17\" ry=\"12\" fill=\"#c39bd3\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(-12 78 57)\"/><ellipse cx=\"50\" cy=\"42\" rx=\"5\" ry=\"27\" fill=\"#6c3483\"/><line x1=\"50\" y1=\"16\" x2=\"39\" y2=\"4\" stroke=\"#6c3483\" stroke-width=\"1.5\"/><line x1=\"50\" y1=\"16\" x2=\"61\" y2=\"4\" stroke=\"#6c3483\" stroke-width=\"1.5\"/><circle cx=\"39\" cy=\"4\" r=\"2.5\" fill=\"#8e44ad\"/><circle cx=\"61\" cy=\"4\" r=\"2.5\" fill=\"#8e44ad\"/><line x1=\"50\" y1=\"1\" x2=\"50\" y2=\"82\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#6c3483;margin-top:3px\">Butterfly: 1 line</div></div></div><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"40.0\" y1=\"1.0\" x2=\"40.0\" y2=\"79.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"77.1\" y1=\"27.9\" x2=\"2.9\" y2=\"52.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"62.9\" y1=\"71.6\" x2=\"17.1\" y2=\"8.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"17.1\" y1=\"71.6\" x2=\"62.9\" y2=\"8.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"2.9\" y1=\"27.9\" x2=\"77.1\" y2=\"52.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><polygon points=\"40.0,4.0 48.8,27.9 74.2,28.9 54.3,44.6 61.2,69.1 40.0,55.0 18.8,69.1 25.7,44.6 5.8,28.9 31.2,27.9\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#f39c12;margin-top:3px\">Star: 5 lines</div></div></div><div style=\"text-align:center;margin:0 8px\"><div style=\"text-align:center;margin:0 8px\"><svg width=\"82\" height=\"82\" viewBox=\"0 0 82 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"41.0\" y1=\"3.0\" x2=\"41.0\" y2=\"79.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"60.0\" y1=\"8.1\" x2=\"22.0\" y2=\"73.9\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"73.9\" y1=\"22.0\" x2=\"8.1\" y2=\"60.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"79.0\" y1=\"41.0\" x2=\"3.0\" y2=\"41.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"73.9\" y1=\"60.0\" x2=\"8.1\" y2=\"22.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"60.0\" y1=\"73.9\" x2=\"22.0\" y2=\"8.1\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"41\" y1=\"41\" x2=\"41.0\" y2=\"5.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"41.0\" y1=\"21.2\" x2=\"34.8\" y2=\"12.4\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41.0\" y1=\"21.2\" x2=\"47.2\" y2=\"12.4\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"72.2\" y2=\"23.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"58.1\" y1=\"31.1\" x2=\"62.7\" y2=\"21.3\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"58.1\" y1=\"31.1\" x2=\"68.9\" y2=\"32.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"72.2\" y2=\"59.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"58.1\" y1=\"50.9\" x2=\"68.9\" y2=\"50.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"58.1\" y1=\"50.9\" x2=\"62.7\" y2=\"60.7\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"41.0\" y2=\"77.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"41.0\" y1=\"60.8\" x2=\"47.2\" y2=\"69.6\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41.0\" y1=\"60.8\" x2=\"34.8\" y2=\"69.6\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"9.8\" y2=\"59.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"23.9\" y1=\"50.9\" x2=\"19.3\" y2=\"60.7\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"23.9\" y1=\"50.9\" x2=\"13.1\" y2=\"50.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"9.8\" y2=\"23.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"23.9\" y1=\"31.1\" x2=\"13.1\" y2=\"32.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"23.9\" y1=\"31.1\" x2=\"19.3\" y2=\"21.3\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><circle cx=\"41\" cy=\"41\" r=\"4\" fill=\"#2980b9\"/></svg><div style=\"font-size:12px;font-weight:bold;color:#2980b9;margin-top:3px\">Snowflake: 6 lines</div></div></div></div><div style=\"text-align:center;font-size:12px;color:#777;margin-top:4px\">Symmetry is all around us in nature!</div>","a":"Symmetry is beautiful! ✅"}],"practice":[{"q":"Does a circle have a line of symmetry?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"69.0\" y1=\"36.0\" x2=\"3.0\" y2=\"36.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"64.6\" y1=\"52.5\" x2=\"7.4\" y2=\"19.5\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"52.5\" y1=\"64.6\" x2=\"19.5\" y2=\"7.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"36.0\" y1=\"69.0\" x2=\"36.0\" y2=\"3.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"19.5\" y1=\"64.6\" x2=\"52.5\" y2=\"7.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"7.4\" y1=\"52.5\" x2=\"64.6\" y2=\"19.5\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><circle cx=\"36\" cy=\"36\" r=\"31\" fill=\"#dff0f8\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><text x=\"36\" y=\"41\" text-anchor=\"middle\" font-size=\"11\" fill=\"#2980b9\" font-weight=\"bold\">∞</text></svg>","a":"Yes, many lines!","h":"You can fold a circle any way and both halves match!","e":"⭕"},{"q":"How many lines of symmetry does a square have?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"36.0\" y1=\"3.0\" x2=\"36.0\" y2=\"69.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"59.3\" y1=\"12.7\" x2=\"12.7\" y2=\"59.3\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"69.0\" y1=\"36.0\" x2=\"3.0\" y2=\"36.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"59.3\" y1=\"59.3\" x2=\"12.7\" y2=\"12.7\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><polygon points=\"36.0,6.0 66.0,36.0 36.0,66.0 6.0,36.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","a":"4 lines","h":"2 straight across + 2 diagonal = 4 lines of symmetry!","e":"⬛"},{"q":"Does the letter Z have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">Z</text><circle cx=\"43\" cy=\"12\" r=\"9\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"36\" y1=\"5\" x2=\"50\" y2=\"19\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","a":"No!","h":"Try folding Z any way — the halves do not match!","e":"🦋"}],"qBank":[{"t":"How many lines of symmetry does a square have?<svg width=\"82\" height=\"82\" viewBox=\"0 0 82 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"11\" y=\"11\" width=\"60\" height=\"60\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"41\" y1=\"4\" x2=\"41\" y2=\"78\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"4\" y1=\"41\" x2=\"78\" y2=\"41\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"7\" y1=\"7\" x2=\"75\" y2=\"75\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"75\" y1=\"7\" x2=\"7\" y2=\"75\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":3,"e":"Square=4 lines.","d":"h"},{"t":"How many lines of symmetry does a circle have?<svg width=\"68\" height=\"68\" viewBox=\"0 0 68 68\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"65.0\" y1=\"34.0\" x2=\"3.0\" y2=\"34.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"55.9\" y1=\"55.9\" x2=\"12.1\" y2=\"12.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"34.0\" y1=\"65.0\" x2=\"34.0\" y2=\"3.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"12.1\" y1=\"55.9\" x2=\"55.9\" y2=\"12.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><circle cx=\"34\" cy=\"34\" r=\"29\" fill=\"#dff0f8\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><text x=\"34\" y=\"39\" text-anchor=\"middle\" font-size=\"11\" fill=\"#2980b9\" font-weight=\"bold\">∞</text></svg>","o":["1","4","8","Unlimited"],"a":3,"e":"Unlimited.","d":"h"},{"t":"Does the letter Z have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">Z</text><circle cx=\"43\" cy=\"12\" r=\"9\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"36\" y1=\"5\" x2=\"50\" y2=\"19\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","o":["Yes","No"],"a":1,"e":"Z has NO line of symmetry.","d":"h"},{"t":"Does the letter A have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">A</text><line x1=\"27\" y1=\"2\" x2=\"27\" y2=\"62\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["Yes, vertical","Yes, horizontal","No","Yes, diagonal"],"a":0,"e":"Vertical line through A.","d":"h"},{"t":"How many lines of symmetry does a rectangle have?<svg width=\"108\" height=\"66\" viewBox=\"0 0 108 66\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"7\" y=\"10\" width=\"94\" height=\"46\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"54\" y1=\"4\" x2=\"54\" y2=\"62\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"33\" x2=\"106\" y2=\"33\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":1,"e":"2 lines: horizontal and vertical.","d":"h"},{"t":"What does the word symmetry mean?","o":["4+ sides","Both halves match when folded","Always a circle","No corners"],"a":1,"e":"Fold: both halves match=symmetry.","d":"e"},{"t":"How many lines of symmetry does an equilateral triangle have?<svg width=\"82\" height=\"76\" viewBox=\"0 0 82 76\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"41,4 6,72 76,72\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"41\" y1=\"2\" x2=\"41\" y2=\"74\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":2,"e":"3 lines.","d":"h"},{"t":"Does the letter B have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">B</text><line x1=\"2\" y1=\"32\" x2=\"52\" y2=\"32\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["Yes, vertical","Yes, horizontal","No","Yes, diagonal"],"a":1,"e":"Horizontal line through B.","d":"h"},{"t":"Which shape has NO symmetry?<svg width=\"78\" height=\"74\" viewBox=\"0 0 78 74\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"10,66 70,66 20,8\" fill=\"#fce4ec\" stroke=\"#c0392b\" stroke-width=\"2\"/><circle cx=\"64\" cy=\"14\" r=\"10\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"57\" y1=\"7\" x2=\"71\" y2=\"21\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","o":["Square","Circle","Rectangle","Scalene triangle"],"a":3,"e":"Scalene triangle (all sides different) has no symmetry.","d":"h"},{"t":"How many lines of symmetry does the letter H have?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">H</text><line x1=\"27\" y1=\"2\" x2=\"27\" y2=\"62\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"32\" x2=\"52\" y2=\"32\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":1,"e":"H has both vertical and horizontal=2.","d":"h"},{"t":"How many lines of symmetry does a 5-pointed star have?<svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"40.0\" y1=\"1.0\" x2=\"40.0\" y2=\"79.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"77.1\" y1=\"27.9\" x2=\"2.9\" y2=\"52.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"62.9\" y1=\"71.6\" x2=\"17.1\" y2=\"8.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"17.1\" y1=\"71.6\" x2=\"62.9\" y2=\"8.4\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"2.9\" y1=\"27.9\" x2=\"77.1\" y2=\"52.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><polygon points=\"40.0,4.0 48.8,27.9 74.2,28.9 54.3,44.6 61.2,69.1 40.0,55.0 18.8,69.1 25.7,44.6 5.8,28.9 31.2,27.9\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg>","o":["3","4","5","6"],"a":2,"e":"5-pointed star=5 lines.","d":"h"},{"t":"How many lines of symmetry does a regular hexagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,20.5 60.1,49.5 35.0,64.0 9.9,49.5 9.9,20.5\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","8"],"a":2,"e":"Regular hexagon=6 lines.","d":"h"},{"t":"A line of symmetry divides a shape into two parts that are?","o":["3 equal parts","2 matching halves","4 equal parts","Unequal parts"],"a":1,"e":"2 matching (mirror) halves.","d":"e"},{"t":"How many lines of symmetry does the letter O have?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">O</text><line x1=\"27\" y1=\"2\" x2=\"27\" y2=\"62\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","4","Unlimited"],"a":3,"e":"O is like a circle=unlimited.","d":"h"},{"t":"Does the letter M have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">M</text><line x1=\"27\" y1=\"2\" x2=\"27\" y2=\"62\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["Yes, vertical","Yes, horizontal","No","Yes, diagonal"],"a":0,"e":"Vertical line through M.","d":"h"},{"t":"Which shape has more lines of symmetry: a square or a rectangle?<svg width=\"62\" height=\"62\" viewBox=\"0 0 62 62\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"31.0\" y1=\"3.0\" x2=\"31.0\" y2=\"59.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"50.8\" y1=\"11.2\" x2=\"11.2\" y2=\"50.8\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"59.0\" y1=\"31.0\" x2=\"3.0\" y2=\"31.0\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"50.8\" y1=\"50.8\" x2=\"11.2\" y2=\"11.2\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><polygon points=\"31.0,6.0 56.0,31.0 31.0,56.0 6.0,31.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg><svg width=\"90\" height=\"58\" viewBox=\"0 0 90 58\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"7\" y=\"10\" width=\"96\" height=\"48\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"55\" y1=\"4\" x2=\"55\" y2=\"64\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"34\" x2=\"108\" y2=\"34\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["Rectangle","Square","Equal","Neither"],"a":1,"e":"Square=4, Rectangle=2.","d":"h"},{"t":"Butterfly has which type of symmetry?<svg width=\"100\" height=\"84\" viewBox=\"0 0 100 84\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><ellipse cx=\"25\" cy=\"28\" rx=\"23\" ry=\"17\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(-18 25 28)\"/><ellipse cx=\"75\" cy=\"28\" rx=\"23\" ry=\"17\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(18 75 28)\"/><ellipse cx=\"22\" cy=\"57\" rx=\"17\" ry=\"12\" fill=\"#c39bd3\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(12 22 57)\"/><ellipse cx=\"78\" cy=\"57\" rx=\"17\" ry=\"12\" fill=\"#c39bd3\" stroke=\"#6c3483\" stroke-width=\"2\" transform=\"rotate(-12 78 57)\"/><ellipse cx=\"50\" cy=\"42\" rx=\"5\" ry=\"27\" fill=\"#6c3483\"/><line x1=\"50\" y1=\"16\" x2=\"39\" y2=\"4\" stroke=\"#6c3483\" stroke-width=\"1.5\"/><line x1=\"50\" y1=\"16\" x2=\"61\" y2=\"4\" stroke=\"#6c3483\" stroke-width=\"1.5\"/><circle cx=\"39\" cy=\"4\" r=\"2.5\" fill=\"#8e44ad\"/><circle cx=\"61\" cy=\"4\" r=\"2.5\" fill=\"#8e44ad\"/><line x1=\"50\" y1=\"1\" x2=\"50\" y2=\"82\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["Rotational","Vertical line","Horizontal line","No symmetry"],"a":1,"e":"Butterfly has 1 vertical line of symmetry.","d":"h"},{"t":"Does the letter S have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">S</text><circle cx=\"43\" cy=\"12\" r=\"9\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"36\" y1=\"5\" x2=\"50\" y2=\"19\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","o":["Yes, vertical","Yes, horizontal","No","Yes, diagonal"],"a":2,"e":"S has no line of symmetry (it is NOT symmetric by fold).","d":"h"},{"t":"Which letter has NO symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">F</text><circle cx=\"43\" cy=\"12\" r=\"9\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"36\" y1=\"5\" x2=\"50\" y2=\"19\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","o":["A","H","M","F"],"a":3,"e":"F has no line of symmetry.","d":"h"},{"t":"Can a shape have more than one line of symmetry?","o":["No","Yes","Only circles","Only squares"],"a":1,"e":"Yes! Square has 4, circle has unlimited.","d":"e"},{"t":"Snowflake typically has how many lines of symmetry?<svg width=\"82\" height=\"82\" viewBox=\"0 0 82 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"41.0\" y1=\"3.0\" x2=\"41.0\" y2=\"79.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"60.0\" y1=\"8.1\" x2=\"22.0\" y2=\"73.9\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"73.9\" y1=\"22.0\" x2=\"8.1\" y2=\"60.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"79.0\" y1=\"41.0\" x2=\"3.0\" y2=\"41.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"73.9\" y1=\"60.0\" x2=\"8.1\" y2=\"22.0\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"60.0\" y1=\"73.9\" x2=\"22.0\" y2=\"8.1\" stroke=\"#e74c3c\" stroke-width=\"1\" stroke-dasharray=\"3,2\" opacity=\"0.5\"/><line x1=\"41\" y1=\"41\" x2=\"41.0\" y2=\"5.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"41.0\" y1=\"21.2\" x2=\"34.8\" y2=\"12.4\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41.0\" y1=\"21.2\" x2=\"47.2\" y2=\"12.4\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"72.2\" y2=\"23.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"58.1\" y1=\"31.1\" x2=\"62.7\" y2=\"21.3\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"58.1\" y1=\"31.1\" x2=\"68.9\" y2=\"32.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"72.2\" y2=\"59.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"58.1\" y1=\"50.9\" x2=\"68.9\" y2=\"50.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"58.1\" y1=\"50.9\" x2=\"62.7\" y2=\"60.7\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"41.0\" y2=\"77.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"41.0\" y1=\"60.8\" x2=\"47.2\" y2=\"69.6\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41.0\" y1=\"60.8\" x2=\"34.8\" y2=\"69.6\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"9.8\" y2=\"59.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"23.9\" y1=\"50.9\" x2=\"19.3\" y2=\"60.7\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"23.9\" y1=\"50.9\" x2=\"13.1\" y2=\"50.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"41\" y1=\"41\" x2=\"9.8\" y2=\"23.0\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><line x1=\"23.9\" y1=\"31.1\" x2=\"13.1\" y2=\"32.0\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><line x1=\"23.9\" y1=\"31.1\" x2=\"19.3\" y2=\"21.3\" stroke=\"#2980b9\" stroke-width=\"1.5\"/><circle cx=\"41\" cy=\"41\" r=\"4\" fill=\"#2980b9\"/></svg>","o":["2","3","6","12"],"a":2,"e":"Snowflakes have 6 lines of symmetry.","d":"h"},{"t":"If you fold a shape along its line of symmetry, what happens to the two halves?","o":["Are different","Match exactly","Change shape","Disappear"],"a":1,"e":"Both halves match exactly.","d":"e"},{"t":"How many lines of symmetry does the letter X have?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">X</text><line x1=\"27\" y1=\"2\" x2=\"27\" y2=\"62\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"32\" x2=\"52\" y2=\"32\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":1,"e":"X has 2 lines of symmetry: vertical and horizontal.","d":"h"},{"t":"How many lines of symmetry does a regular pentagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 62.6,26.0 52.0,58.5 18.0,58.5 7.4,26.0\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2.5\"/></svg>","o":["3","4","5","6"],"a":2,"e":"Regular pentagon=5 lines.","d":"h"},{"t":"Which number has vertical symmetry?","o":["3","5","8","9"],"a":2,"e":"8 has a vertical line of symmetry.","d":"m"},{"t":"How many lines of symmetry does a rhombus have?<svg width=\"78\" height=\"78\" viewBox=\"0 0 78 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"39,5 73,39 39,73 5,39\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2\"/><line x1=\"39\" y1=\"2\" x2=\"39\" y2=\"76\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"39\" x2=\"76\" y2=\"39\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":1,"e":"Rhombus=2 lines (diagonals).","d":"h"},{"t":"How many lines of symmetry does a right triangle have?<svg width=\"78\" height=\"74\" viewBox=\"0 0 78 74\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"8,66 8,8 70,66\" fill=\"#fce4ec\" stroke=\"#c0392b\" stroke-width=\"2\"/><rect x=\"8\" y=\"52\" width=\"14\" height=\"14\" fill=\"none\" stroke=\"#c0392b\" stroke-width=\"1.5\"/><circle cx=\"64\" cy=\"14\" r=\"10\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"57\" y1=\"7\" x2=\"71\" y2=\"21\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","o":["0","1","2","3"],"a":0,"e":"Right triangle=0 lines of symmetry.","d":"h"},{"t":"How many lines of symmetry does an arrow pointing to the right have?","o":["0","1","2","3"],"a":1,"e":"Horizontal arrow=1 horizontal line.","d":"e"},{"t":"Which shapes always have at least 1 line of symmetry?","o":["Scalene triangle","Right triangle","Isosceles triangle","All triangles"],"a":2,"e":"Isosceles triangle has 1 line of symmetry.","d":"m"},{"t":"How many lines of symmetry does a heart shape have?<svg width=\"78\" height=\"72\" viewBox=\"0 0 78 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><path d=\"M39,22 Q39,6 22,6 Q8,6 8,26 Q8,50 39,68 Q70,50 70,26 Q70,6 56,6 Q39,6 39,22 Z\" fill=\"#fad4d4\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"39\" y1=\"2\" x2=\"39\" y2=\"70\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["0","1","2","3"],"a":1,"e":"Heart has 1 vertical line of symmetry.","d":"h"},{"t":"Does a heart shape have a line of symmetry?","o":["Yes","No","Only if it is big","Only if it is red"],"a":0,"e":"Yes! A heart has 1 line of symmetry straight down the middle. The left and right halves match.","d":"e"},{"t":"If you fold a square in half, do both sides match exactly?","o":["Yes","No","Only sometimes","Only if you fold it a special way"],"a":0,"e":"Yes! A square has lines of symmetry. Folding it in half (top to bottom, left to right, or corner to corner) gives matching halves.","d":"e"},{"t":"Two triangles can be put together to make a ___.","o":["Circle","Square","Pentagon","Sphere"],"a":1,"e":"Two identical right triangles can be put together to make a square (or a rectangle or parallelogram, depending on the triangles).","d":"e"},{"t":"What does 'line of symmetry' mean?","o":["A line that makes a shape bigger","A line that folds a shape into two matching halves","A line that goes around a shape","A line that makes a shape 3D"],"a":1,"e":"A line of symmetry divides a shape into two halves that are mirror images -- they match exactly when folded.","d":"e"},{"t":"Does a circle have a line of symmetry?","o":["Yes","No","Only a big circle","Only half a circle"],"a":0,"e":"Yes! A circle has many lines of symmetry. Any line through the center divides it into two matching halves.","d":"e"},{"t":"Which shape can you make by putting 2 squares side by side?","o":["Triangle","Rectangle","Circle","Pentagon"],"a":1,"e":"Two squares side by side make a rectangle that is twice as long as it is tall.","d":"e"},{"t":"Does the letter A have a line of symmetry?","o":["Yes, straight down the middle","No, it does not","Yes, across the top","Only capital A"],"a":0,"e":"The capital letter A has a line of symmetry straight down the middle. The left side mirrors the right side.","d":"e"},{"t":"If you cut a rectangle in half from top to bottom, what 2 shapes do you get?","o":["2 triangles","2 smaller rectangles","2 circles","1 square and 1 triangle"],"a":1,"e":"Cutting a rectangle straight down the middle gives you 2 smaller rectangles.","d":"m"},{"t":"Does a square have more than one line of symmetry?","o":["No, just 1","Yes, it has 2","Yes, it has 4","Squares have no lines of symmetry"],"a":2,"e":"A square has 4 lines of symmetry: horizontal, vertical, and 2 diagonal.","d":"e"},{"t":"What shape do you get when you put 4 small triangles together?","o":["A bigger triangle","A circle","A hexagon","A bigger triangle or a square"],"a":3,"e":"Four small triangles can be arranged to make a bigger triangle or a square, depending on how you place them.","d":"m"},{"t":"Does a rectangle have a line of symmetry?","o":["Yes","No","Only a square rectangle","Only a long rectangle"],"a":0,"e":"Yes! A rectangle has 2 lines of symmetry: one horizontal and one vertical through the center.","d":"e"},{"t":"If you fold a shape along a line of symmetry, what happens?","o":["The shape gets bigger","Both halves match up perfectly","The shape turns into a circle","Nothing happens"],"a":1,"e":"When you fold along a line of symmetry, both halves match up perfectly -- one half covers the other exactly.","d":"e"},{"t":"You have 1 big square. You cut it into 4 equal pieces. What shape is each piece?","o":["Triangle","Small square","Circle","Hexagon"],"a":1,"e":"Cutting a square into 4 equal pieces (one horizontal cut, one vertical cut) gives 4 smaller squares.","d":"m"},{"t":"Which of these shapes has NO line of symmetry?","o":["Square","Circle","Scalene triangle with all different sides","Rectangle"],"a":2,"e":"A scalene triangle (all sides different, all angles different) has no line of symmetry. The other shapes all have at least one.","d":"m"},{"t":"Two rectangles placed end to end make a ___.","o":["Circle","Longer rectangle","Triangle","Hexagon"],"a":1,"e":"Two rectangles placed end to end make one longer rectangle.","d":"e"},{"t":"Does a butterfly have symmetry?","o":["Yes, left and right sides match","No, butterflies are not shapes","Only big butterflies","Only when flying"],"a":0,"e":"Yes! A butterfly has symmetry. Its left wing mirrors its right wing, with a line of symmetry down the body.","d":"e"},{"t":"If you put 6 triangles together at a point, what shape can you make?","o":["Square","Rectangle","Hexagon","Pentagon"],"a":2,"e":"Six equilateral triangles arranged around a center point make a hexagon.","d":"m"},{"t":"Does an equilateral triangle (all sides equal) have a line of symmetry?","o":["Yes","No","Only if it is big","Triangles never have symmetry"],"a":0,"e":"Yes! An equilateral triangle has 3 lines of symmetry -- one from each corner to the middle of the opposite side.","d":"e"},{"t":"You split a circle in half. What are the two pieces called?","o":["Quarter circles","Semicircles","Triangles","Rectangles"],"a":1,"e":"Half of a circle is called a semicircle. 'Semi' means half.","d":"e"},{"t":"Which letter does NOT have a line of symmetry: B, O, X, or F?","o":["B","O","X","F"],"a":3,"e":"The letter F has no line of symmetry. B has a horizontal line, O has many, and X has both vertical and horizontal.","d":"e"},{"t":"How many lines of symmetry does a rectangle have (that is NOT a square)?","o":["0","1","2","4"],"a":2,"e":"A non-square rectangle has 2 lines of symmetry: one horizontal and one vertical through the center. Its diagonals are NOT lines of symmetry.","d":"e"},{"t":"Two triangles are put together to make a rectangle. Each triangle has 3 sides. How many sides does the rectangle have?","o":["6","5","4","3"],"a":2,"e":"Even though the triangles had 6 sides total, the joined sides are hidden inside. The rectangle has only 4 sides.","d":"m"},{"t":"Which has MORE lines of symmetry: a square or a non-square rectangle?","o":["A square (4 vs 2)","A rectangle (2 vs 4)","They are equal","Neither has any"],"a":0,"e":"A square has 4 lines of symmetry (horizontal, vertical, and 2 diagonals). A non-square rectangle has only 2 (horizontal and vertical).","d":"m"},{"t":"You cut a square diagonally. What 2 shapes do you get?","o":["2 squares","2 rectangles","2 triangles","1 triangle and 1 rectangle"],"a":2,"e":"Cutting a square along a diagonal creates 2 right triangles. Each triangle has the diagonal as its longest side.","d":"e"},{"t":"Emma says the letter S has a line of symmetry. Is she correct?","o":["Yes, it has a vertical line","Yes, it has a horizontal line","No, S has no line of symmetry","Yes, it has a diagonal line"],"a":2,"e":"The letter S has no line of symmetry. If you fold it any way, the halves do not match. (S does have rotational symmetry, but not a line of symmetry.)","d":"m"},{"t":"You arrange 2 small squares into an L-shape. How many sides does the L-shape have?","o":["4","5","6","8"],"a":2,"e":"An L-shape made from 2 squares has 6 sides. The shared edge becomes interior, creating extra outside corners.","d":"m"},{"t":"How many lines of symmetry does an equilateral triangle have?","o":["0","1","2","3"],"a":3,"e":"An equilateral triangle has 3 lines of symmetry -- one from each vertex to the midpoint of the opposite side.","d":"e"},{"t":"If you put 2 identical right triangles together along their longest sides, what shape can you make?","o":["A bigger triangle","A rectangle","A pentagon","A hexagon"],"a":1,"e":"Two identical right triangles placed together along their longest sides (hypotenuse) form a rectangle.","d":"m"},{"t":"A shape has exactly 1 line of symmetry. Which could it be?","o":["Square","Circle","Isosceles triangle","Regular hexagon"],"a":2,"e":"An isosceles triangle (2 equal sides) has exactly 1 line of symmetry, from the top vertex straight down to the base.","d":"m"},{"t":"You cut a hexagon into 6 equal triangles from the center. How many sides does each triangle have?","o":["2","3","4","6"],"a":1,"e":"Each piece is a triangle, so each has 3 sides -- even though they came from a hexagon.","d":"m"},{"t":"Does the letter H have a line of symmetry?","o":["Yes -- vertical only","Yes -- horizontal only","Yes -- both vertical and horizontal","No line of symmetry"],"a":2,"e":"The capital letter H has 2 lines of symmetry: one vertical (left matches right) and one horizontal (top matches bottom).","d":"e"},{"t":"What shape do you get if you put 4 identical squares together in a 2-by-2 grid?","o":["A rectangle","A bigger square","A triangle","A pentagon"],"a":1,"e":"Four squares in a 2x2 arrangement make one bigger square. Each side is twice as long as one small square's side.","d":"m"},{"t":"Amy folds a rectangle in half along its line of symmetry (top to bottom). The folded shape is a ___.","o":["Triangle","Smaller rectangle","Circle","Pentagon"],"a":1,"e":"Folding a rectangle in half along its horizontal center gives a smaller rectangle, half the height of the original.","d":"m"},{"t":"Which shape has MORE lines of symmetry: an equilateral triangle or a non-square rectangle?","o":["Equilateral triangle (3 vs 2)","Non-square rectangle (2 vs 3)","They are equal","Neither has any"],"a":0,"e":"An equilateral triangle has 3 lines of symmetry. A non-square rectangle has 2. The triangle has more!","d":"h"},{"t":"You have a big triangle. You draw a line from one side to another, parallel to the base. How many shapes do you now have?","o":["1","2","3","4"],"a":1,"e":"Drawing a line parallel to the base cuts the triangle into 2 shapes: a smaller triangle on top and a trapezoid on the bottom.","d":"h"},{"t":"Can you split a rectangle into 2 equal triangles?","o":["Yes, by cutting corner to corner diagonally","No, rectangles cannot make triangles","Only if it is a square","Yes, but only into 4 triangles"],"a":0,"e":"Yes! Drawing a diagonal line from one corner to the opposite corner splits any rectangle into 2 equal right triangles.","d":"e"},{"t":"How many lines of symmetry does a regular pentagon (all sides equal) have?","o":["0","2","5","10"],"a":2,"e":"A regular pentagon has 5 lines of symmetry -- one from each vertex to the midpoint of the opposite side.","d":"e"},{"t":"Which of these cannot be made by combining 2 identical squares?","o":["A rectangle","An L-shape","A triangle","A bigger shape with 4 or more sides"],"a":2,"e":"Two squares cannot make a triangle. Squares have right angles and straight sides that combine into rectangles or L-shapes, not triangles.","d":"m"},{"t":"A shape and its mirror image look exactly the same. What must the shape have?","o":["Curved sides","At least 6 sides","At least one line of symmetry","No corners"],"a":2,"e":"If a shape looks the same as its mirror image, it has at least one line of symmetry. The mirror line is the line of symmetry.","d":"e"},{"t":"You arrange 3 equilateral triangles in a row, sharing sides. How many sides does the new shape have?","o":["3","4","5","9"],"a":2,"e":"Three triangles in a row (forming a trapezoid-like strip) have 5 outer sides. The shared edges are interior and do not count.","d":"m"},{"t":"How many lines of symmetry does a regular hexagon have? More or fewer than a square?","o":["6 -- more than a square's 4","4 -- the same as a square","2 -- fewer than a square","8 -- more than a square"],"a":0,"e":"A regular hexagon has 6 lines of symmetry. A square has 4. So the hexagon has MORE lines of symmetry.","d":"e"},{"t":"Can you fold a rectangle in half to make two squares? When is this possible?","o":["Always possible","Only when the rectangle is exactly twice as long as it is wide","Never possible","Only with big rectangles"],"a":1,"e":"You can fold a rectangle into 2 squares ONLY when the length is exactly twice the width. Then each half is a perfect square.","d":"e"},{"t":"Mia says cutting a square corner-to-corner gives 2 right triangles. She also says each triangle has 2 lines of symmetry. Is she fully correct?","o":["Yes, both statements are correct","The first part is correct, but each triangle has only 1 line of symmetry","The first part is correct, but each triangle has 0 lines of symmetry","Both statements are wrong"],"a":1,"e":"Mia is right that cutting diagonally gives 2 right triangles. But each is an isosceles right triangle with only 1 line of symmetry (along its own line from the right angle to the hypotenuse midpoint).","d":"h"},{"t":"Ben says all shapes with 4 lines of symmetry must be squares. Can you find a counterexample?","o":["He is correct -- only squares have 4 lines","No, but a circle has more","Yes -- a regular octagon also has more than 4","The plus sign (+) shape has 4 lines and is not a square"],"a":3,"e":"A plus sign (+) shape has 4 lines of symmetry but is not a square. Ben is wrong -- other shapes can have 4 lines of symmetry too.","d":"m"},{"t":"You cut a regular hexagon from center to each corner. How many triangles do you get, and what kind are they?","o":["3 right triangles","6 equilateral triangles","4 isosceles triangles","6 right triangles"],"a":1,"e":"Cutting from center to each of the 6 corners makes 6 equilateral triangles. Each has 3 equal sides.","d":"m"},{"t":"A shape is made from 4 identical squares arranged in a T-shape. How many lines of symmetry does it have?","o":["0","1","2","4"],"a":1,"e":"A T-shaped tetromino has exactly 1 line of symmetry -- a vertical line down the center of the top of the T. It is not symmetric left-right if flipped another way.","d":"m"},{"t":"Sam says: 'If I fold a shape in half and the pieces do not match, the shape has no symmetry.' Is he correct?","o":["Yes, that fold proves no symmetry","No -- he might have folded along the wrong line","No -- all shapes have symmetry","Yes -- you only need to try one fold"],"a":1,"e":"Sam is wrong. He may have folded along a line that is not a line of symmetry. He needs to try ALL possible fold lines before concluding there is no symmetry.","d":"m"},{"t":"You combine a square and a triangle (sharing one full side). How many sides does the new shape have?","o":["4","5","6","7"],"a":1,"e":"A square has 4 sides and a triangle has 3 sides = 7 total. But they share 1 side (hidden inside): 7 - 2 = 5 outside sides.","d":"m"},{"t":"A regular polygon has the same number of lines of symmetry as it has sides. How many lines of symmetry does a regular octagon have?","o":["4","6","8","10"],"a":2,"e":"A regular octagon has 8 sides, so it has 8 lines of symmetry. Regular polygons always have as many lines of symmetry as sides.","d":"h"},{"t":"Rosa puts 2 regular hexagons together sharing one full side. How many sides does the new shape have?","o":["8","10","12","6"],"a":1,"e":"Each hexagon has 6 sides = 12 total. They share 1 side, removing 2 edges from the outside: 12 - 2 = 10 sides.","d":"m"},{"t":"Jaya says a parallelogram (not a rectangle) has 2 lines of symmetry. Is she correct?","o":["Yes, horizontal and vertical","Yes, both diagonals","No, a non-rectangular parallelogram has 0 lines of symmetry","No, it has exactly 1"],"a":2,"e":"A parallelogram that is not a rectangle has 0 lines of symmetry. No fold line will make the two halves match. (It does have rotational symmetry, but no line symmetry.)","d":"m"},{"t":"You have 12 identical equilateral triangles. What is the largest regular polygon you could tile with them?","o":["Square","Regular hexagon","Regular octagon","Regular pentagon"],"a":1,"e":"You cannot tile a square or octagon with equilateral triangles. But 6 equilateral triangles make a regular hexagon, and 12 make 2 hexagons or a larger hexagonal shape.","d":"h"},{"t":"Kai cuts a rectangle diagonally both ways (making an X). How many pieces does he get, and what shape are they?","o":["2 rectangles","4 identical triangles","4 triangles (2 pairs of identical ones)","3 triangles and 1 square"],"a":2,"e":"Two diagonal cuts through a rectangle make 4 triangles. If the rectangle is not a square, you get 2 pairs: 2 wider triangles and 2 taller triangles.","d":"m"},{"t":"How many total lines of symmetry do a square and an equilateral triangle have COMBINED?","o":["5","6","7","8"],"a":2,"e":"A square has 4 lines of symmetry. An equilateral triangle has 3. Combined: 4 + 3 = 7.","d":"e"},{"t":"Alex says you can make a hexagon by arranging 3 rhombuses around a center point. Is this possible?","o":["No, rhombuses cannot make hexagons","Yes, 3 identical rhombuses can tile a regular hexagon","Only with squares, not rhombuses","You would need 6 rhombuses"],"a":1,"e":"Yes! Three identical rhombuses (each made of 2 equilateral triangles) can be arranged around a center to form a regular hexagon.","d":"m"},{"t":"A shape has exactly 2 lines of symmetry. Which of these could it be?","o":["Equilateral triangle","Regular hexagon","Non-square rectangle","Regular pentagon"],"a":2,"e":"A non-square rectangle has exactly 2 lines of symmetry (horizontal and vertical). The triangle has 3, hexagon has 6, pentagon has 5.","d":"m"},{"t":"You remove 1 small square from the corner of a big square. How many sides does the remaining shape have?","o":["4","5","6","8"],"a":2,"e":"Removing a corner square creates a notch. The new shape has 6 sides: the 3 remaining big square sides, plus 2 small edges from the cut, plus 1 remaining edge.","d":"m"},{"t":"Maya says a circle has exactly 1 line of symmetry. Leo says it has infinitely many. Who is correct?","o":["Maya","Leo","Both","Neither"],"a":1,"e":"Leo is correct. ANY line through the center of a circle is a line of symmetry. There are infinitely many such lines.","d":"h"},{"t":"You compose a new shape using 1 square and 2 equilateral triangles (one on the top side, one on the bottom side). How many sides does it have?","o":["4","6","8","10"],"a":1,"e":"The square has 4 sides. Each triangle adds 2 new sides but covers 1 square side. Total: 4 - 2 (covered) + 4 (new triangle sides) = 6 sides.","d":"h"},{"t":"What is the fewest number of lines of symmetry any regular polygon can have?","o":["0","1","2","3"],"a":3,"e":"The simplest regular polygon is an equilateral triangle, which has 3 lines of symmetry. No regular polygon has fewer than 3, because the fewest sides a polygon can have is 3.","d":"m"}],"quiz":[{"t":"Does a square have symmetry?","o":["Yes, 1 line","Yes, 4 lines","No","Only sometimes"],"a":1,"e":"A square has 4 lines of symmetry (2 across, 2 diagonal)."},{"t":"How many lines of symmetry does a circle have?<svg width=\"68\" height=\"68\" viewBox=\"0 0 68 68\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"65.0\" y1=\"34.0\" x2=\"3.0\" y2=\"34.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"55.9\" y1=\"55.9\" x2=\"12.1\" y2=\"12.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"34.0\" y1=\"65.0\" x2=\"34.0\" y2=\"3.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"12.1\" y1=\"55.9\" x2=\"55.9\" y2=\"12.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><circle cx=\"34\" cy=\"34\" r=\"29\" fill=\"#dff0f8\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><text x=\"34\" y=\"39\" text-anchor=\"middle\" font-size=\"11\" fill=\"#2980b9\" font-weight=\"bold\">∞</text></svg>","o":["1","4","8","Unlimited"],"a":3,"e":"Any line through the center of a circle creates symmetry!"},{"t":"Does the letter Z have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">Z</text><circle cx=\"43\" cy=\"12\" r=\"9\" fill=\"none\" stroke=\"#e74c3c\" stroke-width=\"2\"/><line x1=\"36\" y1=\"5\" x2=\"50\" y2=\"19\" stroke=\"#e74c3c\" stroke-width=\"2\"/></svg>","o":["Yes","No"],"a":1,"e":"The letter Z has NO line of symmetry — folding it doesn't make matching halves."},{"t":"Does the letter A have a line of symmetry?<svg width=\"54\" height=\"64\" viewBox=\"0 0 54 64\" style=\"display:inline-block;vertical-align:middle;margin:0 4px\"><text x=\"27\" y=\"54\" text-anchor=\"middle\" font-size=\"48\" font-weight=\"bold\" font-family=\"Arial,sans-serif\" fill=\"#5d3a8e\">A</text><line x1=\"27\" y1=\"2\" x2=\"27\" y2=\"62\" stroke=\"#27ae60\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["Yes, vertical","Yes, horizontal","No","Yes, diagonal"],"a":0,"e":"A vertical line down the middle of A makes two matching halves."},{"t":"How many lines of symmetry does a rectangle have?","o":["1","2","3","4"],"a":1,"e":"A rectangle has 2 lines of symmetry: one horizontal, one vertical."},{"t":"What does the word symmetry mean?","o":["4 or more sides","Both halves match when folded","Always a circle","0 corners"],"a":1,"e":"Symmetry = you can fold the shape so both halves match perfectly."}]}],"unitQuiz":[{"t":"How many sides does a hexagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,20.5 60.1,49.5 35.0,64.0 9.9,49.5 9.9,20.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","8"],"a":2,"e":"6 sides.","d":"m"},{"t":"Which shape has no sides and no corners at all?","o":["Triangle","Square","Circle","Pentagon"],"a":2,"e":"Circle.","d":"e"},{"t":"How many faces does a cube have?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["4","5","6","8"],"a":2,"e":"6 faces.","d":"m"},{"t":"A soup can is shaped like which 3D shape?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"9\" y=\"24\" width=\"54\" height=\"44\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"68\" rx=\"27\" ry=\"10\" fill=\"#85c1e9\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"24\" rx=\"27\" ry=\"10\" fill=\"#d6eaf8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["Cube","Sphere","Cone","Cylinder"],"a":3,"e":"Cylinder.","d":"m"},{"t":"An ice cream cone is shaped like which 3D shape?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"36,4 7,70 65,70\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"70\" rx=\"29\" ry=\"9\" fill=\"#f7dc6f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg>","o":["Cube","Sphere","Cone","Cylinder"],"a":2,"e":"Cone.","d":"m"},{"t":"Which shape has all 4 sides the same length?","o":["Rectangle","Rhombus","Square","Trapezoid"],"a":2,"e":"Square=all 4 sides equal.","d":"e"},{"t":"How many sides does an octagon have?","o":["6","7","8","9"],"a":2,"e":"An octagon has 8 sides and 8 corners.","d":"e"},{"t":"A ball is shaped like which 3D shape?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><circle cx=\"36\" cy=\"36\" r=\"30\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"36\" rx=\"30\" ry=\"10\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/><ellipse cx=\"36\" cy=\"36\" rx=\"10\" ry=\"30\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/></svg>","o":["Cube","Sphere","Cone","Pyramid"],"a":1,"e":"Sphere.","d":"h"},{"t":"How many sides does a pentagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 62.6,26.0 52.0,58.5 18.0,58.5 7.4,26.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","7"],"a":1,"e":"5 sides.","d":"m"},{"t":"How many edges does a cube have?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["8","10","12","14"],"a":2,"e":"12 edges.","d":"h"},{"t":"A shape with 3 sides and 3 corners is called a?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,49.5 9.9,49.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Square","Triangle","Pentagon","Hexagon"],"a":1,"e":"Triangle.","d":"h"},{"t":"How many lines of symmetry does a square have?<svg width=\"82\" height=\"82\" viewBox=\"0 0 82 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"11\" y=\"11\" width=\"60\" height=\"60\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"41\" y1=\"4\" x2=\"41\" y2=\"78\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"4\" y1=\"41\" x2=\"78\" y2=\"41\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"7\" y1=\"7\" x2=\"75\" y2=\"75\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"75\" y1=\"7\" x2=\"7\" y2=\"75\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":3,"e":"4 lines.","d":"m"},{"t":"How many faces does a square pyramid have?<svg width=\"82\" height=\"76\" viewBox=\"0 0 82 76\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"41,4 9,63 73,63\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 41,63 41,4\" fill=\"#7fb3d3\" stroke=\"#2980b9\" stroke-width=\"2\"/><polygon points=\"9,63 73,63 73,70 9,70\" fill=\"#5d8aa8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["3","4","5","6"],"a":2,"e":"5 faces.","d":"m"},{"t":"Which 3D shape has zero edges?","o":["Cube","Sphere","Cone","Cylinder"],"a":1,"e":"Sphere.","d":"m"},{"t":"How many sides does a rectangle have?","o":["2","3","4","5"],"a":2,"e":"4 sides.","d":"e"},{"t":"How many lines of symmetry does a circle have?<svg width=\"68\" height=\"68\" viewBox=\"0 0 68 68\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><line x1=\"65.0\" y1=\"34.0\" x2=\"3.0\" y2=\"34.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"55.9\" y1=\"55.9\" x2=\"12.1\" y2=\"12.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"34.0\" y1=\"65.0\" x2=\"34.0\" y2=\"3.0\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><line x1=\"12.1\" y1=\"55.9\" x2=\"55.9\" y2=\"12.1\" stroke=\"#e74c3c\" stroke-width=\"1.5\" stroke-dasharray=\"4,3\" opacity=\"0.7\"/><circle cx=\"34\" cy=\"34\" r=\"29\" fill=\"#dff0f8\" stroke=\"#2980b9\" stroke-width=\"2.5\"/><text x=\"34\" y=\"39\" text-anchor=\"middle\" font-size=\"11\" fill=\"#2980b9\" font-weight=\"bold\">∞</text></svg>","o":["1","4","8","Unlimited"],"a":3,"e":"Unlimited.","d":"h"},{"t":"How many vertices does a cube have?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["4","6","8","12"],"a":2,"e":"8 vertices.","d":"h"},{"t":"A cereal box is shaped like which 3D shape?","o":["Cube","Sphere","Cylinder","Rectangular prism"],"a":3,"e":"Rectangular prism.","d":"e"},{"t":"How many corners does a hexagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,20.5 60.1,49.5 35.0,64.0 9.9,49.5 9.9,20.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","8"],"a":2,"e":"6 corners.","d":"m"},{"t":"How many lines of symmetry does a rectangle have?<svg width=\"108\" height=\"66\" viewBox=\"0 0 108 66\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"7\" y=\"10\" width=\"94\" height=\"46\" fill=\"#fde8d8\" stroke=\"#e67e22\" stroke-width=\"2\"/><line x1=\"54\" y1=\"4\" x2=\"54\" y2=\"62\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/><line x1=\"2\" y1=\"33\" x2=\"106\" y2=\"33\" stroke=\"#e74c3c\" stroke-width=\"2\" stroke-dasharray=\"5,3\"/></svg>","o":["1","2","3","4"],"a":1,"e":"2 lines.","d":"h"},{"t":"How many vertices does a cone have?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"36,4 7,70 65,70\" fill=\"#f9e79f\" stroke=\"#f39c12\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"70\" rx=\"29\" ry=\"9\" fill=\"#f7dc6f\" stroke=\"#f39c12\" stroke-width=\"2\"/></svg>","o":["0","1","2","3"],"a":1,"e":"1 vertex (tip).","d":"m"},{"t":"How many sides does a rhombus have?","o":["3","4","5","6"],"a":1,"e":"4 sides.","d":"e"},{"t":"A dice is shaped like which 3D shape?<svg width=\"88\" height=\"78\" viewBox=\"0 0 88 78\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"44,4 77,22 44,40 11,22\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"11,22 44,40 44,68 11,50\" fill=\"#a569bd\" stroke=\"#6c3483\" stroke-width=\"2\"/><polygon points=\"44,40 77,22 77,50 44,68\" fill=\"#8e44ad\" stroke=\"#6c3483\" stroke-width=\"2\"/></svg>","o":["Sphere","Cone","Cube","Cylinder"],"a":2,"e":"Cube.","d":"h"},{"t":"Which shape has 5 sides and 5 corners?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 62.6,26.0 52.0,58.5 18.0,58.5 7.4,26.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Pentagon","Hexagon","Square","Octagon"],"a":0,"e":"Pentagon.","d":"h"},{"t":"How many edges does a cylinder have?<svg width=\"72\" height=\"82\" viewBox=\"0 0 72 82\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><rect x=\"9\" y=\"24\" width=\"54\" height=\"44\" fill=\"#aed6f1\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"68\" rx=\"27\" ry=\"10\" fill=\"#85c1e9\" stroke=\"#2980b9\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"24\" rx=\"27\" ry=\"10\" fill=\"#d6eaf8\" stroke=\"#2980b9\" stroke-width=\"2\"/></svg>","o":["0","1","2","3"],"a":2,"e":"2 circular edges.","d":"h"},{"t":"Which of these letters has a vertical line of symmetry?","o":["B","C","D","A"],"a":3,"e":"A has a vertical line of symmetry.","d":"e"},{"t":"How many vertices does a triangle have?","o":["2","3","4","5"],"a":1,"e":"3 vertices.","d":"e"},{"t":"Which of the following is a 3D shape?","o":["Triangle","Circle","Square","Sphere"],"a":3,"e":"Sphere is 3D.","d":"e"},{"t":"What is a flat, 2-dimensional shape called?","o":["3D","Solid","2D","Volume"],"a":2,"e":"2D=flat.","d":"e"},{"t":"How many curved faces does a sphere have?<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><circle cx=\"36\" cy=\"36\" r=\"30\" fill=\"#d7bde2\" stroke=\"#6c3483\" stroke-width=\"2\"/><ellipse cx=\"36\" cy=\"36\" rx=\"30\" ry=\"10\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/><ellipse cx=\"36\" cy=\"36\" rx=\"10\" ry=\"30\" fill=\"none\" stroke=\"#8e44ad\" stroke-width=\"1.5\" opacity=\"0.5\"/></svg>","o":["0","1","2","3"],"a":1,"e":"1 curved face.","d":"h"}],"testBank":[{"t":"How many sides does a hexagon have?","o":["4","5","6","8"],"a":2,"e":"Hexagon=6 sides.","d":"e"},{"t":"Which shape has no sides and no corners at all?","o":["Triangle","Square","Circle","Pentagon"],"a":2,"e":"Circle has no sides.","d":"e"},{"t":"A shape has 3 sides and 3 corners. What shape is it?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 60.1,49.5 9.9,49.5\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["Square","Triangle","Rectangle","Pentagon"],"a":1,"e":"Triangle=3 sides.","d":"h"},{"t":"How many sides does a pentagon have?<svg width=\"70\" height=\"70\" viewBox=\"0 0 70 70\" style=\"display:inline-block;vertical-align:middle;margin:0 5px\"><polygon points=\"35.0,6.0 62.6,26.0 52.0,58.5 18.0,58.5 7.4,26.0\" fill=\"#e8d5f5\" stroke=\"#6c3483\" stroke-width=\"2.5\"/></svg>","o":["4","5","6","7"],"a":1,"e":"Pentagon=5 sides.","d":"m"},{"t":"Which shape has all 4 sides the same length?","o":["Rectangle","Rhombus","Square","Trapezoid"],"a":2,"e":"Square has 4 equal sides.","d":"m"},{"t":"Square and rectangle both have how many sides?","o":["3","4","5","6"],"a":1,"e":"Both have 4 sides.","d":"e"},{"t":"What is the name of a shape that has 8 sides?<svg width=\"70\" he
y=\"2\" width=\"272\" height=\"15\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"13\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Key: ⭐ = 3</text><line x1=\"4\" y1=\"17\" x2=\"276\" y2=\"17\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"8\" y=\"38\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Sunday</text><text x=\"65\" y=\"42\" font-size=\"16\">⭐⭐⭐⭐</text><line x1=\"4\" y1=\"56\" x2=\"276\" y2=\"56\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"8\" y=\"76\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Monday</text><text x=\"65\" y=\"80\" font-size=\"16\">⭐⭐</text><line x1=\"4\" y1=\"88\" x2=\"276\" y2=\"88\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["18","12","16","20"],"a":0,"e":"(4+2) × 3 = 18.","d":"h"},{"t":"A pictograph shows Apples: 5, Oranges: 3. Key = 2. How many more apples? <svg width=\"560\" height=\"192\" viewBox=\"0 0 280 96\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"272\" height=\"15\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"13\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Key: 🍎 = 2</text><line x1=\"4\" y1=\"17\" x2=\"276\" y2=\"17\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"8\" y=\"38\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Apples</text><text x=\"65\" y=\"42\" font-size=\"16\">🍎🍎🍎🍎🍎</text><line x1=\"4\" y1=\"56\" x2=\"276\" y2=\"56\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"8\" y=\"76\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Oranges</text><text x=\"65\" y=\"80\" font-size=\"16\">🍎🍎🍎</text><line x1=\"4\" y1=\"88\" x2=\"276\" y2=\"88\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["2","3","5","4"],"a":3,"e":"Apples: 10, Oranges: 6. 10 − 6 = 4 more.","d":"h"},{"t":"Why do pictographs use pictures instead of numbers? <svg width=\"660\" height=\"150\" viewBox=\"0 0 220 52\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"6\" width=\"212\" height=\"18\" fill=\"#e8f4ff\" rx=\"4\"/><text x=\"8\" y=\"19\" font-size=\"9\" fill=\"#333\" font-weight=\"bold\">Key: 📖 = 2 books</text><text x=\"8\" y=\"40\" font-size=\"7\" fill=\"#666\">Always check the key before counting!</text></svg>","o":["Looks prettier","Each picture represents data quickly","Required by law","Easier to write"],"a":1,"e":"Pictures make data easy to see and compare at a glance.","d":"h"},{"t":"In a pictograph, the key shows 1 picture = 4. A row has 3 pictures. Value? <svg width=\"560\" height=\"144\" viewBox=\"0 0 280 72\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"272\" height=\"15\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"13\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Key: ⭐ = 4</text><line x1=\"4\" y1=\"17\" x2=\"276\" y2=\"17\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"8\" y=\"43\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Row</text><text x=\"65\" y=\"47\" font-size=\"16\">⭐⭐⭐</text><line x1=\"4\" y1=\"62\" x2=\"276\" y2=\"62\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["8","10","12","16"],"a":2,"e":"3 × 4 = 12.","d":"h"},{"t":"A pictograph shows Class A: 4 pictures, Class B: 3 pictures. Key = 2. Total? <svg width=\"560\" height=\"192\" viewBox=\"0 0 280 96\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"272\" height=\"15\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"13\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Key: ⭐ = 2</text><line x1=\"4\" y1=\"17\" x2=\"276\" y2=\"17\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"8\" y=\"38\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Class A</text><text x=\"65\" y=\"42\" font-size=\"16\">⭐⭐⭐⭐</text><line x1=\"4\" y1=\"56\" x2=\"276\" y2=\"56\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"8\" y=\"76\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Class B</text><text x=\"65\" y=\"80\" font-size=\"16\">⭐⭐⭐</text><line x1=\"4\" y1=\"88\" x2=\"276\" y2=\"88\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["12","14","16","18"],"a":1,"e":"(4+3) × 2 = 14.","d":"h"},{"t":"A pictograph shows Red: 3 pictures, Blue: 5 pictures. Key = 2. More for Blue? <svg width=\"560\" height=\"192\" viewBox=\"0 0 280 96\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"272\" height=\"15\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"13\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Key: ⭐ = 2</text><line x1=\"4\" y1=\"17\" x2=\"276\" y2=\"17\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"8\" y=\"38\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Red</text><text x=\"65\" y=\"42\" font-size=\"16\">⭐⭐⭐</text><line x1=\"4\" y1=\"56\" x2=\"276\" y2=\"56\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"8\" y=\"76\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Blue</text><text x=\"65\" y=\"80\" font-size=\"16\">⭐⭐⭐⭐⭐</text><line x1=\"4\" y1=\"88\" x2=\"276\" y2=\"88\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["2","3","4","5"],"a":2,"e":"Blue: 10, Red: 6. 10 − 6 = 4 more.","d":"h"},{"t":"A graph shows favorite fruits: Apples=6, Bananas=3, Grapes=8. Which fruit has the most votes?","o":["Apples","Bananas","Grapes","They are the same"],"a":2,"e":"Grapes has 8, which is the biggest number. Grapes has the most votes.","d":"m"},{"t":"Look at the bar graph. Dogs=9, Cats=4, Fish=7. How many students chose cats?","o":["4","7","9","20"],"a":0,"e":"The bar for cats goes up to 4. So 4 students chose cats.","d":"e"},{"t":"A graph shows: Red=5, Blue=10, Yellow=3. Which color got the fewest votes?","o":["Red","Blue","Yellow","They are the same"],"a":2,"e":"Yellow has 3, which is the smallest number. Yellow got the fewest votes.","d":"e"},{"t":"A pictograph shows each star = 1 vote. Tacos has 6 stars and Pizza has 9 stars. How many votes did tacos get?","o":["6","9","15","3"],"a":0,"e":"Each star = 1 vote. Tacos has 6 stars, so tacos got 6 votes.","d":"m"},{"t":"A tally chart shows: Soccer IIII, Baseball IIII I, Basketball III. How many votes did soccer get?","o":["3","4","5","6"],"a":1,"e":"Count the tally marks for soccer: IIII = 4. Soccer got 4 votes.","d":"e"},{"t":"A graph shows: Chocolate=11, Vanilla=5, Strawberry=8. Which flavor has the most votes?","o":["Vanilla","Strawberry","Chocolate","They are the same"],"a":2,"e":"Chocolate has 11, which is the biggest number. Chocolate has the most.","d":"m"},{"t":"A bar graph shows: Spring=4, Summer=9, Fall=6, Winter=1. Which season has the fewest votes?","o":["Spring","Summer","Fall","Winter"],"a":3,"e":"Winter has 1, which is the smallest number. Winter has the fewest.","d":"m"},{"t":"A pictograph shows each star = 1 kid. Bikes has 5 stars and Scooters has 5 stars. Did the same number of kids pick each?","o":["No, bikes has more","No, scooters has more","Yes, they are the same","Cannot tell"],"a":2,"e":"Bikes = 5 and Scooters = 5. They have the same number of stars, so yes, they are the same.","d":"e"},{"t":"A graph shows: Lions=4, Bears=7, Eagles=2. Which animal has the most votes?","o":["Lions","Bears","Eagles","They are the same"],"a":1,"e":"Bears has 7, which is the biggest number. Bears has the most votes.","d":"m"},{"t":"A tally chart shows: Carrots III, Corn IIII II, Peas IIII. How many votes does corn have?","o":["3","4","5","7"],"a":3,"e":"IIII is 5 and II is 2 more. 5 + 2 = 7. Corn has 7 votes.","d":"e"},{"t":"A bar graph shows: Swings=10, Slide=4, Sandbox=7. Which has fewer votes, slide or sandbox?","o":["Sandbox","They are the same","Slide","Swings"],"a":2,"e":"Slide has 4 and sandbox has 7. 4 is less than 7, so slide has fewer.","d":"m"},{"t":"A graph shows: Sunny=6, Rainy=6, Snowy=3. Which two weather types have the same number of votes?","o":["Sunny and Snowy","Rainy and Snowy","Sunny and Rainy","None are the same"],"a":2,"e":"Sunny and Rainy both have 6. They are the same!","d":"e"},{"t":"The data shows: Math=5, Reading=8, Art=12. A student says art got the fewest votes. Is that correct?","o":["Yes, art got the fewest","No, math got the fewest","No, reading got the fewest","They all got the same"],"a":1,"e":"Math = 5, Reading = 8, Art = 12. Math has the fewest with 5. Art has the most. The student is wrong.","d":"m"},{"t":"A bar graph shows: Monkeys=9, Giraffes=3, Elephants=6. Put the animals in order from fewest to most votes.","o":["Monkeys, Elephants, Giraffes","Giraffes, Elephants, Monkeys","Elephants, Giraffes, Monkeys","Giraffes, Monkeys, Elephants"],"a":1,"e":"Giraffes = 3 (fewest), Elephants = 6 (middle), Monkeys = 9 (most).","d":"e"},{"t":"A pictograph shows each star = 1 student. Milk has 7 stars, Juice has 4 stars, Water has 7 stars. How many categories have the same number?","o":["0","1","2","3"],"a":2,"e":"Milk and Water both have 7 stars. That is 2 categories with the same number.","d":"m"},{"t":"A graph shows: Crayons=8, Markers=3, Pencils=5. Which supply is between markers and crayons in number of votes?","o":["Crayons","Markers","Pencils","None of them"],"a":2,"e":"Markers = 3, Pencils = 5, Crayons = 8. Pencils (5) is between 3 and 8.","d":"e"},{"t":"A bar graph shows: Dogs=8, Cats=5, Birds=8. Do dogs and birds have the same number of votes?","o":["No, dogs has more","No, birds has more","Yes, they are the same","Cannot tell"],"a":2,"e":"Dogs = 8 and Birds = 8. They are the same number!","d":"e"},{"t":"A tally chart shows: Camping III, Hiking IIII IIII, Fishing IIII I. Which activity got the most votes?","o":["Camping","Hiking","Fishing","Camping and Fishing tied"],"a":1,"e":"Camping = 3, Hiking = 9, Fishing = 6. Hiking got the most with 9 votes.","d":"e"},{"t":"A graph shows: Trucks=2, Trains=5, Planes=9. Which vehicle has the fewest votes?","o":["Trucks","Trains","Planes","They are the same"],"a":0,"e":"Trucks has 2, which is the smallest number. Trucks has the fewest.","d":"m"},{"t":"A bar graph shows: Red=4, Blue=4, Green=4, Yellow=4. What can you say about this data?","o":["Red has the most","Yellow has the fewest","All four colors have the same number of votes","Green and Blue are tied"],"a":2,"e":"All four colors have 4 votes each. They are all the same!","d":"e"},{"t":"A graph shows: Apples=6, Bananas=4, Grapes=5. How many fruits were picked in all?","o":["10","11","15","14"],"a":2,"e":"Add them all: 6 + 4 + 5 = 15 fruits in all.","d":"e"},{"t":"A bar graph shows: Dogs=9, Cats=5. How many more students picked dogs than cats?","o":["14","3","4","5"],"a":2,"e":"Dogs = 9 and Cats = 5. 9 - 5 = 4 more students picked dogs.","d":"e"},{"t":"A pictograph shows each star = 2 students. Red has 4 stars, Blue has 6 stars. How many students picked blue?","o":["6","8","10","12"],"a":3,"e":"Each star = 2 students. Blue has 6 stars: 6 x 2 = 12 students.","d":"m"},{"t":"A tally chart shows: Pizza IIII III, Tacos IIII, Burgers IIII II. How many voted for pizza and burgers combined?","o":["12","13","15","17"],"a":2,"e":"Pizza = 8 and Burgers = 7. 8 + 7 = 15 voted for pizza and burgers combined.","d":"e"},{"t":"A bar graph shows: Soccer=8, Baseball=5, Basketball=7. How many total students voted?","o":["13","15","20","21"],"a":2,"e":"8 + 5 + 7 = 20 total students voted.","d":"e"},{"t":"A graph shows the data is missing for one category. Chocolate=11, Vanilla=???, Strawberry=3. There were 20 votes total. How many voted for vanilla?","o":["4","5","6","7"],"a":2,"e":"Chocolate + Strawberry = 11 + 3 = 14. Total = 20. 20 - 14 = 6 voted for vanilla.","d":"m"},{"t":"A bar graph shows: Bikes=4, Scooters=9, Skateboards=2. How many more students chose scooters than skateboards?","o":["5","6","7","11"],"a":2,"e":"Scooters = 9 and Skateboards = 2. 9 - 2 = 7 more chose scooters.","d":"e"},{"t":"A pictograph shows each star = 5 votes. Summer has 3 stars and Winter has 1 star. How many more voted for summer than winter?","o":["2","5","10","20"],"a":2,"e":"Summer = 15, Winter = 5. 15 - 5 = 10 more voted for summer.","d":"e"},{"t":"A tally chart shows: Lions IIII II, Bears III, Eagles IIII. Which animal is in second place?","o":["Lions","Bears","Eagles","Lions and Eagles tied"],"a":2,"e":"Lions = 7 (first), Eagles = 4 (second), Bears = 3 (third). Eagles is in second place.","d":"e"},{"t":"A graph shows: Swimming=5, Running=8, Jumping=6. How many students chose swimming and jumping combined?","o":["11","13","14","19"],"a":0,"e":"Swimming = 5, Jumping = 6. 5 + 6 = 11 students combined.","d":"e"},{"t":"A bar graph shows: Sunny=8, Rainy=4, Snowy=3. How many more sunny days than rainy days?","o":["3","4","5","12"],"a":1,"e":"Sunny = 8 and Rainy = 4. 8 - 4 = 4 more sunny days.","d":"e"},{"t":"A pictograph shows each star = 2 kids. Trucks has 5 stars and Cars has 7 stars. How many total kids voted for trucks and cars?","o":["12","14","20","24"],"a":3,"e":"Trucks = 10, Cars = 14. 10 + 14 = 24 total kids.","d":"m"},{"t":"A graph shows: Hamsters=2, Rabbits=7, Turtles=5. How many fewer students picked hamsters than rabbits?","o":["3","4","5","9"],"a":2,"e":"Rabbits = 7 and Hamsters = 2. 7 - 2 = 5 fewer students picked hamsters.","d":"e"},{"t":"A bar graph shows: Spring=3, Summer=10, Fall=4, Winter=3. Which two seasons got the same number of votes?","o":["Spring and Summer","Summer and Fall","Spring and Winter","Fall and Winter"],"a":2,"e":"Spring = 3 and Winter = 3. They both got the same number of votes.","d":"m"},{"t":"A graph shows: Art=12, Music=7. How many more students chose art than music?","o":["3","4","5","19"],"a":2,"e":"Art = 12 and Music = 7. 12 - 7 = 5 more students chose art.","d":"e"},{"t":"A tally chart shows: Crayons IIII II, Markers IIII, Pencils IIII III. How many supplies were voted for in all?","o":["15","17","19","21"],"a":2,"e":"Crayons = 7, Markers = 4, Pencils = 8. 7 + 4 + 8 = 19 total.","d":"e"},{"t":"A pictograph shows each star = 5 students. Math has 4 stars and Reading has 2 stars. How many total students chose these two subjects?","o":["6","20","25","30"],"a":3,"e":"Math = 20, Reading = 10. 20 + 10 = 30 total students.","d":"e"},{"t":"A bar graph shows: Roses=4, Tulips=8, Daisies=6. Luis says tulips got twice as many votes as roses. Is he right?","o":["Yes, 8 is double 4","No, 8 is not double 4","Yes, 8 is double 6","No, they are the same"],"a":0,"e":"Double of 4 is 8. Yes, Luis is right! Tulips (8) got twice as many as Roses (4).","d":"m"},{"t":"A graph shows: Milk=5, Juice=11. How many fewer students picked milk?","o":["5","6","16","7"],"a":1,"e":"Juice = 11 and Milk = 5. 11 - 5 = 6 fewer students picked milk.","d":"e"},{"t":"A bar graph shows: Elephants=6, Monkeys=8, Tigers=4. How many students voted for elephants and tigers together?","o":["10","12","14","18"],"a":0,"e":"Elephants = 6, Tigers = 4. 6 + 4 = 10 students together.","d":"e"},{"t":"A bar graph shows: Apples=8, Bananas=5, Grapes=7. How many students voted in all? If there are 25 students in the class, how many did NOT vote?","o":["20 voted, 5 did not","18 voted, 7 did not","20 voted, 7 did not","15 voted, 10 did not"],"a":0,"e":"8 + 5 + 7 = 20 voted. 25 - 20 = 5 did not vote.","d":"m"},{"t":"A graph shows: Dogs=9, Cats=6, Fish=3. If 2 more kids pick fish, how many would fish have? Would it be more or less than cats?","o":["5, less than cats","5, more than cats","8, more than cats","5, same as cats"],"a":0,"e":"Fish has 3 + 2 = 5. Cats has 6. 5 is less than 6, so fish is still less than cats.","d":"m"},{"t":"A pictograph shows each star = 5 votes. Soccer has 4 stars and Baseball has 2 stars. Kai says the difference is 2 votes. What mistake did Kai make?","o":["He subtracted stars (4-2=2) instead of actual votes (20-10=10)","He added instead of subtracted","He is correct","He read the wrong rows"],"a":0,"e":"Soccer = 20, Baseball = 10. Difference = 10 votes. Kai subtracted the star counts instead of the real vote totals.","d":"h"},{"t":"A bar graph shows: Red=4, Blue=7, Green=9. How many voted for red and blue together? Is it more or less than green?","o":["11, more than green","11, less than green","13, more than green","10, more than green"],"a":0,"e":"Red + Blue = 4 + 7 = 11. Green = 9. 11 is more than 9!","d":"e"},{"t":"A tally chart shows: Chocolate IIII IIII I, Vanilla IIII III, Strawberry IIII. The class has 28 students. How many students did NOT vote?","o":["3","4","5","6"],"a":2,"e":"Chocolate: IIII IIII I = 5+5+1 = 11. Vanilla = 8, Strawberry = 4. Total = 11+8+4 = 23. 28 - 23 = 5 did not vote.","d":"m"},{"t":"A graph shows: Bikes=7, Scooters=4, Skateboards=9. If 3 kids change from skateboards to bikes, what would the new totals be for each?","o":["Bikes=10, Scooters=4, Skateboards=6","Bikes=4, Scooters=4, Skateboards=12","Bikes=10, Scooters=7, Skateboards=6","Bikes=7, Scooters=7, Skateboards=6"],"a":0,"e":"Bikes gains 3: 7+3=10. Skateboards loses 3: 9-3=6. Scooters stays at 4.","d":"m"},{"t":"A pictograph shows each star = 2 kids. Art has 5 stars, Music has 4 stars, PE has 6 stars. Which two subjects together have the same total as PE?","o":["Art and Music together do NOT equal PE","Art and Music together equal PE","Music and PE equal Art","None of them match"],"a":0,"e":"Art=10, Music=8, PE=12. Art+Music=18. That is NOT equal to PE (12). So no pair equals PE alone.","d":"m"},{"t":"A bar graph shows: Lions=6, Bears=8, Eagles=4. Sophie says bears got twice as many votes as eagles. Jake says bears got 2 more than lions. Who is right?","o":["Only Sophie","Only Jake","Both are right","Neither is right"],"a":2,"e":"Sophie: double of 4 is 8. Bears = 8. Correct! Jake: 8 - 6 = 2. Bears has 2 more than lions. Correct! Both are right.","d":"m"},{"t":"The data shows: Sunny=9, Rainy=2, Snowy=4, Cloudy=5. How many students voted in all? How many more sunny than rainy days?","o":["20 total, 7 more sunny","20 total, 11 more sunny","18 total, 7 more sunny","16 total, 7 more sunny"],"a":0,"e":"Total: 9+2+4+5=20. Sunny - Rainy = 9-2=7 more sunny days.","d":"m"},{"t":"A tally chart shows: Carrots III, Corn IIII II, Peas IIII, Beans ???. There were 20 votes total. How many voted for beans?","o":["4","5","6","7"],"a":2,"e":"Carrots=3, Corn=7, Peas=4. Total so far=14. 20-14=6 voted for beans.","d":"e"},{"t":"A graph shows: Math=7, Reading=10, Art=8. Noah says reading and art together equal 16. He then says that is double math. What should Noah check?","o":["16 is not double 7 (double 7 is 14)","Noah added wrong","16 is actually double 8","Noah is completely correct"],"a":0,"e":"Reading + Art = 10 + 8 = 18, not 16. Noah added wrong. And double of 7 is 14, not 16 or 18.","d":"h"},{"t":"A pictograph shows each star = 2 votes. Spring has 3 stars, Summer has 7 stars, Fall has 5 stars, Winter has 2 stars. Which season got the most votes and how many?","o":["Summer with 14 votes","Summer with 7 votes","Fall with 10 votes","Spring with 6 votes"],"a":0,"e":"Summer = 7 x 2 = 14 votes. That is the most. (Spring=6, Fall=10, Winter=4.)","d":"m"},{"t":"A bar graph shows: Trucks=5, Cars=12, Trains=3. How many fewer voted for trains than cars? If 4 more kids vote for trains, would trains pass trucks?","o":["9 fewer; yes, trains would have 7","9 fewer; no, trains would have 7","7 fewer; yes, trains would pass","9 fewer; no, trains stays at 3"],"a":0,"e":"12-3=9 fewer. Trains + 4 = 7. Trucks = 5. 7 > 5, so yes, trains would pass trucks.","d":"m"},{"t":"A graph shows: Swings=8, Slide=6, Sandbox=4. If each category gets 2 more votes, would swings still have the most?","o":["Yes, Swings=10, Slide=8, Sandbox=6","No, they would all be tied","No, Slide would have the most","Yes, but Slide would tie with Swings"],"a":0,"e":"Swings: 8+2=10. Slide: 6+2=8. Sandbox: 4+2=6. Swings still has the most.","d":"m"},{"t":"A pictograph shows each star = 5 kids. Cats has 3 stars, Dogs has 4 stars, Birds has 1 star. Ella says there were 35 votes total. Is Ella right?","o":["No, the total is 40","Yes, 35 is correct","No, the total is 30","No, the total is 45"],"a":0,"e":"Cats=15, Dogs=20, Birds=5. Total=15+20+5=40. Ella said 35, which is wrong. The total is 40.","d":"m"},{"t":"A bar graph shows: Camping=5, Hiking=8, Fishing=7. Which two activities together have the same total as hiking plus fishing?","o":["There is no pair that equals 15","Camping and Hiking equal 15 but that uses hiking","Camping and Fishing = 12, not 15","Camping and Hiking both used"],"a":0,"e":"Hiking+Fishing=15. The only other activity is camping (5). No pair of the three that doesn't include hiking or fishing equals 15. There is no such pair.","d":"e"},{"t":"A tally chart shows: Milk IIII I, Juice IIII IIII II, Water IIII. Maria says juice got exactly double the votes of water. Is she correct?","o":["No, juice has 12 and double of 4 is 8","Yes, juice is double water","No, juice has 10 and double of 4 is 8","No, juice has 12 and double of 4 is 12... wait, she is correct"],"a":0,"e":"Juice = 5+5+2 = 12. Water = 4. Double of 4 is 8, not 12. So juice is NOT double water. Maria is incorrect. (Juice is actually triple water: 4 x 3 = 12.)","d":"e"},{"t":"A graph shows: Red=8, Blue=5, Yellow=7, Green=10. Put them in order from most to fewest votes.","o":["Blue, Yellow, Red, Green","Green, Red, Yellow, Blue","Green, Yellow, Red, Blue","Red, Green, Yellow, Blue"],"a":1,"e":"Green=10, Red=8, Yellow=7, Blue=5. From most to fewest: Green, Red, Yellow, Blue.","d":"m"},{"t":"Two classes collected data on favorite animals. Class A: Dogs=12, Cats=8. Class B: Dogs=7, Cats=11. Which class had more students vote, and by how much?","o":["Class A by 2","Class B by 2","They are the same","Class A by 4"],"a":0,"e":"Class A total: 12+8=20. Class B total: 7+11=18. Class A had 2 more students.","d":"m"},{"t":"A pictograph shows each star = 2 students. Crayons has 6 stars, Markers has 4 stars, Pencils has ???. There are 26 students total. How many stars should the pencils row have?","o":["2 stars","3 stars","4 stars","5 stars"],"a":1,"e":"Crayons = 12, Markers = 8. Total so far = 20. 26-20=6 students for pencils. 6/2 = 3 stars.","d":"m"}],"quiz":[{"t":"Use the pictograph below. Key: 📖=2 books. How many books did Sofia read? <svg width=\"500\" height=\"258\" viewBox=\"0 0 210 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"202\" height=\"14\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"12\" font-size=\"7\" fill=\"#333\" font-weight=\"bold\">Key: 📖 = 2</text><line x1=\"4\" y1=\"16\" x2=\"206\" y2=\"16\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"6\" y=\"31\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Emma</text><text x=\"55\" y=\"33\" font-size=\"14\">📖📖📖</text><line x1=\"4\" y1=\"37\" x2=\"206\" y2=\"37\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"49\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Liam</text><text x=\"55\" y=\"51\" font-size=\"14\">📖📖</text><line x1=\"4\" y1=\"55\" x2=\"206\" y2=\"55\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"67\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Sofia</text><text x=\"55\" y=\"69\" font-size=\"14\">📖📖📖📖</text><line x1=\"4\" y1=\"73\" x2=\"206\" y2=\"73\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"85\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Noah</text><text x=\"55\" y=\"87\" font-size=\"14\">📖</text><line x1=\"4\" y1=\"104\" x2=\"206\" y2=\"104\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["4","6","10","8"],"a":3,"e":"Sofia: 4 pictures × 2 = 8 books."},{"t":"Use the pictograph below. Who read the most books? <svg width=\"500\" height=\"258\" viewBox=\"0 0 210 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"202\" height=\"14\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"12\" font-size=\"7\" fill=\"#333\" font-weight=\"bold\">Key: 📖 = 2</text><line x1=\"4\" y1=\"16\" x2=\"206\" y2=\"16\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"6\" y=\"31\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Emma</text><text x=\"55\" y=\"33\" font-size=\"14\">📖📖📖</text><line x1=\"4\" y1=\"37\" x2=\"206\" y2=\"37\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"49\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Liam</text><text x=\"55\" y=\"51\" font-size=\"14\">📖📖</text><line x1=\"4\" y1=\"55\" x2=\"206\" y2=\"55\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"67\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Sofia</text><text x=\"55\" y=\"69\" font-size=\"14\">📖📖📖📖</text><line x1=\"4\" y1=\"73\" x2=\"206\" y2=\"73\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"85\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Noah</text><text x=\"55\" y=\"87\" font-size=\"14\">📖</text><line x1=\"4\" y1=\"104\" x2=\"206\" y2=\"104\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["Emma","Liam","Sofia","Noah"],"a":2,"e":"Sofia has 4 pictures — the most."},{"t":"Use the pictograph below. Key: 📖=2. Total books by all students? <svg width=\"500\" height=\"258\" viewBox=\"0 0 210 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"202\" height=\"14\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"12\" font-size=\"7\" fill=\"#333\" font-weight=\"bold\">Key: 📖 = 2</text><line x1=\"4\" y1=\"16\" x2=\"206\" y2=\"16\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"6\" y=\"31\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Emma</text><text x=\"55\" y=\"33\" font-size=\"14\">📖📖📖</text><line x1=\"4\" y1=\"37\" x2=\"206\" y2=\"37\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"49\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Liam</text><text x=\"55\" y=\"51\" font-size=\"14\">📖📖</text><line x1=\"4\" y1=\"55\" x2=\"206\" y2=\"55\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"67\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Sofia</text><text x=\"55\" y=\"69\" font-size=\"14\">📖📖📖📖</text><line x1=\"4\" y1=\"73\" x2=\"206\" y2=\"73\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"85\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Noah</text><text x=\"55\" y=\"87\" font-size=\"14\">📖</text><line x1=\"4\" y1=\"104\" x2=\"206\" y2=\"104\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["20","18","22","24"],"a":0,"e":"10 pictures × 2 = 20 books."},{"t":"Use the pictograph below. Key: ⭐=3. How many stars did Cora earn? <svg width=\"500\" height=\"258\" viewBox=\"0 0 210 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"202\" height=\"14\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"12\" font-size=\"7\" fill=\"#333\" font-weight=\"bold\">Key: ⭐ = 3</text><line x1=\"4\" y1=\"16\" x2=\"206\" y2=\"16\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"6\" y=\"31\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Ava</text><text x=\"55\" y=\"33\" font-size=\"14\">⭐⭐⭐⭐</text><line x1=\"4\" y1=\"37\" x2=\"206\" y2=\"37\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"49\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Ben</text><text x=\"55\" y=\"51\" font-size=\"14\">⭐⭐</text><line x1=\"4\" y1=\"55\" x2=\"206\" y2=\"55\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"67\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Cora</text><text x=\"55\" y=\"69\" font-size=\"14\">⭐⭐⭐⭐⭐</text><line x1=\"4\" y1=\"73\" x2=\"206\" y2=\"73\" stroke=\"#eee\" stroke-width=\"1\"/><text x=\"6\" y=\"85\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Dan</text><text x=\"55\" y=\"87\" font-size=\"14\">⭐⭐⭐</text><line x1=\"4\" y1=\"104\" x2=\"206\" y2=\"104\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["9","12","15","18"],"a":2,"e":"5 × 3 = 15 stars."},{"t":"What does the KEY in a pictograph tell you? <svg width=\"660\" height=\"150\" viewBox=\"0 0 220 52\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"6\" width=\"212\" height=\"18\" fill=\"#e8f4ff\" rx=\"4\"/><text x=\"8\" y=\"19\" font-size=\"9\" fill=\"#333\" font-weight=\"bold\">Key: 📖 = 2 books</text><text x=\"8\" y=\"40\" font-size=\"7\" fill=\"#666\">Always check the key before counting!</text></svg>","o":["The graph heading","What each picture equals","How tall bars should be","The chart direction"],"a":1,"e":"The key tells you what each picture is worth."},{"t":"In a pictograph, 1 picture = 5. There are 4 pictures. Total? <svg width=\"560\" height=\"144\" viewBox=\"0 0 280 72\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"4\" y=\"2\" width=\"272\" height=\"15\" fill=\"#e8f4ff\" rx=\"3\"/><text x=\"8\" y=\"13\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Key: ⭐ = 5</text><line x1=\"4\" y1=\"17\" x2=\"276\" y2=\"17\" stroke=\"#ddd\" stroke-width=\"1\"/><text x=\"8\" y=\"43\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Row</text><text x=\"65\" y=\"47\" font-size=\"16\">⭐⭐⭐⭐</text><line x1=\"4\" y1=\"62\" x2=\"276\" y2=\"62\" stroke=\"#ddd\" stroke-width=\"1\"/></svg>","o":["15","20","25","30"],"a":1,"e":"4 × 5 = 20."}]},{"points":["A line plot shows data on a number line","Each × mark stands for one data point","Stack × marks to show more than one of the same value","The tallest stack is the most common value"],"examples":[{"c":"#229954","tag":"Reading a Line Plot","p":"What does each part mean?","s":"<svg width=\"560\" height=\"302\" viewBox=\"0 0 200 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><text x=\"100\" y=\"11\" text-anchor=\"middle\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Pets in Class</text><line x1=\"12\" y1=\"86\" x2=\"192\" y2=\"86\" stroke=\"#333\" stroke-width=\"2\"/><line x1=\"20\" y1=\"83\" x2=\"20\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"20\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">1</text><text x=\"20\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"20\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"73\" y1=\"83\" x2=\"73\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"73\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">2</text><text x=\"73\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"37\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"126\" y1=\"83\" x2=\"126\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"126\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">3</text><text x=\"126\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"126\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"126\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"179\" y1=\"83\" x2=\"179\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"179\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">4</text><text x=\"179\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"106\" text-anchor=\"middle\" font-size=\"7\" fill=\"#888\">Number of Pets</text></svg>","a":"Tallest stack = most common value ✅"},{"c":"#229954","tag":"Most & Least Common","p":"Pets in Class plot:","s":"<svg width=\"560\" height=\"302\" viewBox=\"0 0 200 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><text x=\"100\" y=\"11\" text-anchor=\"middle\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Pets in Class</text><line x1=\"12\" y1=\"86\" x2=\"192\" y2=\"86\" stroke=\"#333\" stroke-width=\"2\"/><line x1=\"20\" y1=\"83\" x2=\"20\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"20\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">1</text><text x=\"20\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"20\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"73\" y1=\"83\" x2=\"73\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"73\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">2</text><text x=\"73\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"37\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"126\" y1=\"83\" x2=\"126\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"126\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">3</text><text x=\"126\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"126\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"126\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"179\" y1=\"83\" x2=\"179\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"179\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">4</text><text x=\"179\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"106\" text-anchor=\"middle\" font-size=\"7\" fill=\"#888\">Number of Pets</text></svg>","a":"Most = 2 pets, Least = 4 pets ✅"},{"c":"#229954","tag":"Finding the Total","p":"How many students total?","s":"<svg width=\"560\" height=\"302\" viewBox=\"0 0 200 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><text x=\"100\" y=\"11\" text-anchor=\"middle\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Pets in Class</text><line x1=\"12\" y1=\"86\" x2=\"192\" y2=\"86\" stroke=\"#333\" stroke-width=\"2\"/><line x1=\"20\" y1=\"83\" x2=\"20\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"20\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">1</text><text x=\"20\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"20\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"73\" y1=\"83\" x2=\"73\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"73\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">2</text><text x=\"73\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"73\" y=\"37\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"126\" y1=\"83\" x2=\"126\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"126\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">3</text><text x=\"126\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"126\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"126\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"179\" y1=\"83\" x2=\"179\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"179\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">4</text><text x=\"179\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"106\" text-anchor=\"middle\" font-size=\"7\" fill=\"#888\">Number of Pets</text></svg>","a":"10 students total ✅"}],"practice":[{"q":"Which value has the most ×s? <svg width=\"400\" height=\"216\" viewBox=\"0 0 200 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><text x=\"100\" y=\"11\" text-anchor=\"middle\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Favorite Number</text><line x1=\"12\" y1=\"86\" x2=\"192\" y2=\"86\" stroke=\"#333\" stroke-width=\"2\"/><line x1=\"35\" y1=\"83\" x2=\"35\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"35\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">1</text><text x=\"35\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"35\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"100\" y1=\"83\" x2=\"100\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"100\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">2</text><text x=\"100\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"165\" y1=\"83\" x2=\"165\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"165\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">3</text><text x=\"165\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"106\" text-anchor=\"middle\" font-size=\"7\" fill=\"#888\">Number</text></svg>","a":"2","h":"Value 2 has 3 marks — the most stacked!","e":"📈"},{"q":"What is the total count? <svg width=\"400\" height=\"216\" viewBox=\"0 0 200 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><text x=\"100\" y=\"11\" text-anchor=\"middle\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Test Scores</text><line x1=\"12\" y1=\"86\" x2=\"192\" y2=\"86\" stroke=\"#333\" stroke-width=\"2\"/><line x1=\"35\" y1=\"83\" x2=\"35\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"35\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">4</text><text x=\"35\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"35\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"100\" y1=\"83\" x2=\"100\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"100\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">5</text><text x=\"100\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"63\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"50\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"37\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><line x1=\"165\" y1=\"83\" x2=\"165\" y2=\"89\" stroke=\"#555\" stroke-width=\"1.5\"/><text x=\"165\" y=\"99\" text-anchor=\"middle\" font-size=\"9\" fill=\"#333\">6</text><text x=\"165\" y=\"76\" text-anchor=\"middle\" font-size=\"12\" fill=\"#229954\" font-weight=\"bold\">×</text><text x=\"100\" y=\"106\" text-anchor=\"middle\" font-size=\"7\" fill=\"#888\">Score</text></svg>","a":"7","h":"2 + 4 + 1 = 7 total × marks!","e":"📊"},{"q":"Which value is least common? <svg width=\"400\" height=\"216\" viewBox=\"0 0 200 108\" style=\"display:block;margin:8px auto;border-radius:8px;background:#f9f9f9\"><text x=\"100\" y=\"11\" text-anchor=\"middle\" font-size=\"8\" fill=\"#333\" font-weight=\"bold\">Daily Steps</text><line x1=\"12\" y1=\"86\" x2=\"192\" y2=\"86\" stroke=
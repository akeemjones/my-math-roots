// Unit 3: Add & Subtract to 200
_mergeUnitData(2, {"lessons":[{"points":["Line up ones and tens","Add ONES first, then tens","If ones add to 10 or more, REGROUP (move 1 ten)"],"examples":[{"c":"#e67e22","tag":"No Regrouping","p":"23 + 45 = ?","s":"<table class=\"col-math\"><tr><td></td><td>2</td><td>3</td></tr><tr class=\"cm-bottom\"><td class=\"cm-op\">+</td><td>4</td><td>5</td></tr><tr class=\"cm-line\"><td colspan=\"3\"><hr></td></tr><tr class=\"cm-result\"><td></td><td>6</td><td>8</td></tr></table><br>Ones: 3 + 5 = 8<br>Tens: 2 + 4 = 6","a":"23 + 45 = 68 ✅"},{"c":"#e67e22","tag":"With Regrouping","p":"47 + 36 = ?","s":"<table class=\"col-math\"><tr class=\"cm-regroup\"><td></td><td>1</td><td></td></tr><tr><td></td><td>4</td><td>7</td></tr><tr class=\"cm-bottom\"><td class=\"cm-op\">+</td><td>3</td><td>6</td></tr><tr class=\"cm-line\"><td colspan=\"3\"><hr></td></tr><tr class=\"cm-result\"><td></td><td>8</td><td>3</td></tr></table><br>Ones: 7 + 6 = 13 → write <b>3</b>, regroup <b>1</b> ten<br>Tens: 4 + 3 + 1(carried) = <b>8</b><br><br><button onclick=\"playCarryAnim(this)\" class=\"cca-btn\" style=\"background:#e67e22\">🎬 Watch Step by Step</button>","a":"47 + 36 = 83 ✅"},{"c":"#e67e22","tag":"With Regrouping","p":"58 + 27 = ?","s":"<table class=\"col-math\"><tr class=\"cm-regroup\"><td></td><td>1</td><td></td></tr><tr><td></td><td>5</td><td>8</td></tr><tr class=\"cm-bottom\"><td class=\"cm-op\">+</td><td>2</td><td>7</td></tr><tr class=\"cm-line\"><td colspan=\"3\"><hr></td></tr><tr class=\"cm-result\"><td></td><td>8</td><td>5</td></tr></table><br>Ones: 8 + 7 = 15 → write <b>5</b>, regroup <b>1</b> ten<br>Tens: 5 + 2 + 1(carried) = <b>8</b>","a":"58 + 27 = 85 ✅"}],"practice":[{"q":"34 + 25 = ?","a":"59","h":"Ones: 4+5=9. Tens: 3+2=5. No regrouping!","e":"➕"},{"q":"46 + 37 = ?","a":"83","h":"Ones: 6+7=13, write 3 regroup 1 ten. Tens: 4+3+1=8","e":"🍎"},{"q":"55 + 28 = ?","a":"83","h":"Ones: 5+8=13, write 3 regroup 1 ten. Tens: 5+2+1=8","e":"🍊"}],"qBank":[{"t":"What is 34 + 25?","o":["42","69","59","85"],"a":2,"e":"Ones:4+5=9. Tens:3+2=5. No regroup.","d":"e"},{"t":"What is 47 + 36?","o":["83","56","93","40"],"a":0,"e":"Ones:7+6=13, write 3 regroup 1 ten. Tens:4+3+1=8.","d":"e"},{"t":"What is 58 + 27?","o":["70","95","50","85"],"a":3,"e":"Ones:8+7=15, write 5 regroup 1 ten. Tens:5+2+1=8.","d":"e"},{"t":"What is 39 + 45?","o":["64","94","84","50"],"a":2,"e":"Ones:9+5=14, write 4 regroup 1 ten. Tens:3+4+1=8.","d":"e"},{"t":"What is 62 + 79?","o":["141","120","151","100"],"a":0,"e":"Ones:2+9=11, write 1 regroup 1 ten. Tens:6+7+1=14.","d":"e"},{"t":"What is 55 + 38?","o":["40","83","93","150"],"a":2,"e":"Ones:5+8=13, write 3 regroup 1 ten. Tens:5+3+1=9.","d":"e"},{"t":"What is 46 + 54?","o":["90","100","91","101"],"a":1,"e":"Ones:6+4=10, write 0 regroup 1 ten. Tens:4+5+1=10.","d":"e"},{"t":"What is 73 + 19?","o":["92","75","102","60"],"a":0,"e":"Ones:3+9=12, write 2 regroup 1 ten. Tens:7+1+1=9.","d":"e"},{"t":"What is 28 + 65?","o":["50","140","93","82"],"a":2,"e":"Ones:8+5=13, write 3 regroup 1 ten. Tens:2+6+1=9.","d":"e"},{"t":"What is 57 + 34?","o":["71","45","130","91"],"a":3,"e":"Ones:7+4=11, write 1 regroup 1 ten. Tens:5+3+1=9.","d":"e"},{"t":"What does REGROUP mean?","o":["Regroup 10 ones as 1 ten","Start over","Subtract instead","Skip to next"],"a":0,"e":"Regrouping means regrouping 10 ones for 1 ten and regrouping.","d":"e"},{"t":"What is 66 + 27?","o":["50","93","83","145"],"a":1,"e":"Ones:6+7=13, write 3 regroup 1 ten. Tens:6+2+1=9.","d":"e"},{"t":"What is 45 + 48?","o":["78","83","140","93"],"a":3,"e":"Ones:5+8=13, write 3 regroup 1 ten. Tens:4+4+1=9.","d":"e"},{"t":"What is 83 + 9?","o":["80","102","92","65"],"a":2,"e":"Ones:3+9=12, write 2 regroup 1 ten. Tens:8+0+1=9.","d":"e"},{"t":"What is 37 + 46?","o":["56","83","93","40"],"a":1,"e":"Ones:7+6=13, write 3 regroup 1 ten. Tens:3+4+1=8.","d":"e"},{"t":"When do you regroup in addition?","o":["When ones column is 10+","Always","When tens column is 10+","Never"],"a":0,"e":"You regroup (regroup) when the ones column reaches 10 or more.","d":"e"},{"t":"What is 54 + 37?","o":["80","45","140","91"],"a":3,"e":"Ones:4+7=11, write 1 regroup 1 ten. Tens:5+3+1=9.","d":"e"},{"t":"What is 68 + 25?","o":["78","83","93","150"],"a":2,"e":"Ones:8+5=13, write 3 regroup 1 ten. Tens:6+2+1=9.","d":"e"},{"t":"What is 75 + 16?","o":["80","55","130","91"],"a":3,"e":"Ones:5+6=11, write 1 regroup 1 ten. Tens:7+1+1=9.","d":"e"},{"t":"What is 49 + 44?","o":["77","93","83","150"],"a":1,"e":"Ones:9+4=13, write 3 regroup 1 ten. Tens:4+4+1=9.","d":"e"},{"t":"Which addition problem requires regrouping?","o":["31+24","42+37","56+38","61+15"],"a":2,"e":"56+38: ones 6+8=14, needs regroup!","d":"e"},{"t":"What is 86 + 7?","o":["79","93","83","150"],"a":1,"e":"Ones:6+7=13, write 3 regroup 1 ten. Tens:8+0+1=9.","d":"e"},{"t":"What is 23 + 79?","o":["102","92","80","60"],"a":0,"e":"Ones:3+9=12, write 2 regroup 1 ten. Tens:2+7+1=10.","d":"e"},{"t":"What is 64 + 27?","o":["80","55","91","130"],"a":2,"e":"Ones:4+7=11, write 1 regroup 1 ten. Tens:6+2+1=9.","d":"e"},{"t":"What is 78 + 16?","o":["84","60","130","94"],"a":3,"e":"Ones:8+6=14, write 4 regroup 1 ten. Tens:7+1+1=9.","d":"e"},{"t":"What is 35 + 58?","o":["70","93","83","140"],"a":1,"e":"Ones:5+8=13, write 3 regroup 1 ten. Tens:3+5+1=9.","d":"m"},{"t":"Add ones first, then tens. In 47 + 36, what is 7 + 6?","o":["11","12","13","14"],"a":2,"e":"7+6=13. Write 3, regroup 1 ten.","d":"h"},{"t":"What is 94 + 7?","o":["101","90","111","75"],"a":0,"e":"Ones:4+7=11, write 1 regroup 1 ten. Tens:9+0+1=10.","d":"m"},{"t":"What is 26 + 37?","o":["50","73","40","63"],"a":3,"e":"Ones:6+7=13, write 3 regroup 1 ten. Tens:2+3+1=6.","d":"e"},{"t":"What is 88 + 5?","o":["79","93","83","150"],"a":1,"e":"Ones:8+5=13, write 3 regroup 1 ten. Tens:8+0+1=9.","d":"m"},{"t":"What is 52 + 36?","o":["78","88","86","98"],"a":1,"e":"Add the ones: 2 + 6 = 8. Add the tens: 50 + 30 = 80. Then 80 + 8 = 88.","d":"m"},{"t":"What is 41 + 18?","o":["69","59","49","58"],"a":1,"e":"Add the ones: 1 + 8 = 9. Add the tens: 40 + 10 = 50. Then 50 + 9 = 59.","d":"e"},{"t":"What is 63 + 24?","o":["97","77","87","89"],"a":2,"e":"Add the ones: 3 + 4 = 7. Add the tens: 60 + 20 = 80. Then 80 + 7 = 87.","d":"m"},{"t":"What is 70 + 45?","o":["105","125","115","95"],"a":2,"e":"Add the ones: 0 + 5 = 5. Add the tens: 70 + 40 = 110. Then 110 + 5 = 115.","d":"m"},{"t":"What is 50 + 82?","o":["122","132","142","112"],"a":1,"e":"Add the ones: 0 + 2 = 2. Add the tens: 50 + 80 = 130. Then 130 + 2 = 132.","d":"m"},{"t":"What is 23 + 45?","o":["78","68","58","88"],"a":1,"e":"Add the ones: 3 + 5 = 8. Add the tens: 20 + 40 = 60. Then 60 + 8 = 68.","d":"e"},{"t":"What is 91 + 8?","o":["98","89","99","100"],"a":2,"e":"Add the ones: 1 + 8 = 9. The tens stay at 90. Then 90 + 9 = 99.","d":"m"},{"t":"Leo has 35 marbles. He finds 14 more. How many marbles does Leo have now?","o":["59","49","39","48"],"a":1,"e":"Add 35 + 14. Ones: 5 + 4 = 9. Tens: 30 + 10 = 40. Total: 49.","d":"m"},{"t":"What is 60 + 31?","o":["81","91","71","101"],"a":1,"e":"Add the ones: 0 + 1 = 1. Add the tens: 60 + 30 = 90. Then 90 + 1 = 91.","d":"m"},{"t":"What is 44 + 33?","o":["67","87","77","78"],"a":2,"e":"Add the ones: 4 + 3 = 7. Add the tens: 40 + 30 = 70. Then 70 + 7 = 77.","d":"e"},{"t":"A store has 72 red apples and 15 green apples. How many apples in all?","o":["97","87","77","86"],"a":1,"e":"Add 72 + 15. Ones: 2 + 5 = 7. Tens: 70 + 10 = 80. Total: 87.","d":"m"},{"t":"What is 80 + 16?","o":["86","106","96","90"],"a":2,"e":"Add the ones: 0 + 6 = 6. Add the tens: 80 + 10 = 90. Then 90 + 6 = 96.","d":"m"},{"t":"Which sum is greater: 42 + 31 or 50 + 20?","o":["42 + 31","50 + 20","They are the same","Cannot tell"],"a":0,"e":"42 + 31 = 73 and 50 + 20 = 70. Since 73 > 70, the first sum is greater.","d":"m"},{"t":"What is 55 + 34?","o":["79","99","89","88"],"a":2,"e":"Add the ones: 5 + 4 = 9. Add the tens: 50 + 30 = 80. Then 80 + 9 = 89.","d":"m"},{"t":"What is 27 + 51?","o":["78","88","68","77"],"a":0,"e":"Add the ones: 7 + 1 = 8. Add the tens: 20 + 50 = 70. Then 70 + 8 = 78.","d":"m"},{"t":"There are 46 birds on a wire. 23 more land. How many birds are there now?","o":["59","79","69","68"],"a":2,"e":"Add 46 + 23. Ones: 6 + 3 = 9. Tens: 40 + 20 = 60. Total: 69.","d":"m"},{"t":"What is 13 + 62?","o":["85","65","75","74"],"a":2,"e":"Add the ones: 3 + 2 = 5. Add the tens: 10 + 60 = 70. Then 70 + 5 = 75.","d":"m"},{"t":"Which is the correct answer for 81 + 14?","o":["94","85","95","96"],"a":2,"e":"Add the ones: 1 + 4 = 5. Add the tens: 80 + 10 = 90. Then 90 + 5 = 95.","d":"m"},{"t":"What is 30 + 64?","o":["84","94","104","74"],"a":1,"e":"Add the ones: 0 + 4 = 4. Add the tens: 30 + 60 = 90. Then 90 + 4 = 94.","d":"m"},{"t":"47 + 35 = ? Use regrouping to solve.","o":["72","82","81","92"],"a":1,"e":"Add the ones: 7 + 5 = 12. Write 2, regroup 1 ten. Add the tens: 4 + 3 + 1 = 8. Answer: 82.","d":"m"},{"t":"Maria has 45 stickers. She gets 28 more. How many stickers does Maria have now?","o":["63","73","83","62"],"a":1,"e":"Add 45 + 28. Ones: 5 + 8 = 13. Regroup 1 ten. Tens: 4 + 2 + 1 = 7. Answer: 73.","d":"m"},{"t":"Which problem needs regrouping? A) 34 + 25  B) 47 + 38  C) 51 + 23  D) 62 + 15","o":["34 + 25","47 + 38","51 + 23","62 + 15"],"a":1,"e":"47 + 38: the ones are 7 + 8 = 15, which is more than 9, so you must regroup. The other problems have ones that add to 9 or less.","d":"h"},{"t":"__ + 36 = 73. What is the missing number?","o":["47","37","27","43"],"a":1,"e":"Think: what plus 36 equals 73? Subtract: 73 - 36 = 37. Check: 37 + 36 = 73.","d":"h"},{"t":"58 + 67 = ?","o":["115","135","125","105"],"a":2,"e":"Add the ones: 8 + 7 = 15. Write 5, regroup 1 ten. Add the tens: 5 + 6 + 1 = 12. Answer: 125.","d":"m"},{"t":"A box has 76 crayons. Another box has 49 crayons. How many crayons altogether?","o":["115","135","125","145"],"a":2,"e":"Add 76 + 49. Ones: 6 + 9 = 15. Regroup 1 ten. Tens: 7 + 4 + 1 = 12. Answer: 125.","d":"h"},{"t":"__ + 55 = 112. What is the missing number?","o":["67","47","57","77"],"a":2,"e":"Think: what plus 55 equals 112? Subtract: 112 - 55 = 57. Check: 57 + 55 = 112.","d":"h"},{"t":"64 + 78 = ?","o":["132","152","142","122"],"a":2,"e":"Add the ones: 4 + 8 = 12. Write 2, regroup 1 ten. Add the tens: 6 + 7 + 1 = 14. Answer: 142.","d":"m"},{"t":"Which strategy helps solve 89 + 46?","o":["Count back from 89","Break apart: 89 + 40 + 6","Subtract 46 from 89","Round 89 down to 80"],"a":1,"e":"Break apart 46 into 40 + 6. Add 89 + 40 = 129, then 129 + 6 = 135. Breaking apart makes adding easier.","d":"m"},{"t":"There are 53 kids on a bus. At the next stop, 39 more get on. How many kids are on the bus?","o":["82","92","102","72"],"a":1,"e":"Add 53 + 39. Ones: 3 + 9 = 12. Regroup 1 ten. Tens: 5 + 3 + 1 = 9. Answer: 92.","d":"m"},{"t":"Which answer is correct for 86 + 37?","o":["113","133","123","103"],"a":2,"e":"Add the ones: 6 + 7 = 13. Regroup 1 ten. Add the tens: 8 + 3 + 1 = 12. Answer: 123.","d":"m"},{"t":"29 + __ = 81. What is the missing number?","o":["62","52","42","58"],"a":1,"e":"Think: 29 + what = 81? Subtract: 81 - 29 = 52. Check: 29 + 52 = 81.","d":"h"},{"t":"Which problem does NOT need regrouping? A) 56 + 27  B) 43 + 52  C) 68 + 45  D) 79 + 14","o":["56 + 27","43 + 52","68 + 45","79 + 14"],"a":1,"e":"43 + 52: the ones are 3 + 2 = 5, no regrouping needed. All other problems have ones that add above 9.","d":"h"},{"t":"A farm has 67 chickens and 85 ducks. How many birds does the farm have?","o":["142","162","152","132"],"a":2,"e":"Add 67 + 85. Ones: 7 + 5 = 12. Regroup 1 ten. Tens: 6 + 8 + 1 = 15. Answer: 152.","d":"h"},{"t":"73 + 48 = ?","o":["111","131","121","101"],"a":2,"e":"Add the ones: 3 + 8 = 11. Write 1, regroup 1 ten. Add the tens: 7 + 4 + 1 = 12. Answer: 121.","d":"m"},{"t":"Jada had some stickers. She got 44 more and now has 91. How many did she start with?","o":["57","47","37","53"],"a":1,"e":"Think: __ + 44 = 91. Subtract: 91 - 44 = 47. Jada started with 47 stickers.","d":"h"},{"t":"55 + 86 = ?","o":["131","151","141","121"],"a":2,"e":"Add the ones: 5 + 6 = 11. Regroup 1 ten. Tens: 5 + 8 + 1 = 14. Answer: 141.","d":"m"},{"t":"Which is greater: 65 + 48 or 59 + 57?","o":["65 + 48","59 + 57","They are equal","Cannot tell"],"a":1,"e":"65 + 48 = 113 and 59 + 57 = 116. Since 116 > 113, 59 + 57 is greater.","d":"m"},{"t":"A library has 94 fiction books and 68 nonfiction books. How many books in all?","o":["152","172","162","142"],"a":2,"e":"Add 94 + 68. Ones: 4 + 8 = 12. Regroup 1 ten. Tens: 9 + 6 + 1 = 16. Answer: 162.","d":"h"},{"t":"38 + 95 = ?","o":["123","143","133","113"],"a":2,"e":"Add the ones: 8 + 5 = 13. Regroup 1 ten. Tens: 3 + 9 + 1 = 13. Answer: 133.","d":"m"},{"t":"Tom had 85 baseball cards. He gave 27 to Kim and then got 15 from Dad. How many does he have now?","o":["63","83","73","93"],"a":2,"e":"Step 1: 85 - 27 = 58. Step 2: 58 + 15 = 73. Two operations: subtract first, then add.","d":"h"},{"t":"A student solved 63 + 29 = 82. What mistake did the student make?","o":["Added the tens wrong","Forgot to regroup","Added the ones wrong","No mistake, 82 is correct"],"a":1,"e":"63 + 29: ones are 3 + 9 = 12. You must regroup 1 ten. Tens: 6 + 2 + 1 = 9. The correct answer is 92. The student forgot to regroup.","d":"h"},{"t":"__ + 67 = 143. What is the missing number?","o":["86","66","76","96"],"a":2,"e":"Use inverse reasoning: 143 - 67. Ones: 13 - 7 = 6 (regroup). Tens: 13 - 6 = 7. Missing number: 76. Check: 76 + 67 = 143.","d":"h"},{"t":"Mia added 78 + 56 and got 124. Is she correct? What should the answer be?","o":["Yes, 124 is correct","No, it should be 134","No, it should be 144","No, it should be 114"],"a":1,"e":"78 + 56: ones are 8 + 6 = 14. Regroup 1 ten. Tens: 7 + 5 + 1 = 13. Answer: 134. Mia got 124, so she is wrong by 10 — she likely forgot to regroup.","d":"h"},{"t":"Sam needs to buy items costing 67 cents and 54 cents. He has 110 cents. Does he have enough? How do you know?","o":["Yes, because 67 + 54 = 121 and 121 < 110","No, because 67 + 54 = 121 and 121 > 110","Yes, because 67 + 54 = 111 and 111 > 110","No, because 67 + 54 = 131 and 131 > 110"],"a":1,"e":"Add 67 + 54 = 121. Compare: 121 > 110. Sam does not have enough because the total cost is more than what he has.","d":"h"},{"t":"A student wrote 95 + 48 = 133. Check the work. Is the answer correct?","o":["No, the answer is 143","Yes, 133 is correct","No, the answer is 153","No, the answer is 123"],"a":0,"e":"95 + 48: ones are 5 + 8 = 13. Regroup 1 ten. Tens: 9 + 4 + 1 = 14. Correct answer: 143. The student made an error adding the tens.","d":"h"},{"t":"Rosa had 92 stickers. She gave some away and now has 58. Then she got 35 more. How many does she have now?","o":["83","103","93","73"],"a":2,"e":"Step 1: Rosa gave away stickers and has 58 left. Step 2: 58 + 35 = 93. Rosa now has 93 stickers.","d":"h"},{"t":"__ - 38 = 79. What is the missing number?","o":["107","127","117","97"],"a":2,"e":"Use inverse reasoning: add 79 + 38. Ones: 9 + 8 = 17. Regroup. Tens: 7 + 3 + 1 = 11. Missing number: 117.","d":"h"},{"t":"Which problem will give an answer greater than 150? A) 88 + 59  B) 72 + 65  C) 91 + 63  D) 80 + 68","o":["88 + 59","72 + 65","91 + 63","80 + 68"],"a":2,"e":"A) 88 + 59 = 147. B) 72 + 65 = 137. C) 91 + 63 = 154. D) 80 + 68 = 148. Only 91 + 63 = 154 is greater than 150.","d":"h"},{"t":"Jake had 74 toy cars. He bought 38 more on Monday and 29 more on Tuesday. How many toy cars does he have now?","o":["131","151","141","121"],"a":2,"e":"Step 1: 74 + 38 = 112. Step 2: 112 + 29 = 141. Jake now has 141 toy cars.","d":"h"},{"t":"A student solved 86 + 47 = 123. Find the error.","o":["No error, 123 is correct","The student forgot to regroup the ones","The student added the tens incorrectly","The student added the ones incorrectly"],"a":2,"e":"86 + 47: ones are 6 + 7 = 13. Regroup 1 ten. Tens: 8 + 4 + 1 = 13. Answer: 133. The student got 123, so they added the tens as 8 + 4 = 12 instead of 8 + 4 + 1 = 13.","d":"h"},{"t":"Ella has 65 beads. Kai has 48 beads. They want to combine their beads. Do they have more or fewer than 120?","o":["More, because 65 + 48 = 123","Fewer, because 65 + 48 = 113","Exactly 120","More, because 65 + 48 = 133"],"a":1,"e":"65 + 48: ones 5 + 8 = 13, regroup. Tens: 6 + 4 + 1 = 11. Total: 113. 113 < 120, so they have fewer than 120.","d":"h"},{"t":"__ + 89 = 165. What is the missing number?","o":["86","66","76","96"],"a":2,"e":"Inverse reasoning: 165 - 89. Ones: 15 - 9 = 6 (regroup). Tens: 15 - 8 = 7. Missing number: 76. Check: 76 + 89 = 165.","d":"h"},{"t":"A class collected 97 cans in Week 1 and 86 cans in Week 2. They need 200 cans total. Do they have enough? How many more do they need?","o":["Yes, they have enough","No, they need 17 more","No, they need 27 more","No, they need 7 more"],"a":1,"e":"97 + 86 = 183. They need 200. 200 - 183 = 17. They do not have enough and need 17 more cans.","d":"h"},{"t":"Which addition strategy works best for 99 + 67? Why?","o":["Break apart 67 into 60 + 7","Make a friendly number: 100 + 66","Count up from 99 by ones","Subtract 67 from 99"],"a":1,"e":"99 is close to 100. Move 1 from 67 to 99: 100 + 66 = 166. Making a friendly number is the most efficient strategy here.","d":"m"},{"t":"A student says 57 + 86 = 133. Another says it is 143. Who is correct?","o":["The first student (133)","The second student (143)","Neither, it is 153","Neither, it is 123"],"a":1,"e":"57 + 86: ones 7 + 6 = 13, regroup. Tens: 5 + 8 + 1 = 14. Answer: 143. The second student is correct.","d":"h"},{"t":"Ava scored 78 points in Game 1 and 64 in Game 2. Ben scored 86 in Game 1 and 53 in Game 2. Who scored more total points?","o":["Ava, with 142 points","Ben, with 142 points","They tied with 142 points","Ben, with 139 points"],"a":0,"e":"Ava: 78 + 64 = 142. Ben: 86 + 53 = 139. Ava scored 142 and Ben scored 139. Ava scored more.","d":"h"},{"t":"__ + __ = 130, and both numbers are between 50 and 90. Which pair works?","o":["45 and 85","62 and 68","91 and 39","75 and 65"],"a":1,"e":"Check each pair: 45 is not between 50-90. 62 + 68 = 130 and both are between 50-90. 91 is too high. 75 + 65 = 140, not 130.","d":"h"},{"t":"Liam added 69 + 74 and got 133. Is he right? If not, what is the correct answer?","o":["Yes, 133 is correct","No, it should be 143","No, it should be 153","No, it should be 123"],"a":1,"e":"69 + 74: ones 9 + 4 = 13, regroup. Tens: 6 + 7 + 1 = 14. Correct answer: 143. Liam likely forgot to add the regrouped ten.","d":"h"},{"t":"There are 88 red balloons and 76 blue balloons. 30 balloons pop. How many balloons are left?","o":["124","144","134","154"],"a":2,"e":"Step 1: 88 + 76 = 164 total balloons. Step 2: 164 - 30 = 134 balloons left.","d":"h"}],"quiz":[{"t":"What is 47 + 36?","o":["56","83","93","40"],"a":1,"e":"7+6=13, write 3 regroup 1 ten. 4+3+1=8. Answer: 83."},{"t":"What is 58 + 27?","o":["70","85","95","50"],"a":1,"e":"8+7=15, write 5 regroup 1 ten. 5+2+1=8. Answer: 85."},{"t":"What is 39 + 45?","o":["64","84","94","50"],"a":1,"e":"9+5=14, write 4 regroup 1 ten. 3+4+1=8. Answer: 84."},{"t":"What does REGROUP mean in addition?","o":["Start over","Regroup 1 ten when ones reach 10+","Subtract instead","Skip ones"],"a":1,"e":"Regrouping = regrouping 10 ones for 1 ten and regrouping."},{"t":"What is 35 + 48?","o":["56","83","93","40"],"a":1,"e":"5+8=13, write 3 regroup 1 ten. 3+4+1=8. Answer: 83."},{"t":"What is 62 + 79?","o":["120","141","151","100"],"a":1,"e":"2+9=11, write 1 regroup 1 ten. 6+7+1=14. Answer: 141."}]},{"points":["Subtract ONES first, then tens","If the top ones digit is too small, REGROUP 1 ten from the tens column","Regrouping: cross out tens digit, subtract 1, add 10 to ones"],"examples":[{"c":"#e67e22","tag":"No Regrouping","p":"58 − 34 = ?","s":"<table class=\"col-math\"><tr><td></td><td>5</td><td>8</td></tr><tr class=\"cm-bottom\"><td class=\"cm-op\">−</td><td>3</td><td>4</td></tr><tr class=\"cm-line\"><td colspan=\"3\"><hr></td></tr><tr class=\"cm-result\"><td></td><td>2</td><td>4</td></tr></table><br>Ones: 8 − 4 = 4<br>Tens: 5 − 3 = 2","a":"58 − 34 = 24 ✅"},{"c":"#e67e22","tag":"With Regrouping","p":"73 − 28 = ?","s":"<table class=\"col-math\"><tr class=\"cm-regroup\"><td></td><td>6</td><td>13</td></tr><tr><td></td><td>7</td><td>3</td></tr><tr class=\"cm-bottom\"><td class=\"cm-op\">−</td><td>2</td><td>8</td></tr><tr class=\"cm-line\"><td colspan=\"3\"><hr></td></tr><tr class=\"cm-result\"><td></td><td>4</td><td>5</td></tr></table><br>Ones: 3 &lt; 8, regroup 1 ten → <b>13</b> − 8 = <b>5</b><br>Tens: 7 becomes 6 → 6 − 2 = <b>4</b><br><br><button onclick=\"playBorrowAnim(this)\" class=\"cca-btn\" style=\"background:#e67e22\">🎬 Watch Step by Step</button>","a":"73 − 28 = 45 ✅"},{"c":"#e67e22","tag":"With Regrouping","p":"91 − 47 = ?","s":"<table class=\"col-math\"><tr class=\"cm-regroup\"><td></td><td>8</td><td>11</td></tr><tr><td></td><td>9</td><td>1</td></tr><tr class=\"cm-bottom\"><td class=\"cm-op\">−</td><td>4</td><td>7</td></tr><tr class=\"cm-line\"><td colspan=\"3\"><hr></td></tr><tr class=\"cm-result\"><td></td><td>4</td><td>4</td></tr></table><br>Ones: 1 &lt; 7, regroup 1 ten → <b>11</b> − 7 = <b>4</b><br>Tens: 9 becomes 8 → 8 − 4 = <b>4</b>","a":"91 − 47 = 44 ✅"}],"practice":[{"q":"67 - 23 = ?","a":"44","h":"Ones: 7-3=4. Tens: 6-2=4. No regrouping needed!","e":"➖"},{"q":"82 - 45 = ?","a":"37","h":"Ones: 2<5, regroup! 12-5=7. Tens: 7-4=3","e":"🍎"},{"q":"74 - 36 = ?","a":"38","h":"Ones: 4<6, regroup! 14-6=8. Tens: 6-3=3","e":"🍋"}],"qBank":[{"t":"What is 73 − 28?","o":["45","30","55","10"],"a":0,"e":"Regroup:13-8=5, 6-2=4.","d":"e"},{"t":"What is 91 − 47?","o":["44","54","30","80"],"a":0,"e":"Regroup:11-7=4, 8-4=4.","d":"e"},{"t":"What is 84 − 37?","o":["47","57","20","90"],"a":0,"e":"Regroup:14-7=7, 7-3=4.","d":"e"},{"t":"What is 62 − 45?","o":["17","30","27","5"],"a":0,"e":"Regroup:12-5=7, 5-4=1.","d":"e"},{"t":"What is 50 − 23?","o":["27","37","10","60"],"a":0,"e":"Regroup:10-3=7, 4-2=2.","d":"e"},{"t":"What is 76 − 39?","o":["37","47","20","80"],"a":0,"e":"Regroup:16-9=7, 6-3=3.","d":"e"},{"t":"What is 83 − 56?","o":["27","37","10","60"],"a":0,"e":"Regroup:13-6=7, 7-5=2.","d":"e"},{"t":"What is 95 − 48?","o":["57","20","47","90"],"a":2,"e":"Regroup:15-8=7, 8-4=4.","d":"e"},{"t":"What is 64 − 28?","o":["46","10","36","70"],"a":2,"e":"Regroup:14-8=6, 5-2=3.","d":"e"},{"t":"What is 71 − 35?","o":["46","10","36","70"],"a":2,"e":"Regroup:11-5=6, 6-3=3.","d":"e"},{"t":"When do you REGROUP in subtraction?","o":["Always","When numbers are large","When top ones digit is smaller","Never"],"a":2,"e":"You regroup when the top ones digit is smaller than the bottom ones digit.","d":"e"},{"t":"What is 85 − 47?","o":["48","20","38","70"],"a":2,"e":"Regroup:15-7=8, 7-4=3.","d":"e"},{"t":"What is 52 − 27?","o":["35","10","25","60"],"a":2,"e":"Regroup:12-7=5, 4-2=2.","d":"e"},{"t":"What is 90 − 34?","o":["66","20","56","100"],"a":2,"e":"Regroup:10-4=6, 8-3=5.","d":"e"},{"t":"What is 67 − 29?","o":["48","20","80","38"],"a":3,"e":"Regroup:17-9=8, 5-2=3.","d":"m"},{"t":"Which subtraction problem requires regrouping (regrouping)?","o":["75-32","84-21","63-47","51-20"],"a":2,"e":"63-47: ones 3<7, need to regroup.","d":"e"},{"t":"What is 78 − 53?","o":["35","10","60","25"],"a":3,"e":"No regroup: 8-3=5, 7-5=2.","d":"m"},{"t":"What is 86 − 58?","o":["38","10","60","28"],"a":3,"e":"Regroup:16-8=8, 7-5=2.","d":"m"},{"t":"What is 74 − 36?","o":["48","20","80","38"],"a":3,"e":"Regroup:14-6=8, 6-3=3.","d":"m"},{"t":"What is 93 − 67?","o":["36","10","60","26"],"a":3,"e":"Regroup:13-7=6, 8-6=2.","d":"m"},{"t":"What is 60 − 42?","o":["28","5","50","18"],"a":3,"e":"Regroup:10-2=8, 5-4=1.","d":"m"},{"t":"What is 55 − 28?","o":["37","10","60","27"],"a":3,"e":"Regroup:15-8=7, 4-2=2.","d":"m"},{"t":"What is 81 − 44?","o":["47","10","70","37"],"a":3,"e":"Regroup:11-4=7, 7-4=3.","d":"m"},{"t":"What is 70 − 36?","o":["44","34","10","60"],"a":1,"e":"Regroup:10-6=4, 6-3=3.","d":"m"},{"t":"What is 96 − 49?","o":["57","47","20","90"],"a":1,"e":"Regroup:16-9=7, 8-4=4.","d":"m"},{"t":"What is 43 − 18?","o":["35","25","10","60"],"a":1,"e":"Regroup:13-8=5, 3-1=2.","d":"e"},{"t":"What is 82 − 65?","o":["27","17","5","50"],"a":1,"e":"Regroup:12-5=7, 7-6=1.","d":"m"},{"t":"What is 77 − 38?","o":["49","39","20","80"],"a":1,"e":"Regroup:17-8=9, 6-3=3.","d":"m"},{"t":"What is 61 − 27?","o":["44","34","10","70"],"a":1,"e":"Regroup:11-7=4, 5-2=3.","d":"m"},{"t":"What is 54 − 19?","o":["45","35","10","65"],"a":1,"e":"Regroup:14-9=5, 4-1=3.","d":"m"},{"t":"What is 58 - 23?","o":["45","35","25","34"],"a":1,"e":"Subtract the ones: 8 - 3 = 5. Subtract the tens: 50 - 20 = 30. Then 30 + 5 = 35.","d":"e"},{"t":"What is 87 - 42?","o":["55","45","35","44"],"a":1,"e":"Subtract the ones: 7 - 2 = 5. Subtract the tens: 80 - 40 = 40. Then 40 + 5 = 45.","d":"e"},{"t":"What is 96 - 31?","o":["55","75","65","64"],"a":2,"e":"Subtract the ones: 6 - 1 = 5. Subtract the tens: 90 - 30 = 60. Then 60 + 5 = 65.","d":"e"},{"t":"What is 74 - 50?","o":["34","24","14","44"],"a":1,"e":"Subtract the tens: 70 - 50 = 20. The ones stay at 4. Then 20 + 4 = 24.","d":"e"},{"t":"A shelf has 69 books. 25 are taken. How many books are left?","o":["54","44","34","43"],"a":1,"e":"Subtract 69 - 25. Ones: 9 - 5 = 4. Tens: 60 - 20 = 40. Total: 44.","d":"m"},{"t":"What is 145 - 30?","o":["125","115","105","135"],"a":1,"e":"Subtract the tens: 140 - 30 = 110. The ones stay at 5. Then 110 + 5 = 115.","d":"e"},{"t":"What is 83 - 41?","o":["52","42","32","43"],"a":1,"e":"Subtract the ones: 3 - 1 = 2. Subtract the tens: 80 - 40 = 40. Then 40 + 2 = 42.","d":"e"},{"t":"What is 99 - 66?","o":["43","33","23","32"],"a":1,"e":"Subtract the ones: 9 - 6 = 3. Subtract the tens: 90 - 60 = 30. Then 30 + 3 = 33.","d":"e"},{"t":"There are 78 cookies. 34 are eaten. How many are left?","o":["54","44","34","43"],"a":1,"e":"Subtract 78 - 34. Ones: 8 - 4 = 4. Tens: 70 - 30 = 40. Total: 44.","d":"m"},{"t":"What is 127 - 15?","o":["102","122","112","132"],"a":2,"e":"Subtract the ones: 7 - 5 = 2. Subtract the tens: 120 - 10 = 110. Then 110 + 2 = 112.","d":"e"},{"t":"What is 56 - 24?","o":["42","32","22","31"],"a":1,"e":"Subtract the ones: 6 - 4 = 2. Subtract the tens: 50 - 20 = 30. Then 30 + 2 = 32.","d":"e"},{"t":"Which difference is greater: 89 - 43 or 75 - 31?","o":["89 - 43","75 - 31","They are the same","Cannot tell"],"a":0,"e":"89 - 43 = 46 and 75 - 31 = 44. Since 46 > 44, the first difference is greater.","d":"m"},{"t":"What is 160 - 40?","o":["110","130","120","140"],"a":2,"e":"Subtract the tens: 160 - 40 = 120. No ones to worry about.","d":"e"},{"t":"A jar has 48 candies. 16 are given away. How many candies are left?","o":["42","32","22","31"],"a":1,"e":"Subtract 48 - 16. Ones: 8 - 6 = 2. Tens: 40 - 10 = 30. Total: 32.","d":"m"},{"t":"What is 95 - 63?","o":["42","32","22","31"],"a":1,"e":"Subtract the ones: 5 - 3 = 2. Subtract the tens: 90 - 60 = 30. Then 30 + 2 = 32.","d":"e"},{"t":"Which is the correct answer for 138 - 26?","o":["102","122","112","132"],"a":2,"e":"Subtract the ones: 8 - 6 = 2. Subtract the tens: 130 - 20 = 110. Then 110 + 2 = 112.","d":"m"},{"t":"What is 67 - 35?","o":["42","32","22","31"],"a":1,"e":"Subtract the ones: 7 - 5 = 2. Subtract the tens: 60 - 30 = 30. Then 30 + 2 = 32.","d":"e"},{"t":"A park has 84 trees. 21 are cut down. How many trees are left?","o":["73","63","53","62"],"a":1,"e":"Subtract 84 - 21. Ones: 4 - 1 = 3. Tens: 80 - 20 = 60. Total: 63.","d":"m"},{"t":"What is 179 - 54?","o":["115","135","125","145"],"a":2,"e":"Subtract the ones: 9 - 4 = 5. Subtract the tens: 170 - 50 = 120. Then 120 + 5 = 125.","d":"e"},{"t":"What is 46 - 13?","o":["43","33","23","32"],"a":1,"e":"Subtract the ones: 6 - 3 = 3. Subtract the tens: 40 - 10 = 30. Then 30 + 3 = 33.","d":"e"},{"t":"73 - 48 = ? Use regrouping to solve.","o":["35","25","15","45"],"a":1,"e":"You cannot take 8 from 3. Regroup: move 1 ten. 13 - 8 = 5. Tens: 6 - 4 = 2. Answer: 25.","d":"m"},{"t":"Diego has 82 marbles. He gives 37 to his friend. How many does he have left?","o":["55","45","35","54"],"a":1,"e":"82 - 37: you cannot take 7 from 2. Regroup: 12 - 7 = 5. Tens: 7 - 3 = 4. Answer: 45.","d":"m"},{"t":"Which problem needs regrouping? A) 86 - 42  B) 65 - 38  C) 97 - 51  D) 74 - 23","o":["86 - 42","65 - 38","97 - 51","74 - 23"],"a":1,"e":"65 - 38: ones are 5 - 8. Since 5 < 8, you must regroup. The other problems have larger ones digits on top.","d":"h"},{"t":"91 - __ = 56. What is the missing number?","o":["45","35","25","33"],"a":1,"e":"Think: 91 minus what equals 56? Subtract: 91 - 56 = 35. Check: 91 - 35 = 56.","d":"h"},{"t":"134 - 58 = ?","o":["86","76","66","96"],"a":1,"e":"You cannot take 8 from 4. Regroup: 14 - 8 = 6. Tens: 12 - 5 = 7. Answer: 76.","d":"m"},{"t":"A store had 120 apples. 47 were sold. How many are left?","o":["83","73","63","77"],"a":1,"e":"120 - 47: you cannot take 7 from 0. Regroup: 10 - 7 = 3. Tens: 11 - 4 = 7. Answer: 73.","d":"h"},{"t":"__ - 29 = 47. What is the missing number?","o":["66","86","76","56"],"a":2,"e":"Think: what minus 29 equals 47? Add: 47 + 29 = 76. Check: 76 - 29 = 47.","d":"m"},{"t":"Which strategy helps solve 100 - 63?","o":["Add up from 63 to 100","Subtract 100 from 63","Round 63 to 70 first","Count back by ones"],"a":0,"e":"Add up from 63: 63 + 7 = 70, 70 + 30 = 100. That is 7 + 30 = 37. Adding up is efficient for subtracting from 100.","d":"m"},{"t":"156 - 79 = ?","o":["87","77","67","97"],"a":1,"e":"You cannot take 9 from 6. Regroup: 16 - 9 = 7. Tens: 14 - 7 = 7. Answer: 77.","d":"m"},{"t":"A bus has 95 passengers. At the first stop, 38 get off. How many are still on the bus?","o":["67","57","47","63"],"a":1,"e":"95 - 38: you cannot take 8 from 5. Regroup: 15 - 8 = 7. Tens: 8 - 3 = 5. Answer: 57.","d":"h"},{"t":"Which answer is correct for 143 - 67?","o":["86","76","66","96"],"a":1,"e":"143 - 67: regroup ones: 13 - 7 = 6. Tens: 13 - 6 = 7. Answer: 76.","d":"m"},{"t":"Which problem does NOT need regrouping? A) 52 - 37  B) 81 - 45  C) 96 - 52  D) 63 - 28","o":["52 - 37","81 - 45","96 - 52","63 - 28"],"a":2,"e":"96 - 52: ones are 6 - 2 = 4. No regrouping needed because 6 > 2. All others have a smaller ones digit on top.","d":"h"},{"t":"115 - __ = 68. What is the missing number?","o":["57","47","37","53"],"a":1,"e":"Think: 115 minus what equals 68? Subtract: 115 - 68 = 47. Check: 115 - 47 = 68.","d":"h"},{"t":"A farmer had 162 eggs. 85 broke. How many eggs are left?","o":["87","77","67","83"],"a":1,"e":"162 - 85: regroup ones: 12 - 5 = 7. Tens: 15 - 8 = 7. Answer: 77.","d":"h"},{"t":"Which is greater: 130 - 56 or 115 - 48?","o":["130 - 56","115 - 48","They are equal","Cannot tell"],"a":0,"e":"130 - 56 = 74 and 115 - 48 = 67. Since 74 > 67, the first difference is greater.","d":"h"},{"t":"61 - 34 = ?","o":["37","27","17","33"],"a":1,"e":"You cannot take 4 from 1. Regroup: 11 - 4 = 7. Tens: 5 - 3 = 2. Answer: 27.","d":"m"},{"t":"A school has 148 students. 59 go home early. How many remain?","o":["99","89","79","91"],"a":1,"e":"148 - 59: regroup ones: 18 - 9 = 9. Tens: 13 - 5 = 8. Answer: 89.","d":"h"},{"t":"__ - 45 = 88. What is the missing number?","o":["123","143","133","113"],"a":2,"e":"Think: what minus 45 equals 88? Add: 88 + 45 = 133. Check: 133 - 45 = 88.","d":"h"},{"t":"A piggy bank has 107 coins. 39 coins are spent. How many are left?","o":["78","68","58","72"],"a":1,"e":"107 - 39: regroup ones: 17 - 9 = 8. Tens: 9 - 3 = 6. Answer: 68.","d":"h"},{"t":"85 - 47 = ?","o":["48","38","28","42"],"a":1,"e":"You cannot take 7 from 5. Regroup: 15 - 7 = 8. Tens: 7 - 4 = 3. Answer: 38.","d":"m"},{"t":"A student solved 132 - 57 = 85. What mistake did the student make?","o":["Subtracted the ones wrong","Forgot to regroup","Subtracted the tens wrong","No mistake, 85 is correct"],"a":2,"e":"132 - 57: regroup ones: 12 - 7 = 5. Tens: 12 - 5 = 7. Correct answer: 75. The student wrote 85, so they subtracted the tens incorrectly (wrote 8 instead of 7).","d":"h"},{"t":"Nora had 145 stickers. She gave 58 to Ava and 39 to Ben. How many does she have left?","o":["58","48","38","52"],"a":1,"e":"Step 1: 145 - 58 = 87. Step 2: 87 - 39 = 48. Nora has 48 stickers left.","d":"h"},{"t":"__ - 67 = 89. What is the missing number?","o":["146","166","156","136"],"a":2,"e":"Inverse reasoning: add 89 + 67. Ones: 9 + 7 = 16, regroup. Tens: 8 + 6 + 1 = 15. Missing number: 156.","d":"h"},{"t":"Leo subtracted 163 - 78 and got 95. Is he correct?","o":["Yes, 95 is correct","No, it should be 85","No, it should be 75","No, it should be 105"],"a":1,"e":"163 - 78: regroup ones: 13 - 8 = 5. Tens: 15 - 7 = 8. Answer: 85. Leo got 95, which is wrong — he likely subtracted 6 instead of 7 in the tens.","d":"h"},{"t":"A school had 180 pencils. Monday they gave out 45. Tuesday they gave out 68. How many are left?","o":["77","67","57","87"],"a":1,"e":"Step 1: 180 - 45 = 135. Step 2: 135 - 68 = 67. The school has 67 pencils left.","d":"h"},{"t":"Which subtraction will give a result less than 50? A) 134 - 79  B) 121 - 68  C) 142 - 85  D) 113 - 69","o":["134 - 79","121 - 68","142 - 85","113 - 69"],"a":3,"e":"A) 134 - 79 = 55. B) 121 - 68 = 53. C) 142 - 85 = 57. D) 113 - 69 = 44. Only 113 - 69 = 44 is less than 50.","d":"h"},{"t":"A student wrote 150 - 73 = 87. Find the error.","o":["No error, 87 is correct","Forgot to regroup the ones","Subtracted the tens wrong","Subtracted the ones wrong"],"a":2,"e":"150 - 73: regroup ones: 10 - 3 = 7. Tens: 14 - 7 = 7. Correct answer: 77. The student wrote 87, subtracting tens as 14 - 7 = 8 instead of 7.","d":"h"},{"t":"__ - 86 = 57. What is the missing number?","o":["133","153","143","123"],"a":2,"e":"Inverse reasoning: 57 + 86. Ones: 7 + 6 = 13, regroup. Tens: 5 + 8 + 1 = 14. Missing number: 143.","d":"h"},{"t":"Mia has 126 beads. She uses 48 for a bracelet and 35 for a necklace. How many beads are left?","o":["53","43","33","47"],"a":1,"e":"Step 1: 126 - 48 = 78. Step 2: 78 - 35 = 43. Mia has 43 beads left.","d":"h"},{"t":"A store had 200 items. They sold 94 on Saturday and 67 on Sunday. How many items are left?","o":["49","39","29","59"],"a":1,"e":"Step 1: 200 - 94 = 106. Step 2: 106 - 67 = 39. The store has 39 items left.","d":"h"},{"t":"Sam says 141 - 65 = 86. Kai says it is 76. Who is correct?","o":["Sam (86)","Kai (76)","Neither, it is 66","Neither, it is 96"],"a":1,"e":"141 - 65: regroup ones: 11 - 5 = 6. Tens: 13 - 6 = 7. Answer: 76. Kai is correct.","d":"h"},{"t":"Which subtraction strategy works best for 200 - 87?","o":["Count back by ones from 200","Add up from 87 to 200","Round 87 to 100 and adjust","Subtract 200 - 80 - 7"],"a":1,"e":"Add up: 87 + 13 = 100, 100 + 100 = 200. That is 13 + 100 = 113. Adding up from 87 is efficient when subtracting from a round number.","d":"m"},{"t":"A library had 175 books. Some were checked out, leaving 98. Then 24 books were returned. How many are in the library now?","o":["112","132","122","102"],"a":2,"e":"Step 1: 175 - 98 = 77 were checked out. Step 2: 98 + 24 = 122 books now in the library.","d":"h"},{"t":"__ - __ = 45, where the first number is between 100 and 150. Which pair works?","o":["130 and 85","140 and 85","120 and 85","110 and 85"],"a":0,"e":"Check: 130 - 85 = 45. That works! 140 - 85 = 55. 120 - 85 = 35. 110 - 85 = 25. Only 130 - 85 = 45.","d":"h"},{"t":"A student solved 114 - 47 = 77. Check the work.","o":["Correct, 77 is right","Wrong, it should be 67","Wrong, it should be 57","Wrong, it should be 87"],"a":1,"e":"114 - 47: regroup ones: 14 - 7 = 7. Tens: 10 - 4 = 6. Answer: 67. The student got 77, adding 1 extra ten.","d":"h"},{"t":"Ella had 168 stickers. She gave away some and has 79 left. How many did she give away?","o":["99","89","79","91"],"a":1,"e":"Subtract: 168 - 79 = 89. Ella gave away 89 stickers. Check: 79 + 89 = 168.","d":"h"},{"t":"A farmer picks 156 apples. He sells 68 at the market and gives 49 to neighbors. How many does he keep?","o":["49","39","29","43"],"a":1,"e":"Step 1: 156 - 68 = 88. Step 2: 88 - 49 = 39. The farmer keeps 39 apples.","d":"h"},{"t":"There are 193 students. 87 go to lunch first. Of the remaining, 56 go next. How many are still waiting?","o":["60","50","40","55"],"a":1,"e":"Step 1: 193 - 87 = 106 remaining. Step 2: 106 - 56 = 50 still waiting.","d":"h"},{"t":"A student says 160 - 84 = 86. Another says it equals 76. Who is right?","o":["First student (86)","Second student (76)","Neither, it is 66","Neither, it is 96"],"a":1,"e":"160 - 84: regroup ones: 10 - 4 = 6. Tens: 15 - 8 = 7. Answer: 76. The second student is correct.","d":"h"},{"t":"__ - 95 = 78. What is the missing number?","o":["163","183","173","153"],"a":2,"e":"Inverse reasoning: 78 + 95. Ones: 8 + 5 = 13, regroup. Tens: 7 + 9 + 1 = 17. Missing number: 173.","d":"h"}],"quiz":[{"t":"What is 73 − 28?","o":["30","45","55","10"],"a":1,"e":"Regroup: 13-8=5. Then 6-2=4. Answer: 45."},{"t":"What is 91 − 47?","o":["54","44","30","80"],"a":1,"e":"Regroup: 11-7=4. Then 8-4=4. Answer: 44."},{"t":"What is 84 − 37?","o":["57","47","20","90"],"a":1,"e":"Regroup: 14-7=7. Then 7-3=4. Answer: 47."},{"t":"When do you REGROUP in subtraction?","o":["Always","When top ones digit is too small","When numbers are large","Never"],"a":1,"e":"You regroup when the top ones digit is smaller than the bottom ones digit."},{"t":"What is 62 − 45?","o":["30","17","27","5"],"a":1,"e":"Regroup: 12-5=7. Then 5-4=1. Answer: 17."},{"t":"What is 50 − 23?","o":["37","27","10","60"],"a":1,"e":"Regroup: 10-3=7. Then 4-2=2. Answer: 27."}]},{"points":["Look for DOUBLES or MAKE-A-TEN pairs first","Add those two numbers, then add the third","You can add in any order — pick the easiest!"],"examples":[{"c":"#e67e22","tag":"Make a Ten First","p":"4 + 6 + 8 = ?","s":"4+6=10 (make a ten!). Then 10+8=18.","a":"4 + 6 + 8 = 18 ✅","vis":"add3:🌟:4:6:8"},{"c":"#e67e22","tag":"Doubles First","p":"7 + 7 + 5 = ?","s":"7+7=14 (doubles!). Then 14+5=19.","a":"7 + 7 + 5 = 19 ✅","vis":"add3:🍋:7:7:5"},{"c":"#e67e22","tag":"Look for pairs","p":"3 + 8 + 7 = ?","s":"3+7=10 (make a ten!). Then 10+8=18.","a":"3 + 8 + 7 = 18 ✅","vis":"add3:🍊:3:8:7"}],"practice":[{"q":"3 + 7 + 5 = ?","a":"15","h":"3+7=10 first (make a ten!), then 10+5=15","e":"🌟"},{"q":"6 + 6 + 4 = ?","a":"16","h":"6+6=12 (doubles!), then 12+4=16","e":"⭐"},{"q":"8 + 2 + 9 = ?","a":"19","h":"8+2=10 first (make a ten!), then 10+9=19","e":"🍊"}],"qBank":[{"t":"What is 5 + 5 + 8?","o":["18","11","22","25"],"a":0,"e":"5+5=10, +8=18.","d":"e"},{"t":"What is 4 + 6 + 9?","o":["12","24","27","19"],"a":3,"e":"4+6=10, +9=19.","d":"e"},{"t":"What is 7 + 7 + 5?","o":["19","12","25","27"],"a":0,"e":"7+7=14, +5=19.","d":"e"},{"t":"What is 3 + 7 + 8?","o":["11","23","26","18"],"a":3,"e":"3+7=10, +8=18.","d":"e"},{"t":"What is 6 + 4 + 12?","o":["14","22","28","31"],"a":1,"e":"6+4=10, +12=22.","d":"e"},{"t":"What is 8 + 2 + 7?","o":["17","10","22","25"],"a":0,"e":"8+2=10, +7=17.","d":"e"},{"t":"What is 9 + 9 + 4?","o":["22","14","28","31"],"a":0,"e":"9+9=18, +4=22.","d":"e"},{"t":"What is 5 + 6 + 5?","o":["9","16","21","24"],"a":1,"e":"5+5=10, +6=16.","d":"e"},{"t":"What is 3 + 8 + 7?","o":["11","23","26","18"],"a":3,"e":"3+7=10, +8=18.","d":"e"},{"t":"What is 6 + 6 + 9?","o":["13","21","27","30"],"a":1,"e":"6+6=12, +9=21.","d":"e"},{"t":"What is 2 + 8 + 14?","o":["16","24","31","38"],"a":1,"e":"2+8=10, +14=24.","d":"e"},{"t":"What is 4 + 4 + 9?","o":["10","17","22","25"],"a":1,"e":"4+4=8, +9=17.","d":"e"},{"t":"What is 7 + 3 + 15?","o":["15","31","34","25"],"a":3,"e":"7+3=10, +15=25.","d":"e"},{"t":"What is 8 + 8 + 6?","o":["13","22","27","31"],"a":1,"e":"8+8=16, +6=22.","d":"e"},{"t":"What is 5 + 5 + 12?","o":["13","28","22","31"],"a":2,"e":"5+5=10, +12=22.","d":"e"},{"t":"In 2 + 9 + 8, which pair should you add first to make a ten?","o":["2+8","2+9","9+8","9+2"],"a":0,"e":"2+8=10 — make a ten first!","d":"m"},{"t":"In 5 + 7 + 5, which pair should you add first?","o":["5+5","5+7","7+5","7+7"],"a":0,"e":"5+5=10 — doubles make it easy!","d":"m"},{"t":"What is 9 + 1 + 16?","o":["15","31","26","34"],"a":2,"e":"9+1=10, +16=26.","d":"e"},{"t":"What is 6 + 4 + 18?","o":["17","33","36","28"],"a":3,"e":"6+4=10, +18=28.","d":"e"},{"t":"What is 3 + 3 + 14?","o":["11","20","25","29"],"a":1,"e":"3+3=6, +14=20.","d":"e"},{"t":"What is 7 + 7 + 9?","o":["13","28","32","23"],"a":3,"e":"7+7=14, +9=23.","d":"e"},{"t":"What is 4 + 6 + 7?","o":["9","22","25","17"],"a":3,"e":"4+6=10, +7=17.","d":"e"},{"t":"What is 8 + 2 + 9?","o":["11","24","19","27"],"a":2,"e":"8+2=10, +9=19.","d":"e"},{"t":"What is 5 + 5 + 5?","o":["8","20","15","23"],"a":2,"e":"5+5=10, +5=15.","d":"e"},{"t":"Is it true that you can add 3 numbers in any order?","o":["True","False","Sometimes","Never"],"a":0,"e":"Commutative property — order does not change the sum!","d":"e"},{"t":"What is 6 + 6 + 6?","o":["10","23","18","26"],"a":2,"e":"6+6=12, +6=18.","d":"e"},{"t":"What is 3 + 9 + 7?","o":["11","24","19","27"],"a":2,"e":"3+7=10, +9=19.","d":"e"},{"t":"What is 4 + 8 + 8?","o":["12","25","20","29"],"a":2,"e":"8+8=16, +4=20.","d":"e"},{"t":"What is 1 + 9 + 18?","o":["17","34","28","36"],"a":2,"e":"1+9=10, +18=28.","d":"e"},{"t":"What is 5 + 8 + 5?","o":["10","23","18","26"],"a":2,"e":"5+5=10, +8=18.","d":"e"},{"t":"What is 4 + 3 + 6?","o":["12","13","14","11"],"a":1,"e":"Add in steps: 4 + 6 = 10 (make a ten!), then 10 + 3 = 13.","d":"m"},{"t":"What is 5 + 5 + 7?","o":["15","16","17","18"],"a":2,"e":"Add doubles first: 5 + 5 = 10. Then 10 + 7 = 17.","d":"m"},{"t":"What is 20 + 30 + 10?","o":["50","60","70","40"],"a":1,"e":"Add the tens: 20 + 30 = 50. Then 50 + 10 = 60.","d":"m"},{"t":"What is 6 + 4 + 5?","o":["14","15","16","13"],"a":1,"e":"Make a ten: 6 + 4 = 10. Then 10 + 5 = 15.","d":"m"},{"t":"What is 7 + 3 + 8?","o":["16","17","18","19"],"a":2,"e":"Make a ten: 7 + 3 = 10. Then 10 + 8 = 18.","d":"m"},{"t":"A basket has 3 red, 5 blue, and 7 green balls. How many balls in all?","o":["14","15","16","13"],"a":1,"e":"Add: 3 + 7 = 10 (make a ten). Then 10 + 5 = 15 balls.","d":"h"},{"t":"What is 9 + 1 + 4?","o":["13","14","15","12"],"a":1,"e":"Make a ten: 9 + 1 = 10. Then 10 + 4 = 14.","d":"m"},{"t":"What is 10 + 20 + 40?","o":["60","70","80","50"],"a":1,"e":"Add the tens: 10 + 20 = 30. Then 30 + 40 = 70.","d":"m"},{"t":"What is 2 + 8 + 6?","o":["14","15","16","17"],"a":2,"e":"Make a ten: 2 + 8 = 10. Then 10 + 6 = 16.","d":"m"},{"t":"What is 5 + 3 + 5?","o":["12","13","14","11"],"a":1,"e":"Add doubles: 5 + 5 = 10. Then 10 + 3 = 13.","d":"e"},{"t":"Dan scored 6 points, then 4, then 3. How many points total?","o":["12","13","14","11"],"a":1,"e":"Make a ten: 6 + 4 = 10. Then 10 + 3 = 13 points.","d":"h"},{"t":"What is 30 + 40 + 20?","o":["80","90","100","70"],"a":1,"e":"Add: 30 + 40 = 70. Then 70 + 20 = 90.","d":"m"},{"t":"Which pair of numbers makes a ten? A) 3 and 5  B) 6 and 4  C) 7 and 2  D) 8 and 3","o":["3 and 5","6 and 4","7 and 2","8 and 3"],"a":1,"e":"6 + 4 = 10. This is a 'make a ten' pair! 3+5=8, 7+2=9, and 8+3=11. Only 6+4 makes exactly 10.","d":"m"},{"t":"What is 1 + 9 + 7?","o":["15","16","17","18"],"a":2,"e":"Make a ten: 1 + 9 = 10. Then 10 + 7 = 17.","d":"m"},{"t":"What is 50 + 20 + 30?","o":["90","100","110","80"],"a":1,"e":"Add: 50 + 30 = 80. Then 80 + 20 = 100. Or: 50 + 20 = 70, then 70 + 30 = 100.","d":"m"},{"t":"Amy picked 4 flowers, then 6, then 8. How many flowers in all?","o":["16","17","18","19"],"a":2,"e":"Make a ten: 4 + 6 = 10. Then 10 + 8 = 18 flowers.","d":"h"},{"t":"What is 3 + 7 + 2?","o":["11","12","13","10"],"a":1,"e":"Make a ten: 3 + 7 = 10. Then 10 + 2 = 12.","d":"m"},{"t":"What is 6 + 6 + 3?","o":["14","15","16","13"],"a":1,"e":"Add doubles: 6 + 6 = 12. Then 12 + 3 = 15.","d":"m"},{"t":"What is 40 + 10 + 50?","o":["90","100","110","80"],"a":1,"e":"Add: 40 + 10 = 50. Then 50 + 50 = 100.","d":"m"},{"t":"What is 24 + 35 + 16?","o":["65","75","85","55"],"a":1,"e":"Add the first two: 24 + 16 = 40 (ones make a ten!). Then 40 + 35 = 75.","d":"m"},{"t":"Which strategy helps add 18 + 32 + 25?","o":["Add all ones first","Make a ten: 18 + 32 = 50","Start with the largest number","Count by ones"],"a":1,"e":"18 + 32 = 50 (the ones 8 + 2 make a ten). Then 50 + 25 = 75. Making a ten first is efficient.","d":"m"},{"t":"Sam collected 37 shells on Monday, 28 on Tuesday, and 13 on Wednesday. How many in all?","o":["68","78","88","58"],"a":1,"e":"Look for tens: 37 + 13 = 50 (7 + 3 = 10!). Then 50 + 28 = 78.","d":"m"},{"t":"__ + 25 + 19 = 80. What is the missing number?","o":["46","36","26","42"],"a":1,"e":"First add 25 + 19 = 44. Then: __ + 44 = 80. Subtract: 80 - 44 = 36.","d":"h"},{"t":"What is 45 + 27 + 18?","o":["80","90","100","70"],"a":1,"e":"Add 45 + 27 = 72 (with regrouping: 5+7=12). Then 72 + 18 = 90 (2+8=10, regroup).","d":"m"},{"t":"A toy store sells 42 cars, 38 trucks, and 15 planes. How many toys sold in all?","o":["85","95","105","75"],"a":1,"e":"Add 42 + 38 = 80 (2+8=10!). Then 80 + 15 = 95 toys.","d":"m"},{"t":"Which two numbers should you add first to make a ten? 17 + 24 + 33","o":["17 and 24","24 and 33","17 and 33","Add in order"],"a":2,"e":"17 + 33: ones are 7 + 3 = 10, making a ten! 17 + 33 = 50. Then 50 + 24 = 74.","d":"m"},{"t":"What is 56 + 14 + 23?","o":["83","93","103","73"],"a":1,"e":"Make a ten: 56 + 14 = 70 (6+4=10!). Then 70 + 23 = 93.","d":"m"},{"t":"Which is the correct sum: 31 + 49 + 22?","o":["92","102","112","82"],"a":1,"e":"Make a ten: 31 + 49 = 80 (1+9=10). Then 80 + 22 = 102.","d":"m"},{"t":"15 + __ + 28 = 73. What is the missing number?","o":["40","30","20","35"],"a":1,"e":"Add the known numbers: 15 + 28 = 43. Then: 43 + __ = 73. Subtract: 73 - 43 = 30.","d":"m"},{"t":"A garden has 29 red flowers, 41 yellow flowers, and 18 pink flowers. How many flowers total?","o":["78","88","98","68"],"a":1,"e":"Make a ten: 29 + 41 = 70 (9+1=10). Then 70 + 18 = 88.","d":"h"},{"t":"What is 33 + 47 + 26?","o":["96","106","116","86"],"a":1,"e":"Make a ten: 33 + 47 = 80 (3+7=10!). Then 80 + 26 = 106.","d":"m"},{"t":"Which is greater: 25 + 36 + 14 or 43 + 28 + 12?","o":["25 + 36 + 14","43 + 28 + 12","They are equal","Cannot tell"],"a":1,"e":"First sum: 25 + 36 + 14 = 75. Second sum: 43 + 28 + 12 = 83. 83 > 75, so the second is greater.","d":"h"},{"t":"What is 62 + 19 + 11?","o":["82","92","102","72"],"a":1,"e":"Make a ten: 19 + 11 = 30 (9+1=10!). Then 62 + 30 = 92.","d":"m"},{"t":"A class read 26 books in January, 34 in February, and 22 in March. How many books total?","o":["72","82","92","62"],"a":1,"e":"Make a ten: 26 + 34 = 60 (6+4=10!). Then 60 + 22 = 82 books.","d":"h"},{"t":"38 + 22 + __ = 100. What is the missing number?","o":["50","40","30","45"],"a":1,"e":"Add known: 38 + 22 = 60 (8+2=10!). Then 60 + __ = 100. Missing: 40.","d":"h"},{"t":"What is 51 + 39 + 17?","o":["97","107","117","87"],"a":1,"e":"Make a ten: 51 + 39 = 90 (1+9=10!). Then 90 + 17 = 107.","d":"m"},{"t":"Which pair makes adding 27 + 46 + 13 easier?","o":["27 and 46","46 and 13","27 and 13","No pair helps"],"a":2,"e":"27 + 13: ones are 7 + 3 = 10, making a ten! 27 + 13 = 40. Then 40 + 46 = 86.","d":"m"},{"t":"A pet shop has 44 fish, 31 hamsters, and 16 birds. How many pets in all?","o":["81","91","101","71"],"a":1,"e":"Add 44 + 16 = 60 (4+6=10!). Then 60 + 31 = 91 pets.","d":"h"},{"t":"What is 28 + 35 + 42?","o":["95","105","115","85"],"a":1,"e":"Add 28 + 42 = 70 (8+2=10!). Then 70 + 35 = 105.","d":"m"},{"t":"Jake scored 47 points in Round 1, 38 in Round 2, and 29 in Round 3. He needs 120 to win. Does he have enough?","o":["Yes, he has 124","Yes, he has exactly 120","No, he has 114","No, he has 104"],"a":2,"e":"Step 1: 47 + 38 = 85. Step 2: 85 + 29 = 114. 114 < 120, so Jake does not have enough.","d":"h"},{"t":"A student added 36 + 45 + 24 and got 95. Find the error.","o":["No error, 95 is correct","Forgot to regroup, answer is 105","Added ones wrong, answer is 115","Added tens wrong, answer is 85"],"a":1,"e":"36 + 24 = 60 (6+4=10). 60 + 45 = 105. The student got 95, forgetting to regroup the tens when adding 60 + 45.","d":"h"},{"t":"__ + 37 + 28 = 112. What is the missing number?","o":["57","47","37","53"],"a":1,"e":"Add known: 37 + 28 = 65. Then __ + 65 = 112. Subtract: 112 - 65 = 47.","d":"h"},{"t":"Mia has 53 red beads, 39 blue beads, and 48 green beads. She uses 25 for a project. How many are left?","o":["115","105","125","95"],"a":0,"e":"Step 1: 53 + 39 + 48. Add 53 + 48 = 101, then 101 + 39 = 140. Step 2: 140 - 25 = 115.","d":"h"},{"t":"A student says 28 + 34 + 19 = 71. Another says 81. Who is correct?","o":["First student (71)","Second student (81)","Neither, it is 91","Neither, it is 61"],"a":1,"e":"28 + 34 = 62 (8+4=12, regroup). 62 + 19 = 81 (2+9=11, regroup). The second student is correct with 81.","d":"h"},{"t":"Which set of three numbers adds to more than 120? A) 35+42+28  B) 46+38+41  C) 29+33+47  D) 31+44+36","o":["35+42+28","46+38+41","29+33+47","31+44+36"],"a":1,"e":"A) 35+42+28 = 105. B) 46+38+41 = 125. C) 29+33+47 = 109. D) 31+44+36 = 111. Only B = 125 is greater than 120.","d":"h"},{"t":"A baker made 45 muffins in the morning, 38 at noon, and 27 in the evening. He sold 65. How many are left?","o":["55","45","35","50"],"a":1,"e":"Step 1: 45 + 38 + 27. Add 45 + 27 = 72, then 72 + 38 = 110. Step 2: 110 - 65 = 45 muffins left.","d":"h"},{"t":"__ + 56 + __ = 140, and both missing numbers are the same. What is each number?","o":["52","42","32","46"],"a":1,"e":"Let the missing number be N. N + 56 + N = 140. So 2N + 56 = 140. 2N = 84. N = 42. Check: 42 + 56 + 42 = 140.","d":"h"},{"t":"Three friends scored: Ana 67, Ben 45, Cal 38. What is the difference between the highest total of two friends and the lowest total of two friends?","o":["29","39","19","49"],"a":0,"e":"Highest pair: Ana+Ben = 67+45 = 112. Lowest pair: Ben+Cal = 45+38 = 83. Difference: 112 - 83 = 29.","d":"h"},{"t":"A student checked 52 + 29 + 41 = 112. Is this correct?","o":["No, it should be 122","Yes, 112 is correct","No, it should be 132","No, it should be 102"],"a":0,"e":"52 + 29 = 81 (2+9=11, regroup). 81 + 41 = 122 (1+1=2). Answer: 122. The student got 112, which is wrong.","d":"h"},{"t":"Rosa picked 34 apples, 46 oranges, and 28 bananas. She gave away 50 pieces of fruit. How many are left?","o":["68","58","48","78"],"a":1,"e":"Step 1: 34 + 46 + 28. Add 34 + 46 = 80, then 80 + 28 = 108. Step 2: 108 - 50 = 58.","d":"h"},{"t":"Which strategy is best for adding 63 + 17 + 25?","o":["Add left to right","Make a ten: 63 + 17 = 80, then + 25","Add all ones, then all tens","Round each number first"],"a":1,"e":"63 + 17: ones 3+7=10, making a ten! 63 + 17 = 80. Then 80 + 25 = 105. Making a ten first is most efficient.","d":"h"},{"t":"A class needs 150 cans. Group A collected 43, Group B collected 58, Group C collected 37. Do they have enough?","o":["Yes, they have 148","Yes, they have 138","No, they have 138","No, they have 128"],"a":2,"e":"43 + 58 + 37: add 43 + 37 = 80, then 80 + 58 = 138. 138 < 150, so they do not have enough.","d":"h"},{"t":"25 + __ + 48 = 130. What is the missing number?","o":["67","57","47","63"],"a":1,"e":"Add known: 25 + 48 = 73. Then __ + 73 = 130. Subtract: 130 - 73 = 57.","d":"h"},{"t":"A student added 39 + 52 + 18 and got 99. Check the work and find the mistake.","o":["No mistake, 99 is correct","Forgot to regroup, answer is 109","Added ones wrong, answer is 119","Added tens wrong, answer is 89"],"a":1,"e":"39 + 52 = 91 (9+2=11, regroup). 91 + 18 = 109 (1+8=9). Answer: 109. The student got 99, likely forgetting to regroup.","d":"h"},{"t":"Three boxes hold 55, 47, and 36 items. If 40 items are removed, how many remain?","o":["108","98","88","78"],"a":1,"e":"Step 1: 55 + 47 + 36. Add 55 + 36 = 91, then 91 + 47 = 138. Step 2: 138 - 40 = 98.","d":"h"},{"t":"Is 44 + 38 + 26 greater or less than 29 + 55 + 31?","o":["First is greater (108 vs 115)","Second is greater (108 vs 115)","They are equal","First is greater (118 vs 105)"],"a":1,"e":"First: 44+38+26 = 108. Second: 29+55+31 = 115. 115 > 108, so the second sum is greater.","d":"h"},{"t":"__ + 43 + 29 = 119. What is the missing number?","o":["57","47","37","53"],"a":1,"e":"Add known: 43 + 29 = 72. Then __ + 72 = 119. Subtract: 119 - 72 = 47.","d":"h"},{"t":"A zoo has 41 monkeys, 59 birds, and 33 snakes. 20 animals are moved. How many remain?","o":["123","113","103","93"],"a":1,"e":"Step 1: 41 + 59 + 33. Add 41 + 59 = 100, then 100 + 33 = 133. Step 2: 133 - 20 = 113.","d":"h"},{"t":"A student says the best way to add 76 + 24 + 53 is to add left to right. Is there a better strategy?","o":["No, left to right is best","Yes, add 76 + 24 = 100 first","Yes, add 24 + 53 first","Yes, round all numbers first"],"a":1,"e":"76 + 24 = 100 (6+4=10!). Then 100 + 53 = 153. Making a hundred first is much more efficient than adding left to right.","d":"h"}],"quiz":[{"t":"What is 5 + 5 + 8?","o":["11","22","18","25"],"a":2,"e":"5+5=10 (ten!), then 10+8=18."},{"t":"What is 4 + 6 + 9?","o":["12","24","19","27"],"a":2,"e":"4+6=10 (ten!), then 10+9=19."},{"t":"What is 7 + 7 + 5?","o":["12","25","19","27"],"a":2,"e":"7+7=14 (doubles!), then 14+5=19."},{"t":"What is 3 + 7 + 8?","o":["11","23","18","26"],"a":2,"e":"3+7=10 (ten!), then 10+8=18."},{"t":"When adding 3 numbers, look for:","o":["The biggest number","Make-a-ten or doubles pairs","Add left to right always","Skip the middle"],"a":1,"e":"Looking for make-a-ten or doubles pairs makes adding easier!"},{"t":"What is 6 + 4 + 12?","o":["14","28","22","31"],"a":2,"e":"6+4=10 (ten!), then 10+12=22."}]},{"points":["Step 1: Read carefully","Step 2: Find the numbers","Step 3: Add or subtract?","Step 4: Solve and check","ADD words: total, altogether, in all, combined","SUBTRACT words: left, fewer, difference, gave away"],"examples":[{"c":"#e67e22","tag":"Addition Problem","p":"Mia has 56 red and 78 green apples. How many total?","s":"\"Total\" = add! 56 + 78 =","a":"134 apples ✅"},{"c":"#e67e22","tag":"Subtraction Problem","p":"Jake had 143 coins. He gave away 68. How many left?","s":"\"Left\" = subtract! 143 - 68 =","a":"75 coins ✅"},{"c":"#e67e22","tag":"Read Carefully!","p":"There were 85 students. 37 went home. How many stayed?","s":"\"Went home\" means subtract. 85 - 37 =","a":"48 students stayed ✅"}],"practice":[{"q":"Tom has 45 stickers and gets 38 more. Total?","a":"83 stickers","h":"\"Gets more\" = ADD! 45+38=83","e":"⭐"},{"q":"92 birds in a tree. 47 flew away. How many left?","a":"45 birds","h":"\"Flew away\" = SUBTRACT! 92-47=45","e":"🐦"},{"q":"Sam has 67 cards, Ana has 85. How many more for Ana?","a":"18 more","h":"\"How many more\" = SUBTRACT! 85-67=18","e":"🃏"}],"qBank":[{"t":"Tom had 45 stickers and got 38 more. How many does he have in all?","o":["83","56","93","40"],"a":0,"e":"\"Got more\" = ADD. 45+38=83.","d":"e"},{"t":"There were 92 birds in a tree and 47 flew away. How many are left?","o":["45","25","55","10"],"a":0,"e":"\"Flew away\" = SUBTRACT. 92-47=45.","d":"m"},{"t":"Sam has 67 cards and Ana has 85. How many more cards does Ana have?","o":["18","8","30","50"],"a":0,"e":"\"How many more\" = SUBTRACT. 85-67=18.","d":"m"},{"t":"What does the word \"altogether\" tell you to do?","o":["Subtract","Multiply","Add","Divide"],"a":2,"e":"Words like altogether = ADD.","d":"e"},{"t":"Lily had 143 coins and gave away 68. How many coins does she have left?","o":["75","55","85","30"],"a":0,"e":"\"Gave away\" = SUBTRACT. 143-68=75.","d":"h"},{"t":"There are 56 red apples and 78 green apples. How many apples are there in all?","o":["134","104","144","90"],"a":0,"e":"\"Total\" = ADD. 56+78=134.","d":"e"},{"t":"There are 165 crayons and 78 are broken. How many good crayons are there?","o":["87","97","50","130"],"a":0,"e":"\"Broken\" = SUBTRACT. 165-78=87.","d":"m"},{"t":"What does the phrase \"how many left\" tell you to do?","o":["Subtract","Add","Multiply","Count up"],"a":0,"e":"\"Left\" = what remains after subtracting.","d":"e"},{"t":"There are 82 students in one class and 59 in another. How many students are there combined?","o":["120","151","141","100"],"a":2,"e":"\"Combined\" = ADD. 82+59=141.","d":"e"},{"t":"What is the first step when solving a word problem?","o":["Guess the answer","Write numbers first","Read carefully","Add everything"],"a":2,"e":"Always read the problem carefully first!","d":"e"},{"t":"The park had 175 people and 89 left. How many people are still at the park?","o":["76","50","86","130"],"a":2,"e":"\"Left\" = SUBTRACT. 175-89=86.","d":"h"},{"t":"What does the phrase \"in all\" mean in a math story?","o":["Subtract","Divide","Add","None"],"a":2,"e":"\"In all\" is like \"total\" — it means ADD.","d":"e"},{"t":"The store had 136 apples and sold 78. How many apples are left?","o":["38","68","58","20"],"a":2,"e":"\"Sold\" = SUBTRACT. 136-78=58.","d":"h"},{"t":"There are 63 boys and 74 girls at school. How many students are there altogether?","o":["107","147","90","137"],"a":3,"e":"Boys + girls = ADD. 63+74=137.","d":"e"},{"t":"What does the word \"difference\" mean in a math problem?","o":["Add two numbers","Multiply","Count on","Subtract to find gap"],"a":3,"e":"\"Difference\" always means SUBTRACT.","d":"e"},{"t":"Mia has 95 stickers and gives 47 away. How many stickers does she have left?","o":["38","20","80","48"],"a":3,"e":"\"Gives\" = SUBTRACT. 95-47=48.","d":"m"},{"t":"There are 74 pencils and 58 more pencils. How many are there altogether?","o":["102","142","90","132"],"a":3,"e":"\"Altogether\" = ADD. 74+58=132.","d":"e"},{"t":"The school had 183 books and 96 were checked out. How many books are still there?","o":["97","50","130","87"],"a":3,"e":"\"Checked out\" = SUBTRACT. 183-96=87.","d":"h"},{"t":"Which word tells you to SUBTRACT in a math story?","o":["total","altogether","in all","fewer"],"a":3,"e":"\"Fewer\" means less — SUBTRACT to find how many fewer.","d":"e"},{"t":"There are 27 girls, 38 boys, and 15 teachers. How many people are there in all?","o":["45","90","55","80"],"a":3,"e":"27+38+15=80 people in all.","d":"e"},{"t":"A book has 152 pages and Maria has read 67 pages. How many pages are left?","o":["75","55","120","85"],"a":3,"e":"152-67=85.","d":"h"},{"t":"Sam scored 86 points and Ben scored 74 points. How many more points did Sam score?","o":["10","12","14","16"],"a":1,"e":"\"How many more\" = SUBTRACT. 86-74=12.","d":"e"},{"t":"Which word tells you to ADD in a math story?","o":["left","fewer","combined","gave away"],"a":2,"e":"\"Combined\" means put together = ADD.","d":"e"},{"t":"There are 125 students and 46 more joined. How many students are there in all?","o":["151","171","181","120"],"a":1,"e":"125+46=171.","d":"m"},{"t":"There are 200 apples and 87 were sold. How many apples are remaining?","o":["93","113","123","80"],"a":1,"e":"200-87=113.","d":"m"},{"t":"Which word means SUBTRACT?","o":["total","sum","difference","combined"],"a":2,"e":"\"Difference\" = subtract.","d":"e"},{"t":"A bag had 134 grapes and 58 were eaten. How many grapes are left?","o":["56","76","86","30"],"a":1,"e":"134-58=76.","d":"h"},{"t":"There are 43 red balloons and 59 blue balloons. How many balloons are there in all?","o":["82","102","112","70"],"a":1,"e":"43+59=102.","d":"e"},{"t":"There were 175 people at a game and 88 left early. How many people are still at the game?","o":["97","87","50","130"],"a":1,"e":"175-88=87.","d":"h"},{"t":"Jen had 95 cards, gave away 38, then got 27 more. How many cards does she have now?","o":["64","84","94","50"],"a":1,"e":"95-38=57, 57+27=84.","d":"h"},{"t":"Zoe has 34 crayons. She gets 25 more. How many crayons does she have now?","o":["49","59","69","58"],"a":1,"e":"This is an addition problem. 34 + 25: ones 4+5=9, tens 30+20=50. Total: 59.","d":"e"},{"t":"A class had 47 pencils. They used 23. How many are left?","o":["34","24","14","23"],"a":1,"e":"This is a subtraction problem. 47 - 23: ones 7-3=4, tens 40-20=20. Total: 24.","d":"e"},{"t":"There are 56 birds in a tree. 12 fly away. How many birds are still in the tree?","o":["54","44","34","43"],"a":1,"e":"Birds fly away means subtract. 56 - 12: ones 6-2=4, tens 50-10=40. Total: 44.","d":"e"},{"t":"Mia read 31 pages on Monday and 48 pages on Tuesday. How many pages did she read in all?","o":["69","89","79","78"],"a":2,"e":"How many in all means add. 31 + 48: ones 1+8=9, tens 30+40=70. Total: 79.","d":"e"},{"t":"A shop has 83 toys. 41 are sold. How many toys are left?","o":["52","42","32","43"],"a":1,"e":"Sold means subtract. 83 - 41: ones 3-1=2, tens 80-40=40. Total: 42.","d":"m"},{"t":"Sam picked 45 apples. Ava picked 32 apples. How many apples did they pick altogether?","o":["67","87","77","78"],"a":2,"e":"Altogether means add. 45 + 32: ones 5+2=7, tens 40+30=70. Total: 77.","d":"e"},{"t":"There were 68 fish in a pond. 24 swam away. How many fish are still in the pond?","o":["54","44","34","43"],"a":1,"e":"Swam away means subtract. 68 - 24: ones 8-4=4, tens 60-20=40. Total: 44.","d":"e"},{"t":"A farm has 52 cows and 36 horses. How many animals in all?","o":["78","98","88","86"],"a":2,"e":"In all means add. 52 + 36: ones 2+6=8, tens 50+30=80. Total: 88.","d":"m"},{"t":"Which operation do you use? 'Leo had 75 cards. He gave 33 to a friend.'","o":["Addition","Subtraction","Both","Neither"],"a":1,"e":"Gave away means something is removed, so you subtract. 75 - 33 = 42.","d":"m"},{"t":"Rosa has 29 stickers. She finds 40 more. How many stickers does she have now?","o":["59","79","69","49"],"a":2,"e":"Finds more means add. 29 + 40: ones 9+0=9, tens 20+40=60. Total: 69.","d":"m"},{"t":"A box has 97 markers. 55 are taken out. How many are left in the box?","o":["52","42","32","43"],"a":1,"e":"Taken out means subtract. 97 - 55: ones 7-5=2, tens 90-50=40. Total: 42.","d":"m"},{"t":"Kai collected 43 rocks. His sister collected 35 rocks. How many rocks do they have together?","o":["68","88","78","77"],"a":2,"e":"Together means add. 43 + 35: ones 3+5=8, tens 40+30=70. Total: 78.","d":"e"},{"t":"Which operation do you use? 'A bakery made 84 cookies. They sold 51.'","o":["Addition","Subtraction","Both","Neither"],"a":1,"e":"Sold means items are removed, so you subtract. 84 - 51 = 33.","d":"e"},{"t":"A library has 62 books on one shelf and 26 on another. How many books on both shelves?","o":["78","98","88","86"],"a":2,"e":"Both shelves means add. 62 + 26: ones 2+6=8, tens 60+20=80. Total: 88.","d":"m"},{"t":"There are 75 students. 43 go outside. How many are still inside?","o":["42","32","22","33"],"a":1,"e":"Go outside means subtract. 75 - 43: ones 5-3=2, tens 70-40=30. Total: 32.","d":"e"},{"t":"A bus had 38 passengers. At the stop, 21 more got on. How many passengers now?","o":["49","69","59","57"],"a":2,"e":"Got on means add. 38 + 21: ones 8+1=9, tens 30+20=50. Total: 59.","d":"m"},{"t":"Ella has 54 beads. She uses 31 for a necklace. How many beads are left?","o":["33","23","13","22"],"a":1,"e":"Uses means subtract. 54 - 31: ones 4-1=3, tens 50-30=20. Total: 23.","d":"m"},{"t":"A garden has 41 roses and 37 tulips. How many flowers are there in all?","o":["68","88","78","77"],"a":2,"e":"In all means add. 41 + 37: ones 1+7=8, tens 40+30=70. Total: 78.","d":"m"},{"t":"There are 86 balloons. 44 pop. How many balloons are left?","o":["52","42","32","43"],"a":1,"e":"Pop means subtract. 86 - 44: ones 6-4=2, tens 80-40=40. Total: 42.","d":"m"},{"t":"Which is a correct answer? 'A store has 63 hats and 25 scarves. How many items in all?'","o":["78","98","88","38"],"a":2,"e":"In all means add. 63 + 25: ones 3+5=8, tens 60+20=80. Total: 88.","d":"m"},{"t":"Maya has 67 stickers. She buys 45 more. How many does she have now?","o":["102","122","112","92"],"a":2,"e":"Add 67 + 45. Ones: 7+5=12, regroup. Tens: 6+4+1=11. Answer: 112.","d":"m"},{"t":"A tank has 134 fish. 58 are moved to another tank. How many fish are left?","o":["86","76","66","82"],"a":1,"e":"Subtract 134 - 58. Regroup: 14-8=6. Tens: 12-5=7. Answer: 76.","d":"h"},{"t":"Ben has 83 baseball cards. He gives away 47. How many does he have left?","o":["46","36","26","42"],"a":1,"e":"Subtract 83 - 47. Regroup: 13-7=6. Tens: 7-4=3. Answer: 36.","d":"m"},{"t":"A store sold 78 ice cream cones in the morning and 56 in the afternoon. How many were sold in all?","o":["124","144","134","114"],"a":2,"e":"Add 78 + 56. Ones: 8+6=14, regroup. Tens: 7+5+1=13. Answer: 134.","d":"m"},{"t":"There were __ students in a gym. 38 left and now there are 57. How many were there at first?","o":["85","105","95","75"],"a":2,"e":"Think: __ - 38 = 57. Add: 57 + 38 = 95. There were 95 students at first.","d":"m"},{"t":"Which operation do you use? 'A jar had some marbles. 29 were added and now there are 86.'","o":["Add 86 + 29","Subtract 86 - 29","Add 29 + 29","Subtract 29 - 86"],"a":1,"e":"You know the total (86) and one part (29). To find the starting amount, subtract: 86 - 29 = 57.","d":"m"},{"t":"Ava has 95 beads. She uses 67 for a bracelet. How many are left?","o":["38","28","18","32"],"a":1,"e":"Subtract 95 - 67. Regroup: 15-7=8. Tens: 8-6=2. Answer: 28.","d":"m"},{"t":"A school collected 89 cans one week and 74 cans the next. How many cans in all?","o":["153","173","163","143"],"a":2,"e":"Add 89 + 74. Ones: 9+4=13, regroup. Tens: 8+7+1=16. Answer: 163.","d":"e"},{"t":"Leo had some coins. He spent 43 and has 68 left. How many did he start with?","o":["101","121","111","91"],"a":2,"e":"Think: __ - 43 = 68. Add: 68 + 43 = 111. Leo started with 111 coins.","d":"m"},{"t":"Which is greater: 'a bag with 93 - 47 marbles' or 'a bag with 85 - 36 marbles'?","o":["First bag (46 marbles)","Second bag (49 marbles)","They are equal","Cannot tell"],"a":1,"e":"First bag: 93 - 47 = 46. Second bag: 85 - 36 = 49. 49 > 46, so the second bag has more.","d":"m"},{"t":"A bakery made 126 muffins. They sold 79. How many are left?","o":["57","47","37","53"],"a":1,"e":"Subtract 126 - 79. Regroup: 16-9=7. Tens: 11-7=4. Answer: 47.","d":"m"},{"t":"Sam found 58 shells at the beach. His friend found 75 shells. How many shells did they find together?","o":["123","143","133","113"],"a":2,"e":"Add 58 + 75. Ones: 8+5=13, regroup. Tens: 5+7+1=13. Answer: 133.","d":"m"},{"t":"Rosa has __ stickers. She gets 56 more and now has 123. How many did she start with?","o":["77","67","57","73"],"a":1,"e":"Think: __ + 56 = 123. Subtract: 123 - 56 = 67. Rosa started with 67 stickers.","d":"h"},{"t":"A farmer had 143 eggs. He sold 85 at the market. How many eggs does he have left?","o":["68","58","48","62"],"a":1,"e":"Subtract 143 - 85. Regroup: 13-5=8. Tens: 13-8=5. Answer: 58.","d":"h"},{"t":"Two classes collect bottles: Class A gets 76, Class B gets 88. How many altogether?","o":["154","174","164","144"],"a":2,"e":"Add 76 + 88. Ones: 6+8=14, regroup. Tens: 7+8+1=16. Answer: 164.","d":"e"},{"t":"Which word problem needs subtraction? A) 'How many in all?' B) 'How many are left?' C) 'How many together?' D) 'What is the total?'","o":["How many in all?","How many are left?","How many together?","What is the total?"],"a":1,"e":"'How many are left?' means something was taken away, so you subtract. The other phrases signal addition.","d":"e"},{"t":"A zoo has 97 animals. 39 are in one area. How many are in the other area?","o":["68","58","48","62"],"a":1,"e":"Subtract 97 - 39. Regroup: 17-9=8. Tens: 8-3=5. Answer: 58.","d":"m"},{"t":"Kai walks 48 steps to school and 65 steps to the park. How many steps total?","o":["103","123","113","93"],"a":2,"e":"Add 48 + 65. Ones: 8+5=13, regroup. Tens: 4+6+1=11. Answer: 113.","d":"e"},{"t":"A box had __ crackers. 46 were eaten and 59 are left. How many were there at first?","o":["95","115","105","85"],"a":2,"e":"Think: __ - 46 = 59. Add: 59 + 46 = 105 crackers at first.","d":"m"},{"t":"Ella scored 86 points. Ana scored 69 points. How many more points did Ella score?","o":["27","17","7","23"],"a":1,"e":"How many more means subtract. 86 - 69. Regroup: 16-9=7. Tens: 7-6=1. Answer: 17.","d":"e"},{"t":"A store had 165 toys. They sold 78 on Monday and 49 on Tuesday. How many toys are left?","o":["48","38","28","42"],"a":1,"e":"Step 1: 165 - 78 = 87. Step 2: 87 - 49 = 38 toys left.","d":"h"},{"t":"A student solved this: 'Ben had 132 cards. He gave away 65 and has 77 left.' Is this correct?","o":["Yes, 77 is correct","No, he should have 67","No, he should have 57","No, he should have 87"],"a":1,"e":"132 - 65: regroup ones 12-5=7. Tens: 12-6=6. Answer: 67. The student got 77, which is wrong by 10.","d":"h"},{"t":"Mia earned 57 points in Game 1 and 84 in Game 2. She needs 150 to win a prize. Does she have enough? How many more does she need?","o":["Yes, she has enough","No, she needs 9 more","No, she needs 19 more","No, she needs 29 more"],"a":1,"e":"57 + 84 = 141. She needs 150. 150 - 141 = 9 more points needed.","d":"h"},{"t":"A farmer picked 96 apples and 87 oranges. He sold 135 fruits. How many does he have left?","o":["58","48","38","52"],"a":1,"e":"Step 1: 96 + 87 = 183 fruits total. Step 2: 183 - 135 = 48 fruits left.","d":"h"},{"t":"__ children were at the park. 36 went home, then 28 more came. Now there are 75. How many were there at first?","o":["73","93","83","63"],"a":2,"e":"Work backward: before 28 came, there were 75 - 28 = 47. Before 36 left, there were 47 + 36 = 83.","d":"h"},{"t":"A student wrote: '147 - 89 = 68.' Find the error and give the correct answer.","o":["No error","Should be 58","Should be 78","Should be 48"],"a":1,"e":"147 - 89: regroup 17-9=8. Tens: 13-8=5. Answer: 58. The student got 68, subtracting 8 tens instead of 9.","d":"h"},{"t":"Team A scored 76 and 68. Team B scored 89 and 52. Which team scored more total points, and by how much?","o":["Team A by 3","Team B by 3","They tied","Team A by 13"],"a":0,"e":"Team A: 76 + 68 = 144. Team B: 89 + 52 = 141. Team A scored 144 - 141 = 3 more points.","d":"h"},{"t":"A library had 200 books. Monday: 43 checked out. Tuesday: 67 checked out. Wednesday: 25 returned. How many are in the library now?","o":["125","115","105","135"],"a":1,"e":"Step 1: 200 - 43 = 157. Step 2: 157 - 67 = 90. Step 3: 90 + 25 = 115.","d":"h"},{"t":"A student solved 95 - 48 this way: '9-4=5, 8-5=3, so the answer is 53.' What did the student do wrong?","o":["Subtracted ones digits backward instead of regrouping","Added instead of subtracted","Subtracted tens wrong","Nothing, 53 is correct"],"a":0,"e":"The student subtracted 8-5=3 for the ones instead of regrouping: 15-8=7. Correct way: regroup to get 15-8=7 in the ones and 8-4=4 in the tens. Answer: 47, not 53.","d":"h"},{"t":"A class needs 175 cans for a project. They collected 89 in Week 1 and 64 in Week 2. How many more do they need?","o":["32","22","12","42"],"a":1,"e":"Step 1: 89 + 64 = 153 cans collected. Step 2: 175 - 153 = 22 more needed.","d":"h"},{"t":"Sam had 118 coins. He spent 45 on a toy and 36 on a book. He then found 13 coins. How many does he have?","o":["60","50","40","55"],"a":1,"e":"Step 1: 118 - 45 = 73. Step 2: 73 - 36 = 37. Step 3: 37 + 13 = 50.","d":"h"},{"t":"Which problem has the greatest answer? A) 143-67  B) 98+59  C) 175-88  D) 76+68","o":["143 - 67 = 76","98 + 59 = 157","175 - 88 = 87","76 + 68 = 144"],"a":1,"e":"A) 76. B) 157. C) 87. D) 144. The greatest answer is 157 from 98 + 59.","d":"h"},{"t":"A baker made 85 cookies. He sold 39 and then baked 47 more. How many does he have now?","o":["83","103","93","73"],"a":2,"e":"Step 1: 85 - 39 = 46. Step 2: 46 + 47 = 93 cookies.","d":"h"},{"t":"Ella had some money. She spent 78 cents on a pencil and 45 cents on an eraser. She has 27 cents left. How much did she start with?","o":["140 cents","150 cents","160 cents","130 cents"],"a":1,"e":"Work backward: 27 + 45 = 72. Then 72 + 78 = 150 cents. Ella started with 150 cents.","d":"h"},{"t":"A student checked: 'There are 156 chairs. 79 are used. 77 are empty.' Is this correct?","o":["Yes, 77 is correct","No, it should be 87","No, it should be 67","No, it should be 97"],"a":0,"e":"156 - 79: regroup 16-9=7. Tens: 14-7=7. Answer: 77. The student is correct!","d":"h"},{"t":"Two friends share 164 stickers equally. How many does each friend get? What operation do you use?","o":["82 each, use repeated subtraction","74 each, use subtraction","92 each, use addition","164 each, no operation needed"],"a":0,"e":"Equal sharing: 164 divided into 2 groups. Half of 160 = 80, half of 4 = 2. Each gets 82. This uses equal grouping.","d":"m"},{"t":"A toy store received 97 dolls and 86 cars. They sold 125 total toys. How many toys are still in the store?","o":["68","58","48","78"],"a":1,"e":"Step 1: 97 + 86 = 183 toys received. Step 2: 183 - 125 = 58 toys left.","d":"h"},{"t":"__ kids played outside. 47 went inside for lunch. After lunch, 33 came back out. Now 52 are outside. How many started outside?","o":["56","76","66","86"],"a":2,"e":"Work backward: before 33 came back, 52 - 33 = 19 were outside. Before 47 went in, 19 + 47 = 66 started outside.","d":"h"},{"t":"Ana says 87 + 65 = 142. Ben says 87 + 65 = 152. Check both and explain who is right.","o":["Ana (142)","Ben (152)","Neither, it is 162","Neither, it is 132"],"a":1,"e":"87 + 65: ones 7+5=12, regroup. Tens: 8+6+1=15. Answer: 152. Ben is correct. Ana forgot to add the regrouped ten.","d":"h"},{"t":"A garden has 143 flowers. A storm knocks down 67. The gardener plants 45 new ones. How many flowers are there now?","o":["131","121","111","141"],"a":1,"e":"Step 1: 143 - 67 = 76. Step 2: 76 + 45 = 121 flowers.","d":"h"}],"quiz":[{"t":"Mia had 85 stickers and gave away 37. How many stickers does she have left?","o":["38","48","20","80"],"a":1,"e":"\"Gave away\" = subtract. 85-37=48."},{"t":"There are 56 red apples and 78 green apples. How many apples are there in all?","o":["104","134","144","90"],"a":1,"e":"\"Total\" = add. 56+78=134."},{"t":"What does the word \"altogether\" usually mean in a math problem?","o":["Subtract","Multiply","Add","Divide"],"a":2,"e":"Words like altogether, total, in all = add!"},{"t":"A team scored 72 points and another scored 85 points combined. How many points are there in all?","o":["140","157","167","110"],"a":1,"e":"\"Combined\" = add. 72+85=157."},{"t":"There are 165 crayons and 78 are broken. How many good crayons are there?","o":["97","87","50","130"],"a":1,"e":"\"Broken\" = subtract. 165-78=87."},{"t":"What does the question \"How many more?\" ask you to find?","o":["Add","Subtract","Multiply","Cannot tell"],"a":1,"e":"\"How many more?\" asks for the DIFFERENCE, which means subtract."}]}],"unitQuiz":[{"t":"What is 47 + 36?","o":["56","93","83","40"],"a":2,"e":"7+6=13,regroup 1 ten. 4+3+1=8. Answer 83.","d":"e"},{"t":"What is 58 + 27?","o":["70","95","50","85"],"a":3,"e":"8+7=15,regroup 1 ten. 5+2+1=8. Answer 85.","d":"e"},{"t":"What is 73 − 28?","o":["45","30","55","10"],"a":0,"e":"Regroup:13-8=5, 6-2=4. Answer 45.","d":"m"},{"t":"What is 91 − 47?","o":["54","30","44","80"],"a":2,"e":"Regroup:11-7=4, 8-4=4. Answer 44.","d":"m"},{"t":"What is 5 + 5 + 8?","o":["18","11","22","25"],"a":0,"e":"5+5=10, +8=18.","d":"e"},{"t":"What is 62 + 79?","o":["120","151","100","141"],"a":3,"e":"2+9=11,regroup 1 ten. 6+7+1=14. Answer 141.","d":"e"},{"t":"What is 84 − 37?","o":["57","20","47","90"],"a":2,"e":"Regroup:14-7=7, 7-3=4. Answer 47.","d":"m"},{"t":"What is 4 + 6 + 9?","o":["12","24","27","19"],"a":3,"e":"4+6=10, +9=19.","d":"e"},{"t":"A student had 85 stickers and gave away 37. How many stickers are left?","o":["48","38","20","80"],"a":0,"e":"85-37=48.","d":"h"},{"t":"What is 56 + 78?","o":["104","144","90","134"],"a":3,"e":"6+8=14,regroup 1 ten. 5+7+1=13. Answer 134.","d":"e"},{"t":"What is 100 − 63?","o":["37","47","20","80"],"a":0,"e":"100-63=37.","d":"h"},{"t":"What is 7 + 7 + 5?","o":["12","25","19","27"],"a":2,"e":"7+7=14(double), +5=19.","d":"m"},{"t":"What is 92 − 54?","o":["48","38","20","80"],"a":1,"e":"Regroup:12-4=8, 8-5=3. Answer 38.","d":"m"},{"t":"What is 35 + 48?","o":["83","56","93","40"],"a":0,"e":"5+8=13,regroup 1 ten. 3+4+1=8. Answer 83.","d":"e"},{"t":"What is the missing number? 67 + ___ = 100","o":["23","50","33","60"],"a":2,"e":"100-67=33.","d":"h"},{"t":"What is 143 + 68?","o":["190","221","170","211"],"a":3,"e":"3+8=11,regroup 1 ten. 4+6+1=11,regroup 1 ten. 1+1+1=3. Answer 211.","d":"m"},{"t":"What is 76 − 49?","o":["37","27","10","60"],"a":1,"e":"Regroup:16-9=7, 6-4=2. Answer 27.","d":"m"},{"t":"What is 23 + 14 + 36?","o":["52","86","73","41"],"a":2,"e":"23+14=37, 37+36=73.","d":"m"},{"t":"What is 145 + 37?","o":["162","182","192","140"],"a":1,"e":"5+7=12,regroup 1 ten. 4+3+1=8. 1. Answer 182.","d":"m"},{"t":"What is 200 − 76?","o":["124","104","134","90"],"a":0,"e":"200-76=124.","d":"h"},{"t":"What is 19 + 13 + 7?","o":["26","51","63","39"],"a":3,"e":"19+13=32, 32+7=39.","d":"m"},{"t":"What is 178 − 94?","o":["94","50","130","84"],"a":3,"e":"178-94=84.","d":"h"},{"t":"What is 65 + 58?","o":["103","133","90","123"],"a":3,"e":"5+8=13,regroup 1 ten. 6+5+1=12. Answer 123.","d":"e"},{"t":"What is 147 rounded to the nearest ten?","o":["130","140","150","200"],"a":2,"e":"Ones=7(≥5), round up to 150.","d":"h"},{"t":"What is 150 − 63?","o":["87","97","50","130"],"a":0,"e":"150-63=87.","d":"h"},{"t":"What is 85 + 72?","o":["140","157","167","100"],"a":1,"e":"5+2=7. 8+7=15,regroup 1 ten. 1. Answer 157.","d":"e"},{"t":"What is 42 + 39?","o":["70","91","81","50"],"a":2,"e":"2+9=11,regroup 1 ten. 4+3+1=8. Answer 81.","d":"e"},{"t":"What is 165 − 78?","o":["97","87","50","130"],"a":1,"e":"165-78=87.","d":"h"},{"t":"What is 99 − 45?","o":["44","54","30","80"],"a":1,"e":"99-45=54.","d":"h"},{"t":"What is the best estimate for 48 + 53?","o":["90","100","110","80"],"a":1,"e":"50+50=100.","d":"h"}],"testBank":[{"t":"What is 34 + 25?","o":["42","69","59","85"],"a":2,"e":"Ones:4+5=9. Tens:3+2=5. No regroup.","d":"e"},{"t":"What is 47 + 36?","o":["83","56","93","40"],"a":0,"e":"Ones:7+6=13, write 3 regroup 1 ten. Tens:4+3+1=8.","d":"e"},{"t":"What is 58 + 27?","o":["70","95","50","85"],"a":3,"e":"Ones:8+7=15, write 5 regroup 1 ten. Tens:5+2+1=8.","d":"e"},{"t":"What is 39 + 45?","o":["64","94","84","50"],"a":2,"e":"Ones:9+5=14, write 4 regroup 1 ten. Tens:3+4+1=8.","d":"e"},{"t":"What is 62 + 79?","o":["141","120","151","100"],"a":0,"e":"Ones:2+9=11, write 1 regroup 1 ten. Tens:6+7+1=14.","d":"e"},{"t":"What is 55 + 38?","o":["40","83","93","150"],"a":2,"e":"Ones:5+8=13, write 3 regroup 1 ten. Tens:5+3+1=9.","d":"e"},{"t":"What is 46 + 54?","o":["90","100","91","101"],"a":1,"e":"Ones:6+4=10, write 0 regroup 1 ten. Tens:4+5+1=10.","d":"e"},{"t":"What is 73 + 19?","o":["92","75","102","60"],"a":0,"e":"Ones:3+9=12, write 2 regroup 1 ten. Tens:7+1+1=9.","d":"e"},{"t":"What is 28 + 65?","o":["50","140","93","82"],"a":2,"e":"Ones:8+5=13, write 3 regroup 1 ten. Tens:2+6+1=9.","d":"e"},{"t":"What is 57 + 34?","o":["71","45","130","91"],"a":3,"e":"Ones:7+4=11, write 1 regroup 1 ten. Tens:5+3+1=9.","d":"e"},{"t":"What does REGROUP mean?","o":["Regroup 10 ones as 1 ten","Start over","Subtract instead","Skip to next"],"a":0,"e":"Regrouping means regrouping 10 ones for 1 ten and regrouping.","d":"e"},{"t":"What is 66 + 27?","o":["50","93","83","145"],"a":1,"e":"Ones:6+7=13, write 3 regroup 1 ten. Tens:6+2+1=9.","d":"e"},{"t":"What is 45 + 48?","o":["78","83","140","93"],"a":3,"e":"Ones:5+8=13, write 3 regroup 1 ten. Tens:4+4+1=9.","d":"e"},{"t":"What is 83 + 9?","o":["80","102","92","65"],"a":2,"e":"Ones:3+9=12, write 2 regroup 1 ten. Tens:8+0+1=9.","d":"e"},{"t":"What is 37 + 46?","o":["56","83","93","40"],"a":1,"e":"Ones:7+6=13, write 3 regroup 1 ten. Tens:3+4+1=8.","d":"e"},{"t":"When do you regroup in addition?","o":["When ones column is 10+","Always","When tens column is 10+","Never"],"a":0,"e":"You regroup (regroup) when the ones column reaches 10 or more.","d":"e"},{"t":"What is 54 + 37?","o":["80","45","140","91"],"a":3,"e":"Ones:4+7=11, write 1 regroup 1 ten. Tens:5+3+1=9.","d":"e"},{"t":"What is 68 + 25?","o":["78","83","93","150"],"a":2,"e":"Ones:8+5=13, write 3 regroup 1 ten. Tens:6+2+1=9.","d":"e"},{"t":"What is 75 + 16?","o":["80","55","130","91"],"a":3,"e":"Ones:5+6=11, write 1 regroup 1 ten. Tens:7+1+1=9.","d":"e"},{"t":"What is 49 + 44?","o":["77","93","83","150"],"a":1,"e":"Ones:9+4=13, write 3 regroup 1 ten. Tens:4+4+1=9.","d":"e"},{"t":"Which addition problem requires regrouping?","o":["31+24","42+37","56+38","61+15"],"a":2,"e":"56+38: ones 6+8=14, needs regroup!","d":"e"},{"t":"What is 86 + 7?","o":["79","93","83","150"],"a":1,"e":"Ones:6+7=13, write 3 regroup 1 ten. Tens:8+0+1=9.","d":"e"},{"t":"What is 23 + 79?","o":["102","92","80","60"],"a":0,"e":"Ones:3+9=12, write 2 regroup 1 ten. Tens:2+7+1=10.","d":"e"},{"t":"What is 64 + 27?","o":["80","55","91","130"],"a":2,"e":"Ones:4+7=11, write 1 regroup 1 ten. Tens:6+2+1=9.","d":"e"},{"t":"What is 78 + 16?","o":["84","60","130","94"],"a":3,"e":"Ones:8+6=14, write 4 regroup 1 ten. Tens:7+1+1=9.","d":"e"},{"t":"What is 35 + 58?","o":["70","93","83","140"],"a":1,"e":"Ones:5+8=13, write 3 regroup 1 ten. Tens:3+5+1=9.","d":"e"},{"t":"Add ones first, then tens. In 47 + 36, what is 7 + 6?","o":["11","12","13","14"],"a":2,"e":"7+6=13. Write 3, regroup 1 ten.","d":"h"},{"t":"What is 94 + 7?","o":["101","90","111","75"],"a":0,"e":"Ones:4+7=11, write 1 regroup 1 ten. Tens:9+0+1=10.","d":"e"},{"t":"What is 26 + 37?","o":["50","73","40","63"],"a":3,"e":"Ones:6+7=13, write 3 regroup 1 ten. Tens:2+3+1=6.","d":"e"},{"t":"What is 88 + 5?","o":["79","93","83","150"],"a":1,"e":"Ones:8+5=13, write 3 regroup 1 ten. Tens:8+0+1=9.","d":"e"},{"t":"What is 73 − 28?","o":["45","30","55","10"],"a":0,"e":"Regroup:13-8=5, 6-2=4.","d":"m"},{"t":"What is 91 − 47?","o":["44","54","30","80"],"a":0,"e":"Regroup:11-7=4, 8-4=4.","d":"m"},{"t":"What is 84 − 37?","o":["47","57","20","90"],"a":0,"e":"Regroup:14-7=7, 7-3=4.","d":"m"},{"t":"What is 62 − 45?","o":["17","30","27","5"],"a":0,"e":"Regroup:12-5=7, 5-4=1.","d":"m"},{"t":"What is 50 − 23?","o":["27","37","10","60"],"a":0,"e":"Regroup:10-3=7, 4-2=2.","d":"m"},{"t":"What is 76 − 39?","o":["37","47","20","80"],"a":0,"e":"Regroup:16-9=7, 6-3=3.","d":"m"},{"t":"What is 83 − 56?","o":["27","37","10","60"],"a":0,"e":"Regroup:13-6=7, 7-5=2.","d":"m"},{"t":"What is 95 − 48?","o":["57","20","47","90"],"a":2,"e":"Regroup:15-8=7, 8-4=4.","d":"m"},{"t":"What is 64 − 28?","o":["46","10","36","70"],"a":2,"e":"Regroup:14-8=6, 5-2=3.","d":"m"},{"t":"What is 71 − 35?","o":["46","10","36","70"],"a":2,"e":"Regroup:11-5=6, 6-3=3.","d":"m"},{"t":"When do you REGROUP in subtraction?","o":["Always","When numbers are large","When top ones digit is smaller","Never"],"a":2,"e":"You regroup when the top ones digit is smaller than the bottom ones digit.","d":"e"},{"t":"What is 85 − 47?","o":["48","20","38","70"],"a":2,"e":"Regroup:15-7=8, 7-4=3.","d":"m"},{"t":"What is 52 − 27?","o":["35","10","25","60"],"a":2,"e":"Regroup:12-7=5, 4-2=2.","d":"m"},{"t":"What is 90 − 34?","o":["66","20","56","100"],"a":2,"e":"Regroup:10-4=6, 8-3=5.","d":"m"},{"t":"What is 67 − 29?","o":["48","20","80","38"],"a":3,"e":"Regroup:17-9=8, 5-2=3.","d":"m"},{"t":"Which subtraction problem requires regrouping (regrouping)?","o":["75-32","84-21","63-47","51-20"],"a":2,"e":"63-47: ones 3<7, need to regroup.","d":"e"},{"t":"What is 78 − 53?","o":["35","10","60","25"],"a":3,"e":"No regroup: 8-3=5, 7-5=2.","d":"m"},{"t":"What is 86 − 58?","o":["38","10","60","28"],"a":3,"e":"Regroup:16-8=8, 7-5=2.","d":"m"},{"t":"What is 74 − 36?","o":["48","20","80","38"],"a":3,"e":"Regroup:14-6=8, 6-3=3.","d":"m"},{"t":"What is 93 − 67?","o":["36","10","60","26"],"a":3,"e":"Regroup:13-7=6, 8-6=2.","d":"m"},{"t":"What is 60 − 42?","o":["28","5","50","18"],"a":3,"e":"Regroup:10-2=8, 5-4=1.","d":"m"},{"t":"What is 55 − 28?","o":["37","10","60","27"],"a":3,"e":"Regroup:15-8=7, 4-2=2.","d":"m"},{"t":"What is 81 − 44?","o":["47","10","70","37"],"a":3,"e":"Regroup:11-4=7, 7-4=3.","d":"m"},{"t":"What is 70 − 36?","o":["44","34","10","60"],"a":1,"e":"Regroup:10-6=4, 6-3=3.","d":"m"},{"t":"What is 96 − 49?","o":["57","47","20","90"],"a":1,"e":"Regroup:16-9=7, 8-4=4.","d":"m"},{"t":"What is 43 − 18?","o":["35","25","10","60"],"a":1,"e":"Regroup:13-8=5, 3-1=2.","d":"e"},{"t":"What is 82 − 65?","o":["27","17","5","50"],"a":1,"e":"Regroup:12-5=7, 7-6=1.","d":"m"},{"t":"What is 77 − 38?","o":["49","39","20","80"],"a":1,"e":"Regroup:17-8=9, 6-3=3.","d":"m"},{"t":"What is 61 − 27?","o":["44","34","10","70"],"a":1,"e":"Regroup:11-7=4, 5-2=3.","d":"m"},{"t":"What is 54 − 19?","o":["45","35","10","65"],"a":1,"e":"Regroup:14-9=5, 4-1=3.","d":"m"},{"t":"What is 5 + 5 + 8?","o":["18","11","22","25"],"a":0,"e":"5+5=10, +8=18.","d":"e"},{"t":"What is 4 + 6 + 9?","o":["12","24","27","19"],"a":3,"e":"4+6=10, +9=19.","d":"e"},{"t":"What is 7 + 7 + 5?","o":["19","12","25","27"],"a":0,"e":"7+7=14, +5=19.","d":"e"},{"t":"What is 3 + 7 + 8?","o":["11","23","26","18"],"a":3,"e":"3+7=10, +8=18.","d":"e"},{"t":"What is 6 + 4 + 12?","o":["14","22","28","31"],"a":1,"e":"6+4=10, +12=22.","d":"e"},{"t":"What is 8 + 2 + 7?","o":["17","10","22","25"],"a":0,"e":"8+2=10, +7=17.","d":"e"},{"t":"What is 9 + 9 + 4?","o":["22","14","28","31"],"a":0,"e":"9+9=18, +4=22.","d":"e"},{"t":"What is 5 + 6 + 5?","o":["9","16","21","24"],"a":1,"e":"5+5=10, +6=16.","d":"e"},{"t":"What is 3 + 8 + 7?","o":["11","23","26","18"],"a":3,"e":"3+7=10, +8=18.","d":"e"},{"t":"What is 6 + 6 + 9?","o":["13","21","27","30"],"a":1,"e":"6+6=12, +9=21.","d":"e"},{"t":"What is 2 + 8 + 14?","o":["16","24","31","38"],"a":1,"e":"2+8=10, +14=24.","d":"m"},{"t":"What is 4 + 4 + 9?","o":["10","17","22","25"],"a":1,"e":"4+4=8, +9=17.","d":"m"},{"t":"What is 7 + 3 + 15?","o":["15","31","34","25"],"a":3,"e":"7+3=10, +15=25.","d":"m"},{"t":"What is 8 + 8 + 6?","o":["13","22","27","31"],"a":1,"e":"8+8=16, +6=22.","d":"m"},{"t":"What is 5 + 5 + 12?","o":["13","28","22","31"],"a":2,"e":"5+5=10, +12=22.","d":"m"},{"t":"In 2 + 9 + 8, which pair should you add first to make a ten?","o":["2+8","2+9","9+8","9+2"],"a":0,"e":"2+8=10 — make a ten first!","d":"m"},{"t":"In 5 + 7 + 5, which pair should you add first?","o":["5+5","5+7","7+5","7+7"],"a":0,"e":"5+5=10 — doubles make it easy!","d":"m"},{"t":"What is 9 + 1 + 16?","o":["15","31","26","34"],"a":2,"e":"9+1=10, +16=26.","d":"m"},{"t":"What is 6 + 4 + 18?","o":["17","33","36","28"],"a":3,"e":"6+4=10, +18=28.","d":"m"},{"t":"What is 3 + 3 + 14?","o":["11","20","25","29"],"a":1,"e":"3+3=6, +14=20.","d":"m"},{"t":"What is 7 + 7 + 9?","o":["13","28","32","23"],"a":3,"e":"7+7=14, +9=23.","d":"m"},{"t":"What is 4 + 6 + 7?","o":["9","22","25","17"],"a":3,"e":"4+6=10, +7=17.","d":"m"},{"t":"What is 8 + 2 + 9?","o":["11","24","19","27"],"a":2,"e":"8+2=10, +9=19.","d":"m"},{"t":"What is 5 + 5 + 5?","o":["8","20","15","23"],"a":2,"e":"5+5=10, +5=15.","d":"e"},{"t":"Is it true that you can add 3 numbers in any order?","o":["True","False","Sometimes","Never"],"a":0,"e":"Commutative property — order does not change the sum!","d":"e"},{"t":"What is 6 + 6 + 6?","o":["10","23","18","26"],"a":2,"e":"6+6=12, +6=18.","d":"m"},{"t":"What is 3 + 9 + 7?","o":["11","24","19","27"],"a":2,"e":"3+7=10, +9=19.","d":"m"},{"t":"What is 4 + 8 + 8?","o":["12","25","20","29"],"a":2,"e":"8+8=16, +4=20.","d":"m"},{"t":"What is 1 + 9 + 18?","o":["17","34","28","36"],"a":2,"e":"1+9=10, +18=28.","d":"m"},{"t":"What is 5 + 8 + 5?","o":["10","23","18","26"],"a":2,"e":"5+5=10, +8=18.","d":"m"},{"t":"Tom had 45 stickers and got 38 more. How many does he have in all?","o":["83","56","93","40"],"a":0,"e":"\"Got more\" = ADD. 45+38=83.","d":"h"},{"t":"There were 92 birds in a tree and 47 flew away. How many are left?","o":["45","25","55","10"],"a":0,"e":"\"Flew away\" = SUBTRACT. 92-47=45.","d":"h"},{"t":"Sam has 67 cards and Ana has 85. How many more cards does Ana have?","o":["18","8","30","50"],"a":0,"e":"\"How many more\" = SUBTRACT. 85-67=18.","d":"h"},{"t":"What does the word \"altogether\" tell you to do?","o":["Subtract","Multiply","Add","Divide"],"a":2,"e":"Words like altogether = ADD.","d":"e"},{"t":"Lily had 143 coins and gave away 68. How many coins does she have left?","o":["75","55","85","30"],"a":0,"e":"\"Gave away\" = SUBTRACT. 143-68=75.","d":"h"},{"t":"There are 56 red apples and 78 green apples. How many apples are there in all?","o":["134","104","144","90"],"a":0,"e":"\"Total\" = ADD. 56+78=134.","d":"h"},{"t":"There are 165 crayons and 78 are broken. How many good crayons are there?","o":["87","97","50","130"],"a":0,"e":"\"Broken\" = SUBTRACT. 165-78=87.","d":"h"},{"t":"What does the phrase \"how many left\" tell you to do?","o":["Subtract","Add","Multiply","Count up"],"a":0,"e":"\"Left\" = what remains after subtracting.","d":"e"},{"t":"There are 82 students in one class and 59 in another. How many students are there combined?","o":["120","151","141","100"],"a":2,"e":"\"Combined\" = ADD. 82+59=141.","d":"h"},{"t":"What is the first step when solving a word problem?","o":["Guess the answer","Write numbers first","Read carefully","Add everything"],"a":2,"e":"Always read the problem carefully first!","d":"e"},{"t":"What is 43 + 35?","o":["68","88","78","79"],"a":2,"e":"Add the ones: 3 + 5 = 8. Add the tens: 40 + 30 = 70. Then 70 + 8 = 78.","d":"e"},{"t":"What is 86 - 52?","o":["44","34","24","33"],"a":1,"e":"Subtract the ones: 6 - 2 = 4. Subtract the tens: 80 - 50 = 30. Then 30 + 4 = 34.","d":"e"},{"t":"What is 7 + 3 + 5?","o":["14","15","16","13"],"a":1,"e":"Make a ten: 7 + 3 = 10. Then 10 + 5 = 15.","d":"m"},{"t":"A bag has 61 marbles. 20 are removed. How many are left?","o":["51","41","31","40"],"a":1,"e":"Subtract 61 - 20. Ones stay: 1. Tens: 60 - 20 = 40. Total: 41.","d":"h"},{"t":"What is 72 + 16?","o":["78","98","88","86"],"a":2,"e":"Add the ones: 2 + 6 = 8. Add the tens: 70 + 10 = 80. Then 80 + 8 = 88.","d":"e"},{"t":"What is 95 - 43?","o":["62","52","42","51"],"a":1,"e":"Subtract the ones: 5 - 3 = 2. Subtract the tens: 90 - 40 = 50. Then 50 + 2 = 52.","d":"e"},{"t":"What is 8 + 2 + 4?","o":["12","13","14","15"],"a":2,"e":"Make a ten: 8 + 2 = 10. Then 10 + 4 = 14.","d":"m"},{"t":"There are 54 apples and 33 oranges. How many fruits in all?","o":["77","97","87","88"],"a":2,"e":"Add 54 + 33. Ones: 4+3=7. Tens: 50+30=80. Total: 87.","d":"m"},{"t":"What is 148 - 36?","o":["102","122","112","132"],"a":2,"e":"Subtract the ones: 8 - 6 = 2. Subtract the tens: 140 - 30 = 110. Then 110 + 2 = 112.","d":"m"},{"t":"Which is the correct answer for 37 + 52?","o":["79","99","89","88"],"a":2,"e":"Add the ones: 7 + 2 = 9. Add the tens: 30 + 50 = 80. Then 80 + 9 = 89.","d":"h"},{"t":"What is 20 + 30 + 40?","o":["80","90","100","70"],"a":1,"e":"Add the tens: 20 + 30 = 50. Then 50 + 40 = 90.","d":"m"},{"t":"A class has 76 books. 44 are checked out. How many are on the shelf?","o":["42","32","22","33"],"a":1,"e":"Subtract 76 - 44. Ones: 6-4=2. Tens: 70-40=30. Total: 32.","d":"h"},{"t":"What is 65 + 24?","o":["79","99","89","88"],"a":2,"e":"Add the ones: 5 + 4 = 9. Add the tens: 60 + 20 = 80. Then 80 + 9 = 89.","d":"e"},{"t":"Sam has 48 stickers. He gets 31 more. How many does he have?","o":["69","89","79","77"],"a":2,"e":"Add 48 + 31. Ones: 8+1=9. Tens: 40+30=70. Total: 79.","d":"h"},{"t":"Which difference is greater: 67 - 23 or 58 - 15?","o":["67 - 23","58 - 15","They are the same","Cannot tell"],"a":0,"e":"67 - 23 = 44 and 58 - 15 = 43. Since 44 > 43, the first difference is greater.","d":"h"},{"t":"What is 6 + 4 + 9?","o":["17","18","19","20"],"a":2,"e":"Make a ten: 6 + 4 = 10. Then 10 + 9 = 19.","d":"m"},{"t":"A box has 83 crayons. 51 are used. How many are left?","o":["42","32","22","31"],"a":1,"e":"Subtract 83 - 51. Ones: 3-1=2. Tens: 80-50=30. Total: 32.","d":"h"},{"t":"What is 110 + 45?","o":["145","165","155","150"],"a":2,"e":"Add the ones: 0 + 5 = 5. Add the tens: 110 + 40 = 150. Then 150 + 5 = 155.","d":"m"},{"t":"There are 39 red cars and 50 blue cars in a lot. How many cars in all?","o":["79","99","89","88"],"a":2,"e":"Add 39 + 50. Ones: 9+0=9. Tens: 30+50=80. Total: 89.","d":"h"},{"t":"56 + 78 = ? Use regrouping to solve.","o":["124","144","134","114"],"a":2,"e":"Add the ones: 6 + 8 = 14. Write 4, regroup 1 ten. Tens: 5 + 7 + 1 = 13. Answer: 134.","d":"h"},{"t":"A pool has 152 gallons of water. 76 gallons drain out. How many gallons are left?","o":["86","76","66","82"],"a":1,"e":"Subtract 152 - 76. Regroup: 12-6=6. Tens: 14-7=7. Answer: 76.","d":"h"},{"t":"Which problem needs regrouping? A) 73 - 41  B) 85 - 27  C) 96 - 53  D) 64 - 32","o":["73 - 41","85 - 27","96 - 53","64 - 32"],"a":1,"e":"85 - 27: ones are 5 - 7. Since 5 < 7, you must regroup. The others have larger ones on top.","d":"h"},{"t":"__ + 48 = 125. What is the missing number?","o":["87","77","67","83"],"a":1,"e":"Subtract: 125 - 48 = 77. Check: 77 + 48 = 125.","d":"h"},{"t":"What is 37 + 46 + 23?","o":["96","106","116","86"],"a":1,"e":"Make a ten: 37 + 23 = 60 (7+3=10!). Then 60 + 46 = 106.","d":"m"},{"t":"A bakery made 94 cupcakes. They sold 57. How many are left?","o":["47","37","27","43"],"a":1,"e":"Subtract 94 - 57. Regroup: 14-7=7. Tens: 8-5=3. Answer: 37.","d":"h"},{"t":"Kai has some cards. He gets 63 more and now has 141. How many did he start with?","o":["88","78","68","84"],"a":1,"e":"Think: __ + 63 = 141. Subtract: 141 - 63 = 78.","d":"h"},{"t":"Which strategy helps solve 98 + 56?","o":["Count back from 98","Make a friendly number: 100 + 54","Subtract 56 from 98","Round both down"],"a":1,"e":"98 is close to 100. Move 2 from 56 to 98: 100 + 54 = 154. Making a friendly number is efficient.","d":"h"},{"t":"A garden has 82 tomatoes and 69 peppers. How many vegetables total?","o":["141","161","151","131"],"a":2,"e":"Add 82 + 69. Ones: 2+9=11, regroup. Tens: 8+6+1=15. Answer: 151.","d":"h"},{"t":"161 - __ = 84. What is the missing number?","o":["87","77","67","83"],"a":1,"e":"Subtract: 161 - 84 = 77. Check: 161 - 77 = 84.","d":"h"},{"t":"Which is greater: 89 + 47 or 75 + 58?","o":["89 + 47","75 + 58","They are equal","Cannot tell"],"a":0,"e":"89 + 47 = 136 and 75 + 58 = 133. Since 136 > 133, the first sum is greater.","d":"h"},{"t":"A school bus has 115 seats. 68 students are seated. How many empty seats?","o":["57","47","37","53"],"a":1,"e":"Subtract 115 - 68. Regroup: 15-8=7. Tens: 10-6=4. Answer: 47.","d":"h"},{"t":"What is 44 + 29 + 16?","o":["79","89","99","69"],"a":1,"e":"Add 44 + 16 = 60 (4+6=10!). Then 60 + 29 = 89.","d":"m"},{"t":"Which problem does NOT need regrouping for addition? A) 57+36  B) 84+49  C) 62+25  D) 78+43","o":["57 + 36","84 + 49","62 + 25","78 + 43"],"a":2,"e":"62 + 25: ones are 2 + 5 = 7, no regrouping needed. All others have ones that add above 9.","d":"h"},{"t":"__ - 56 = 79. What is the missing number?","o":["125","145","135","115"],"a":2,"e":"Add: 79 + 56 = 135. Check: 135 - 56 = 79.","d":"h"},{"t":"A farmer collected 73 eggs on Monday and 88 on Tuesday. How many altogether?","o":["151","171","161","141"],"a":2,"e":"Add 73 + 88. Ones: 3+8=11, regroup. Tens: 7+8+1=16. Answer: 161.","d":"h"},{"t":"Rosa had 143 beads. She used 65 for a craft. How many are left?","o":["88","78","68","82"],"a":1,"e":"Subtract 143 - 65. Regroup: 13-5=8. Tens: 13-6=7. Answer: 78.","d":"h"},{"t":"Which word problem needs addition? A) 'How many are left?' B) 'How many more?' C) 'What is the total?' D) 'How many fewer?'","o":["How many are left?","How many more?","What is the total?","How many fewer?"],"a":2,"e":"'What is the total?' means combining groups, which requires addition. The other phrases typically signal subtraction.","d":"h"},{"t":"A toy box has 58 small toys, 31 medium toys, and 19 large toys. How many toys in all?","o":["98","108","118","88"],"a":1,"e":"Make a ten: 31 + 19 = 50 (1+9=10!). Then 50 + 58 = 108.","d":"h"},{"t":"67 + 85 = ?","o":["142","162","152","132"],"a":2,"e":"Add the ones: 7 + 5 = 12. Regroup 1 ten. Tens: 6 + 8 + 1 = 15. Answer: 152.","d":"m"},{"t":"A student solved 145 - 68 = 87. Find the error and give the correct answer.","o":["No error, 87 is correct","Should be 77","Should be 67","Should be 97"],"a":1,"e":"145 - 68: regroup ones 15-8=7. Tens: 13-6=7. Answer: 77. The student got 87, adding 1 extra ten.","d":"h"},{"t":"Ava had 178 stickers. She gave 59 to Maya and 43 to Leo. How many stickers does Ava have left?","o":["86","76","66","82"],"a":1,"e":"Step 1: 178 - 59 = 119. Step 2: 119 - 43 = 76 stickers left.","d":"h"},{"t":"__ + 79 = 163. What is the missing number?","o":["94","74","84","64"],"a":2,"e":"Inverse reasoning: 163 - 79. Regroup: 13-9=4. Tens: 15-7=8. Missing number: 84.","d":"h"},{"t":"Ben scored 68, 75, and 49 in three games. He needs 200 total to earn a trophy. Does he have enough? How many more does he need?","o":["Yes, he has enough","No, he needs 8 more","No, he needs 18 more","No, he needs 28 more"],"a":1,"e":"68 + 75 = 143. 143 + 49 = 192. He needs 200 - 192 = 8 more points.","d":"h"},{"t":"A student added 87 + 65 and got 142. Is the student correct?","o":["No, it should be 152","Yes, 142 is correct","No, it should be 162","No, it should be 132"],"a":0,"e":"87 + 65: ones 7+5=12, regroup. Tens: 8+6+1=15. Answer: 152. The student forgot to add the regrouped ten.","d":"h"},{"t":"A bakery made 95 muffins in the morning and 78 in the afternoon. They sold 136. How many are left?","o":["47","37","27","42"],"a":1,"e":"Step 1: 95 + 78 = 173 muffins total. Step 2: 173 - 136 = 37 left.","d":"h"},{"t":"__ children were on a playground. 48 went inside, then 35 came out. Now there are 62. How many started on the playground?","o":["85","65","75","95"],"a":2,"e":"Work backward: before 35 came out, 62 - 35 = 27 were outside. Before 48 went in, 27 + 48 = 75.","d":"h"},{"t":"Which has a greater answer: 156 - 89 or 143 - 68?","o":["156 - 89 = 67","143 - 68 = 75","They are equal","156 - 89 = 77"],"a":1,"e":"156 - 89 = 67. 143 - 68 = 75. Since 75 > 67, the second problem has the greater answer.","d":"h"},{"t":"A class collected 53 cans in Week 1, 67 in Week 2, and 44 in Week 3. They need 175. How many more do they need?","o":["21","11","1","31"],"a":1,"e":"53 + 67 = 120. 120 + 44 = 164. They need 175 - 164 = 11 more cans.","d":"h"},{"t":"Sam says 93 - 47 = 56. Mia says it equals 46. Who is correct?","o":["Sam (56)","Mia (46)","Neither, it is 36","Neither, it is 66"],"a":1,"e":"93 - 47: regroup 13-7=6. Tens: 8-4=4. Answer: 46. Mia is correct.","d":"h"},{"t":"__ - 58 = 94. What is the missing number?","o":["142","162","152","132"],"a":2,"e":"Inverse reasoning: 94 + 58. Ones: 4+8=12, regroup. Tens: 9+5+1=15. Missing number: 152.","d":"h"},{"t":"A toy store had 200 items. Monday sold 67. Tuesday sold 54. Wednesday received 38 new items. How many items now?","o":["127","117","107","137"],"a":1,"e":"Step 1: 200 - 67 = 133. Step 2: 133 - 54 = 79. Step 3: 79 + 38 = 117.","d":"h"},{"t":"Which addition strategy is most efficient for 97 + 88?","o":["Add ones then tens","Make a friendly number: 100 + 85","Count up from 97 by ones","Break apart both numbers"],"a":1,"e":"97 is close to 100. Move 3 from 88 to 97: 100 + 85 = 185. Making a friendly number avoids messy regrouping.","d":"h"},{"t":"Team A: 89 + 67 = ? Team B: 78 + 74 = ? Which team has a higher total, and by how much?","o":["Team A by 4","Team B by 4","They are tied","Team A by 14"],"a":0,"e":"Team A: 89+67=156. Team B: 78+74=152. Team A wins by 156-152=4 points.","d":"h"},{"t":"A student checked: 'I had 134 coins, spent 67, and have 77 left.' Is this correct?","o":["No, should have 67 left","Yes, 77 is correct","No, should have 57 left","No, should have 87 left"],"a":0,"e":"134 - 67: regroup 14-7=7. Tens: 12-6=6. Answer: 67. The student should have 67, not 77.","d":"h"},{"t":"Rosa had 85 beads. She bought 47 more, then used 63 for a craft. How many does she have?","o":["79","69","59","89"],"a":1,"e":"Step 1: 85 + 47 = 132. Step 2: 132 - 63 = 69 beads.","d":"h"},{"t":"Three friends have 56, 43, and 38 marbles. If they combine all marbles and split equally among 3 friends, about how many does each get?","o":["About 45 each","About 55 each","About 35 each","About 65 each"],"a":0,"e":"Total: 56+43+38. Add 56+38=94, then 94+43=137. Split 3 ways: 137 is close to 135, and 135/3=45. Each gets about 45.","d":"h"},{"t":"A farmer had __ eggs. He sold 89 at the market and gave 34 to a neighbor. He has 52 left. How many did he start with?","o":["165","185","175","155"],"a":2,"e":"Work backward: 52 + 34 = 86. Then 86 + 89 = 175. The farmer started with 175 eggs.","d":"h"},{"t":"A student solved 38 + 54 + 27 = 109. Check the work.","o":["Correct, 109 is right","Wrong, should be 119","Wrong, should be 129","Wrong, should be 99"],"a":1,"e":"38 + 54 = 92 (8+4=12, regroup). 92 + 27 = 119 (2+7=9). Answer: 119. The student got 109, off by 10.","d":"h"},{"t":"A school has 186 students. 97 eat in the cafeteria. Of the rest, 45 eat outside. How many bring lunch from home and eat in their classroom?","o":["54","44","34","48"],"a":1,"e":"Step 1: 186 - 97 = 89 do not eat in cafeteria. Step 2: 89 - 45 = 44 eat in their classroom.","d":"h"}]});

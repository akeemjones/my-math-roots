// Unit 1: Basic Fact Strategies
_mergeUnitData(0, {"lessons":[{"points":["Count ON to add: start at the bigger number, then count forward","Count BACK to subtract: start at the bigger number, then count backward","Always start with the BIGGER number!"],"examples":[{"c":"#e74c3c","tag":"Counting ON to Add","p":"7 + 3 = ?","s":"Start at 7, count on 3 more: 8 → 9 → 10","a":"7 + 3 = 10 ✅","vis":"add:🍎:7:3"},{"c":"#e74c3c","tag":"Counting ON to Add","p":"8 + 5 = ?","s":"Start at 8, count on 5 more: 9 → 10 → 11 → 12 → 13","a":"8 + 5 = 13 ✅","vis":"add:🍋:8:5"},{"c":"#c0392b","tag":"Counting BACK to Subtract","p":"12 - 4 = ?","s":"Start at 12, count back 4: 11 → 10 → 9 → 8","a":"12 - 4 = 8 ✅","vis":"sub:🍎:12:4"}],"practice":[{"q":"5 + 2 = ?","a":"7","h":"Start at 5, count on 2 fingers!","e":"🍎"},{"q":"9 + 3 = ?","a":"12","h":"Start at 9, count on 3 more: 10, 11, 12","e":"🍊"},{"q":"14 - 4 = ?","a":"10","h":"Start at 14, count back 4: 13, 12, 11, 10","e":"🍋"}],"qBank":[{"t":"Use the count-on strategy. What is 6 + 3?","o":["7","8","9","10"],"a":2,"e":"Start at 6, count on 3: 7,8,9.","d":"e"},{"t":"Use the count-on strategy. What is 8 + 4?","o":["12","10","11","13"],"a":0,"e":"Start at 8, count on 4: 9,10,11,12.","d":"m"},{"t":"Use the count-on strategy. What is 7 + 5?","o":["12","10","11","13"],"a":0,"e":"Start at 7, count on 5: 8,9,10,11,12.","d":"m"},{"t":"Use the count-on strategy. What is 9 + 3?","o":["12","10","11","13"],"a":0,"e":"Start at 9, count on 3: 10,11,12.","d":"m"},{"t":"Use the count-on strategy. What is 5 + 4?","o":["9","7","8","10"],"a":0,"e":"Start at 5, count on 4: 6,7,8,9.","d":"e"},{"t":"Use the count-on strategy. What is 11 + 3?","o":["12","13","15","14"],"a":3,"e":"Start at 11, count on 3: 12,13,14.","d":"m"},{"t":"Use the count-on strategy. What is 14 + 2?","o":["14","16","15","17"],"a":1,"e":"Start at 14, count on 2: 15,16.","d":"m"},{"t":"Use the count-on strategy. What is 7 + 4?","o":["9","10","11","12"],"a":2,"e":"Start at 7, count on 4: 8,9,10,11.","d":"m"},{"t":"Use the count-back strategy. What is 10 − 3?","o":["5","6","8","7"],"a":3,"e":"Start at 10, count back 3: 9,8,7.","d":"m"},{"t":"Use the count-back strategy. What is 13 − 4?","o":["7","8","10","9"],"a":3,"e":"Start at 13, count back 4: 12,11,10,9.","d":"m"},{"t":"Use the count-back strategy. What is 15 − 5?","o":["10","8","9","11"],"a":0,"e":"Start at 15, count back 5: 14,13,12,11,10.","d":"m"},{"t":"Use the count-back strategy. What is 12 − 3?","o":["7","9","8","10"],"a":1,"e":"Start at 12, count back 3: 11,10,9.","d":"m"},{"t":"Use the count-back strategy. What is 17 − 6?","o":["9","10","12","11"],"a":3,"e":"Start at 17, count back 6: 16,15,14,13,12,11.","d":"m"},{"t":"Use the count-back strategy. What is 14 − 5?","o":["7","8","9","10"],"a":2,"e":"Start at 14, count back 5: 13,12,11,10,9.","d":"m"},{"t":"Use the count-back strategy. What is 11 − 4?","o":["7","5","6","8"],"a":0,"e":"Start at 11, count back 4: 10,9,8,7.","d":"m"},{"t":"Use the count-back strategy. What is 16 − 7?","o":["7","8","9","10"],"a":2,"e":"Start at 16, count back 7: 15,14,13,12,11,10,9.","d":"m"},{"t":"Which strategy works best to solve 8 + 3?","o":["Count back from 11","Count on from 8","Start at 3","Subtract"],"a":1,"e":"To add, start at the bigger number and count on.","d":"m"},{"t":"Which strategy works best to solve 14 − 4?","o":["Count on from 14","Count back from 14","Add 4 to 14","Double 7"],"a":1,"e":"To subtract, start at the bigger number and count back.","d":"m"},{"t":"Use the count-on strategy. What is 12 + 4?","o":["14","15","16","17"],"a":2,"e":"Start at 12, count on 4: 13,14,15,16.","d":"m"},{"t":"Use the count-back strategy. What is 18 − 5?","o":["13","11","12","14"],"a":0,"e":"Start at 18, count back 5: 17,16,15,14,13.","d":"m"},{"t":"Use the count-on strategy. What is 6 + 6?","o":["10","11","13","12"],"a":3,"e":"Start at 6, count on 6: 7,8,9,10,11,12.","d":"m"},{"t":"Use the count-back strategy. What is 20 − 4?","o":["14","15","16","17"],"a":2,"e":"Start at 20, count back 4: 19,18,17,16.","d":"m"},{"t":"Use the count-on strategy. What is 9 + 5?","o":["14","12","13","15"],"a":0,"e":"Start at 9, count on 5: 10,11,12,13,14.","d":"m"},{"t":"What does count ON mean?","o":["Subtract","Count forward to add","Count backward","Guess"],"a":1,"e":"Count ON means count forward starting from the bigger number to add.","d":"e"},{"t":"Use the count-on strategy. What is 13 + 3?","o":["14","15","17","16"],"a":3,"e":"Start at 13, count on 3: 14,15,16.","d":"m"},{"t":"Use the count-back strategy. What is 19 − 6?","o":["11","13","12","14"],"a":1,"e":"Start at 19, count back 6: 18,17,16,15,14,13.","d":"m"},{"t":"Use the count-on strategy. What is 10 + 5?","o":["13","14","15","16"],"a":2,"e":"Start at 10, count on 5: 11,12,13,14,15.","d":"m"},{"t":"Use the count-back strategy. What is 16 − 4?","o":["10","11","13","12"],"a":3,"e":"Start at 16, count back 4: 15,14,13,12.","d":"m"},{"t":"Use the count-on strategy. What is 15 + 3?","o":["16","17","18","19"],"a":2,"e":"Start at 15, count on 3: 16,17,18.","d":"m"},{"t":"Use the count-back strategy. What is 13 − 6?","o":["5","6","7","8"],"a":2,"e":"Start at 13, count back 6: 12,11,10,9,8,7.","d":"m"},{"t":"Start at 3. Count up 2. What number do you land on?","o":["4","5","6","3"],"a":1,"e":"Count: 3... 4, 5. You land on 5.","d":"e"},{"t":"What is 2 + 1?","o":["3","4","2","1"],"a":0,"e":"Start at 2, count up 1. You get 3.","d":"e"},{"t":"What is 5 + 2?","o":["6","8","7","5"],"a":2,"e":"Count up from 5: 6, 7. The answer is 7.","d":"e"},{"t":"What is 4 + 3?","o":["8","6","7","5"],"a":2,"e":"Start at 4 and count up 3: 5, 6, 7.","d":"e"},{"t":"Start at 6. Count up 1. What number do you get?","o":["5","8","6","7"],"a":3,"e":"6... 7. You land on 7.","d":"e"},{"t":"What is 1 + 3?","o":["3","5","4","2"],"a":2,"e":"Start at 1, count up 3: 2, 3, 4. The answer is 4.","d":"e"},{"t":"Count back 1 from 5. What number do you get?","o":["6","3","5","4"],"a":3,"e":"Start at 5, count back 1: 4.","d":"e"},{"t":"What is 7 - 1?","o":["8","7","5","6"],"a":3,"e":"Count back 1 from 7. You get 6.","d":"e"},{"t":"Count back 2 from 6. Where do you land?","o":["5","4","3","8"],"a":1,"e":"Start at 6, count back: 5, 4. You land on 4.","d":"e"},{"t":"What is 5 - 2?","o":["4","2","3","7"],"a":2,"e":"Count back 2 from 5: 4, 3. The answer is 3.","d":"e"},{"t":"What is 3 + 1?","o":["2","5","3","4"],"a":3,"e":"Start at 3, count up 1: 4.","d":"e"},{"t":"Count up 3 from 2. What number do you reach?","o":["4","6","5","3"],"a":2,"e":"Start at 2, count: 3, 4, 5. You reach 5.","d":"e"},{"t":"What is 8 - 2?","o":["5","7","6","10"],"a":2,"e":"Count back 2 from 8: 7, 6. The answer is 6.","d":"e"},{"t":"What is 6 - 1?","o":["7","4","6","5"],"a":3,"e":"Count back 1 from 6. You get 5.","d":"e"},{"t":"Start at 1. Count up 2. Where do you land?","o":["2","4","1","3"],"a":3,"e":"Count from 1: 2, 3. You land on 3.","d":"e"},{"t":"What is 9 - 2?","o":["8","6","11","7"],"a":3,"e":"Count back 2 from 9: 8, 7. The answer is 7.","d":"e"},{"t":"What is 4 + 1?","o":["3","6","4","5"],"a":3,"e":"Start at 4, count up 1: 5.","d":"e"},{"t":"Count back 3 from 7. What number do you get?","o":["5","3","10","4"],"a":3,"e":"Start at 7, count back: 6, 5, 4. You get 4.","d":"e"},{"t":"What is 2 + 3?","o":["4","6","5","3"],"a":2,"e":"Start at 2, count up 3: 3, 4, 5. The answer is 5.","d":"e"},{"t":"What is 10 - 1?","o":["11","8","9","10"],"a":2,"e":"Count back 1 from 10. You get 9.","d":"e"},{"t":"Jada has 8 crayons. She gets 3 more. How many crayons does she have now?","o":["10","12","11","5"],"a":2,"e":"Count up 3 from 8: 9, 10, 11. Jada has 11 crayons.","d":"h"},{"t":"__ + 3 = 7. What is the missing number?","o":["3","10","5","4"],"a":3,"e":"Think: what plus 3 equals 7? Count back 3 from 7: 6, 5, 4. The missing number is 4.","d":"h"},{"t":"Which way helps you solve 9 + 3?","o":["Count back 3 from 9","Skip count by 5s","Count up 3 from 9","Subtract 3 from 9"],"a":2,"e":"To add, count up from the bigger number. Start at 9 and count up 3: 10, 11, 12.","d":"m"},{"t":"Leo had 12 grapes. He ate 3. How many grapes are left?","o":["8","15","10","9"],"a":3,"e":"Count back 3 from 12: 11, 10, 9. Leo has 9 grapes left.","d":"h"},{"t":"Count up 4 from 7. What number do you reach?","o":["12","10","3","11"],"a":3,"e":"Start at 7, count up: 8, 9, 10, 11. You reach 11.","d":"e"},{"t":"9 - __ = 6. What is the missing number?","o":["2","15","4","3"],"a":3,"e":"Think: 9 minus what gives 6? Count back from 9 to 6: 8, 7, 6. That is 3 steps. The answer is 3.","d":"h"},{"t":"A frog is on lily pad 5. It jumps forward 4 pads. Which pad does it land on?","o":["10","1","8","9"],"a":3,"e":"Count up 4 from 5: 6, 7, 8, 9. The frog lands on pad 9.","d":"e"},{"t":"Which number sentence can you solve by counting back 2?","o":["5 + 2","7 - 2","3 + 3","2 + 2"],"a":1,"e":"Counting back is for subtraction. 7 - 2 means count back 2 from 7: 6, 5.","d":"e"},{"t":"There are 11 birds on a fence. 4 fly away. How many are left?","o":["8","6","15","7"],"a":3,"e":"Count back 4 from 11: 10, 9, 8, 7. There are 7 birds left.","d":"h"},{"t":"6 + __ = 9. What is the missing number?","o":["2","4","15","3"],"a":3,"e":"Count up from 6 to 9: 7, 8, 9. That is 3 steps. The missing number is 3.","d":"h"},{"t":"Kai has 7 toy cars. His friend gives him some more. Now Kai has 10. How many did his friend give him?","o":["2","4","17","3"],"a":3,"e":"Count up from 7 to 10: 8, 9, 10. His friend gave him 3 cars.","d":"h"},{"t":"Which is the best way to solve 11 - 3?","o":["Count up 3 from 11","Count back 3 from 11","Add 3 to 11","Skip count by 3s"],"a":1,"e":"To subtract, count back. Start at 11, count back 3: 10, 9, 8.","d":"m"},{"t":"__ - 2 = 8. What is the missing number?","o":["6","11","9","10"],"a":3,"e":"Think: what minus 2 equals 8? Count up 2 from 8: 9, 10. The missing number is 10.","d":"h"},{"t":"A bunny hops 3 spaces from 6 on a number line. Where does it land?","o":["3","10","8","9"],"a":3,"e":"Count up 3 from 6: 7, 8, 9. The bunny lands on 9.","d":"m"},{"t":"There are 14 apples. 4 are eaten. How many are left?","o":["11","10","18","9"],"a":1,"e":"Count back 4 from 14: 13, 12, 11, 10. There are 10 apples left.","d":"h"},{"t":"Which problem can be solved by counting up from 8?","o":["8 - 3","3 - 8","8 + 2","2 - 8"],"a":2,"e":"Count up is for adding. For 8 + 2, start at 8 and count up 2: 9, 10.","d":"e"},{"t":"Maya picks 6 flowers. Then she picks 5 more. How many flowers does she have?","o":["12","1","10","11"],"a":3,"e":"Count up 5 from 6: 7, 8, 9, 10, 11. Maya has 11 flowers.","d":"h"},{"t":"7 + __ = 11. What is the missing number?","o":["3","5","18","4"],"a":3,"e":"Count up from 7 to 11: 8, 9, 10, 11. That is 4 steps. The missing number is 4.","d":"h"},{"t":"Start at 15. Count back 3. What number do you land on?","o":["11","18","13","12"],"a":3,"e":"Count back from 15: 14, 13, 12. You land on 12.","d":"e"},{"t":"A dog has 9 treats. It eats some. Now it has 6. How many did it eat?","o":["4","2","15","3"],"a":3,"e":"Count back from 9 to 6: 8, 7, 6. That is 3 steps. The dog ate 3 treats.","d":"h"},{"t":"Mia had 14 stickers. She gave 3 to Kai and 4 to Jada. How many stickers does Mia have left?","o":["8","6","9","7"],"a":3,"e":"Two steps: 14 - 3 = 11, then 11 - 4 = 7. Count back each time. Mia has 7 left.","d":"h"},{"t":"A student wrote: 11 - 3 = 9. What mistake did the student make?","o":["They added instead","They counted back only 2, not 3","They started at 12","They counted up"],"a":1,"e":"Error analysis: 11 - 3 should be 8. The student only counted back 2 (to 9) instead of 3.","d":"h"},{"t":"Leo says counting back 4 from 13 gives 8. Is Leo correct?","o":["No, it should be 10","No, it should be 9","Yes, Leo is correct","No, it should be 7"],"a":1,"e":"Check: 13, 12, 11, 10, 9. Counting back 4 from 13 gives 9, not 8. Leo counted back 5 by mistake.","d":"h"},{"t":"__ + __ = 11. Both numbers are more than 3. What could they be?","o":["2 and 9","4 and 7","3 and 8","1 and 10"],"a":1,"e":"Open reasoning: both must be more than 3. 4 + 7 = 11 and both 4 and 7 are more than 3.","d":"h"},{"t":"Sam had 8 marbles. He found some more and now has 15. Then he lost 3. How many does Sam have now?","o":["10","13","11","12"],"a":3,"e":"Two steps: Sam went from 8 to 15 marbles. Then 15 - 3 = 12. Sam has 12 marbles now.","d":"h"},{"t":"Which number sentence is NOT solved by counting back?","o":["10 - 2","13 - 4","7 + 3","9 - 1"],"a":2,"e":"Counting back is for subtraction. 7 + 3 is addition, so you count up, not back.","d":"e"},{"t":"A student wrote: 7 + 4 = 12. What went wrong?","o":["They subtracted instead","They counted up 5 instead of 4","They started at 8 instead of 7","They counted up from 6"],"a":1,"e":"Error analysis: 7 + 4 = 11, not 12. The student counted too many: 8, 9, 10, 11, 12 (5 counts, not 4).","d":"h"},{"t":"Zoe is on step 6. She goes up 3 steps, then back down 2 steps. What step is she on now?","o":["5","8","6","7"],"a":3,"e":"Two steps: 6 + 3 = 9, then 9 - 2 = 7. Zoe is on step 7.","d":"h"},{"t":"I am a number. If you count back 3 from me, you get 9. What number am I?","o":["6","11","13","12"],"a":3,"e":"Think backwards: __ - 3 = 9. Count up 3 from 9: 10, 11, 12. The number is 12.","d":"h"},{"t":"True or false: You can solve 6 + 3 by counting back 3 from 6.","o":["True, counting back works for addition","False, you should count up 3 from 6","True, it gives the same answer","False, you should count back from 3"],"a":1,"e":"Count back is for subtraction. For 6 + 3, count up from 6: 7, 8, 9. The answer is 9.","d":"h"},{"t":"There were 16 kids at the park. 5 went home, then 3 more went home. How many are still at the park?","o":["7","9","10","8"],"a":3,"e":"Two steps: 16 - 5 = 11, then 11 - 3 = 8. Count back each time. 8 kids are still at the park.","d":"h"},{"t":"Kim says 8 + 3 = 10. What should Kim do to fix her work?","o":["Count back 3 from 8","Count up one more from 10","Start over at 3","Subtract instead of add"],"a":1,"e":"Error analysis: 8 + 3 = 11. Kim stopped one count too early. She should count one more: 9, 10, 11.","d":"h"},{"t":"__ - 4 = 7. Then 7 + 2 = __. What are both missing numbers?","o":["10 and 9","12 and 9","11 and 9","11 and 10"],"a":2,"e":"First: count up 4 from 7 to get 11. Then 7 + 2 = 9. The answers are 11 and 9.","d":"h"},{"t":"Which problem gives the BIGGEST answer?","o":["9 + 3","8 + 2","7 + 4","6 + 5"],"a":0,"e":"Compare: 9 + 3 = 12, 8 + 2 = 10, 7 + 4 = 11, 6 + 5 = 11. The biggest answer is 12.","d":"e"},{"t":"A number line goes from 0 to 20. You start at 5, jump forward 4, then jump forward 3. Where are you?","o":["11","13","10","12"],"a":3,"e":"Two jumps: 5 + 4 = 9, then 9 + 3 = 12. You are at 12.","d":"h"},{"t":"Eli has 13 cards. He gives away some and has 9 left. Then he finds 4 more. How many does Eli have now?","o":["12","14","8","13"],"a":3,"e":"First: 13 - 9 = 4 given away. Then 9 + 4 = 13. Eli has 13 cards now.","d":"h"},{"t":"A student solved 15 - 4 and got 10. Explain what went wrong.","o":["They counted back 5 instead of 4","They counted back 4 correctly","They added 4 instead","They started at 14"],"a":0,"e":"Error analysis: 15 - 4 = 11. The student got 10, meaning they counted back 5 instead of 4.","d":"h"},{"t":"I am thinking of two numbers that add up to 13. Both are greater than 5. What could they be?","o":["4 and 9","5 and 8","6 and 7","3 and 10"],"a":2,"e":"Open reasoning: both must be greater than 5. 6 + 7 = 13 and both 6 and 7 are greater than 5.","d":"h"},{"t":"Count back 3 from 12, then count back 2 more. What number do you get?","o":["8","6","9","7"],"a":3,"e":"Two steps: 12 - 3 = 9 (count back: 11, 10, 9). Then 9 - 2 = 7 (count back: 8, 7). You get 7.","d":"h"},{"t":"Is this true or false? 14 - 3 and 13 - 2 give the same answer.","o":["True, both equal 11","False, 14 - 3 = 10","False, 13 - 2 = 12","False, they give different answers"],"a":0,"e":"Check both: 14 - 3 = 11 and 13 - 2 = 11. They are the same! Both equal 11.","d":"h"}],"quiz":[{"t":"Use the count-on strategy. What is 9 + 3?","o":["10","11","12","13"],"a":2,"e":"Start at 9, count on 3: 10, 11, 12. Answer is 12!"},{"t":"Use the count-on strategy. What is 7 + 4?","o":["9","10","11","12"],"a":2,"e":"Start at 7, count on 4: 8, 9, 10, 11. Answer is 11!"},{"t":"Use the count-on strategy. What is 6 + 5?","o":["9","10","11","12"],"a":2,"e":"Start at 6, count on 5: 7, 8, 9, 10, 11. Answer is 11!"},{"t":"Use the count-back strategy. What is 12 − 5?","o":["5","6","7","8"],"a":2,"e":"Start at 12, count back 5: 11,10,9,8,7. Answer is 7!"},{"t":"Use the count-back strategy. What is 15 − 4?","o":["10","11","12","13"],"a":1,"e":"Start at 15, count back 4: 14,13,12,11. Answer is 11!"},{"t":"Use the count-back strategy. What is 16 − 3?","o":["11","12","13","14"],"a":2,"e":"Start at 16, count back 3: 15,14,13. Answer is 13!"}]},{"points":["DOUBLES: add the same number twice — memorize these!","NEAR DOUBLES: one number is 1 more — use the double then add 1","Example: 6+7? Think 6+6=12, then +1 more = 13"],"examples":[{"c":"#e74c3c","tag":"Doubles","p":"6 + 6 = ?","s":"Same number + same number = double! 6 doubled is 12","a":"6 + 6 = 12 ✅","vis":"doubles:🍊:6"},{"c":"#e74c3c","tag":"Doubles","p":"8 + 8 = ?","s":"8 doubled = 16","a":"8 + 8 = 16 ✅","vis":"doubles:🍇:8"},{"c":"#c0392b","tag":"Near Doubles","p":"7 + 8 = ?","s":"Think: 7+7=14 (double), then add 1 more = 15","a":"7 + 8 = 15 ✅","vis":"add:🍓:7:8"}],"practice":[{"q":"7 + 7 = ?","a":"14","h":"Double 7! Two groups of 7","e":"⭐"},{"q":"5 + 5 = ?","a":"10","h":"Double 5! Two groups of 5","e":"🌟"},{"q":"6 + 7 = ?","a":"13","h":"Near double: 6+6=12, then +1 more!","e":"🍓"}],"qBank":[{"t":"What is 3 + 3? (This is a doubles fact!)","o":["4","5","6","7"],"a":2,"e":"3 doubled = 6.","d":"e"},{"t":"What is 4 + 4? (This is a doubles fact!)","o":["6","7","8","9"],"a":2,"e":"4 doubled = 8.","d":"e"},{"t":"What is 5 + 5? (This is a doubles fact!)","o":["8","9","10","11"],"a":2,"e":"5 doubled = 10.","d":"e"},{"t":"What is 6 + 6? (This is a doubles fact!)","o":["10","11","12","13"],"a":2,"e":"6 doubled = 12.","d":"m"},{"t":"What is 7 + 7? (This is a doubles fact!)","o":["12","13","14","15"],"a":2,"e":"7 doubled = 14.","d":"m"},{"t":"What is 8 + 8? (This is a doubles fact!)","o":["14","15","16","17"],"a":2,"e":"8 doubled = 16.","d":"m"},{"t":"What is 9 + 9? (This is a doubles fact!)","o":["16","17","18","19"],"a":2,"e":"9 doubled = 18.","d":"m"},{"t":"What is 3 + 4? Use the near-doubles strategy.","o":["5","6","7","8"],"a":2,"e":"3+3=6, +1=7.","d":"e"},{"t":"What is 4 + 5? Use the near-doubles strategy.","o":["7","8","9","10"],"a":2,"e":"4+4=8, +1=9.","d":"e"},{"t":"What is 5 + 6? Use the near-doubles strategy.","o":["11","9","10","12"],"a":0,"e":"5+5=10, +1=11.","d":"m"},{"t":"What is 6 + 7? Use the near-doubles strategy.","o":["11","12","14","13"],"a":3,"e":"6+6=12, +1=13.","d":"m"},{"t":"What is 7 + 8? Use the near-doubles strategy.","o":["13","15","14","16"],"a":1,"e":"7+7=14, +1=15.","d":"m"},{"t":"What is 8 + 9? Use the near-doubles strategy.","o":["15","16","17","18"],"a":2,"e":"8+8=16, +1=17.","d":"m"},{"t":"What is 9 + 10? Use the near-doubles strategy.","o":["17","18","19","20"],"a":2,"e":"9+9=18, +1=19.","d":"m"},{"t":"What is 2 + 2? (This is a doubles fact!)","o":["2","3","4","5"],"a":2,"e":"2 doubled = 4.","d":"e"},{"t":"Which is a doubles fact?","o":["3+4=7","6+6=12","5+6=11","7+8=15"],"a":1,"e":"6+6=12 uses the same number twice — that is a double!","d":"e"},{"t":"What is 10 + 11? Use the near-doubles strategy.","o":["19","20","21","22"],"a":2,"e":"10+10=20, +1=21.","d":"m"},{"t":"What is 1 + 1? (This is a doubles fact!)","o":["1","2","3","4"],"a":1,"e":"1 doubled = 2.","d":"m"},{"t":"Near double strategy: 5 + 6. Think 5+5=10 then?","o":["Add 0","Add 1","Add 2","Subtract 1"],"a":1,"e":"Near double: use 5+5=10 then add 1 more to get 11.","d":"h"},{"t":"What is 10 + 10? (This is a doubles fact!)","o":["15","18","20","22"],"a":2,"e":"10 doubled = 20.","d":"m"},{"t":"Which helps solve 7+8?","o":["7+7=14","8+8=16","7+9=16","6+8=14"],"a":0,"e":"7 is a near double of 8. Use 7+7=14 then +1=15.","d":"m"},{"t":"What is 11 + 12? Use the near-doubles strategy.","o":["21","22","23","24"],"a":2,"e":"11+11=22, +1=23.","d":"m"},{"t":"What is 15 + 15? (This is a doubles fact!)","o":["25","28","30","32"],"a":2,"e":"15 doubled = 30.","d":"m"},{"t":"What is 4 + 3? Use the near-doubles strategy.","o":["5","6","7","8"],"a":2,"e":"4+4=8, but 3+4 is near double: 3+3=6, +1=7.","d":"m"},{"t":"What is the double of 12?","o":["20","22","24","26"],"a":2,"e":"12+12=24.","d":"m"},{"t":"What is 6 + 5? Use the near-doubles strategy.","o":["9","10","11","12"],"a":2,"e":"5+5=10, +1=11. Same as 5+6!","d":"m"},{"t":"Which strategy for 8+9?","o":["Count back","Doubles","Near doubles","Skip count by 5"],"a":2,"e":"8+9 is a near double. 8+8=16, +1=17.","d":"m"},{"t":"What is the double of 20?","o":["30","35","40","45"],"a":2,"e":"20+20=40.","d":"m"},{"t":"What is 14 + 15? Use the near-doubles strategy.","o":["27","28","29","30"],"a":2,"e":"14+14=28, +1=29.","d":"m"},{"t":"What is 11 + 11? (This is a doubles fact!)","o":["20","21","22","23"],"a":2,"e":"11 doubled = 22.","d":"m"},{"t":"What is 2 + 2?","o":["3","5","4","2"],"a":2,"e":"Use doubles: 2 + 2 = 4.","d":"e"},{"t":"What is 3 + 3?","o":["5","7","6","3"],"a":2,"e":"Use doubles: 3 + 3 = 6.","d":"e"},{"t":"What is 4 + 4?","o":["6","9","8","7"],"a":2,"e":"Use doubles: 4 + 4 = 8.","d":"e"},{"t":"What is 5 + 5?","o":["11","8","9","10"],"a":3,"e":"Use doubles: 5 + 5 = 10.","d":"e"},{"t":"What is 1 + 1?","o":["3","0","1","2"],"a":3,"e":"Use doubles: 1 + 1 = 2.","d":"e"},{"t":"What is 6 + 6?","o":["11","13","10","12"],"a":3,"e":"Use doubles: 6 + 6 = 12.","d":"e"},{"t":"What is 7 + 7?","o":["13","15","12","14"],"a":3,"e":"Use doubles: 7 + 7 = 14.","d":"e"},{"t":"What is 8 + 8?","o":["14","18","15","16"],"a":3,"e":"Use doubles: 8 + 8 = 16.","d":"e"},{"t":"What is 9 + 9?","o":["17","19","18","16"],"a":2,"e":"Use doubles: 9 + 9 = 18.","d":"e"},{"t":"What is 10 + 10?","o":["22","18","20","19"],"a":2,"e":"Use doubles: 10 + 10 = 20.","d":"e"},{"t":"What is double 3?","o":["5","9","3","6"],"a":3,"e":"Double means add a number to itself. 3 + 3 = 6.","d":"e"},{"t":"What is double 5?","o":["15","5","10","8"],"a":2,"e":"Double means 5 + 5. That equals 10.","d":"e"},{"t":"What is double 7?","o":["12","15","7","14"],"a":3,"e":"Double 7 means 7 + 7. That equals 14.","d":"m"},{"t":"What is double 4?","o":["6","4","10","8"],"a":3,"e":"Double 4 means 4 + 4 = 8.","d":"e"},{"t":"What is 0 + 0?","o":["2","1","0","10"],"a":2,"e":"Use doubles: 0 + 0 = 0. Zero plus zero is still zero.","d":"e"},{"t":"What is double 8?","o":["18","14","16","8"],"a":2,"e":"Double 8 means 8 + 8 = 16.","d":"m"},{"t":"What is double 2?","o":["2","6","3","4"],"a":3,"e":"Double 2 means 2 + 2 = 4.","d":"e"},{"t":"What is double 6?","o":["8","6","10","12"],"a":3,"e":"Double 6 means 6 + 6 = 12.","d":"m"},{"t":"What is double 1?","o":["0","1","3","2"],"a":3,"e":"Double 1 means 1 + 1 = 2.","d":"e"},{"t":"What is double 9?","o":["16","19","18","17"],"a":2,"e":"Double 9 means 9 + 9 = 18.","d":"m"},{"t":"What is 6 + 7? Hint: Think of a double you know.","o":["14","12","11","13"],"a":3,"e":"Use doubles plus 1: 6 + 6 = 12, then add 1 more. 12 + 1 = 13.","d":"h"},{"t":"What is 5 + 6?","o":["12","10","11","9"],"a":2,"e":"Use doubles plus 1: 5 + 5 = 10, plus 1 more = 11.","d":"e"},{"t":"Sara has 7 red beads and 7 blue beads. How many beads in all?","o":["13","15","12","14"],"a":3,"e":"Use doubles: 7 + 7 = 14. Sara has 14 beads.","d":"h"},{"t":"__ + __ = 16. Both numbers are the same. What are they?","o":["7 and 7","9 and 9","6 and 6","8 and 8"],"a":3,"e":"Think: what double equals 16? 8 + 8 = 16. Both numbers are 8.","d":"h"},{"t":"Which doubles fact helps you solve 8 + 9?","o":["7 + 7","9 + 9","8 + 8","6 + 6"],"a":2,"e":"Strategy: 8 + 9 is close to 8 + 8 = 16. Then add 1 more: 17. Use doubles plus 1.","d":"h"},{"t":"What is 7 + 8?","o":["14","16","13","15"],"a":3,"e":"Use doubles plus 1: 7 + 7 = 14, then add 1 more = 15.","d":"e"},{"t":"A boy has 2 hands. Each hand has 5 fingers. How many fingers in all?","o":["7","12","10","8"],"a":2,"e":"Use doubles: 5 + 5 = 10. He has 10 fingers in all.","d":"h"},{"t":"What is 4 + 5?","o":["10","8","7","9"],"a":3,"e":"Use doubles plus 1: 4 + 4 = 8, plus 1 more = 9.","d":"e"},{"t":"__ + 6 = 12. What is the missing number?","o":["5","7","8","6"],"a":3,"e":"Think: what plus 6 equals 12? Use doubles: 6 + 6 = 12. The missing number is 6.","d":"h"},{"t":"Which strategy helps you solve 3 + 4?","o":["Make a 10","Doubles plus 1","Count by 10s","Subtract"],"a":1,"e":"3 + 4 is close to the double 3 + 3 = 6. Then add 1 more to get 7. Use doubles plus 1.","d":"m"},{"t":"What is 9 + 8?","o":["18","16","15","17"],"a":3,"e":"Use doubles minus 1: 9 + 9 = 18, minus 1 = 17. Or 8 + 8 = 16, plus 1 = 17.","d":"e"},{"t":"Two friends each have 6 stickers. How many stickers do they have together?","o":["10","14","11","12"],"a":3,"e":"Use doubles: 6 + 6 = 12 stickers together.","d":"h"},{"t":"__ + __ = 10. Both numbers are the same. What is each number?","o":["4","6","3","5"],"a":3,"e":"Think: what double equals 10? 5 + 5 = 10. Each number is 5.","d":"h"},{"t":"What is 3 + 4? Use a doubles fact to help.","o":["8","6","5","7"],"a":3,"e":"Doubles plus 1: 3 + 3 = 6, plus 1 = 7.","d":"m"},{"t":"Max has 8 toy cars. His brother has 7. How many cars do they have together?","o":["14","16","13","15"],"a":3,"e":"Use doubles plus 1: 7 + 7 = 14, then 1 more = 15. They have 15 cars.","d":"h"},{"t":"Which doubles fact helps you solve 5 + 6?","o":["6 + 6","4 + 4","5 + 5","3 + 3"],"a":2,"e":"5 + 6 is close to 5 + 5 = 10. Add 1 more to get 11.","d":"h"},{"t":"__ + 9 = 18. What is the missing number?","o":["8","10","7","9"],"a":3,"e":"Think: what plus 9 equals 18? Use doubles: 9 + 9 = 18. The missing number is 9.","d":"h"},{"t":"What is 8 + 7?","o":["14","16","13","15"],"a":3,"e":"Use doubles plus 1: 7 + 7 = 14, add 1 more = 15. Or 8 + 8 = 16, minus 1 = 15.","d":"e"},{"t":"Ava and Mia each brought 4 books. How many books are there in all?","o":["6","9","7","8"],"a":3,"e":"Use doubles: 4 + 4 = 8 books in all.","d":"m"},{"t":"What is 2 + 3? Use a doubles fact.","o":["4","6","3","5"],"a":3,"e":"Doubles plus 1: 2 + 2 = 4, plus 1 = 5. The answer is 5.","d":"m"},{"t":"Emma has 7 red marbles and 8 blue marbles. She gives away 3 marbles. How many does she have left?","o":["11","13","10","12"],"a":3,"e":"Two steps: 7 + 8 = 15 (use doubles plus 1: 7 + 7 = 14, + 1 = 15). Then 15 - 3 = 12.","d":"h"},{"t":"A student said double 7 is 15. What mistake did the student make?","o":["They added 8 + 7 by mistake","They subtracted instead","They used the wrong double","They forgot to count"],"a":0,"e":"Error analysis: double 7 is 7 + 7 = 14, not 15. The student may have confused it with 7 + 8 = 15.","d":"h"},{"t":"Jake says 6 + 7 = 14 because double 7 is 14. Is Jake correct?","o":["Yes, 6 + 7 = 14","No, it should be 13","No, it should be 12","No, it should be 15"],"a":1,"e":"Jake used the wrong double. 6 + 7: use double 6 = 12, plus 1 = 13. Or double 7 = 14, minus 1 = 13.","d":"h"},{"t":"__ + __ = 18. Both numbers are the same. What are they? Then subtract 5 from your answer. What do you get?","o":["9 and 13","8 and 13","9 and 14","8 and 11"],"a":0,"e":"Double: 9 + 9 = 18. Then 18 - 5 = 13. The numbers are 9, and you get 13.","d":"h"},{"t":"Which problem can NOT be solved with doubles plus 1?","o":["6 + 7","5 + 6","4 + 4","3 + 4"],"a":2,"e":"4 + 4 is an exact double, not doubles plus 1. Doubles plus 1 works when numbers are 1 apart.","d":"e"},{"t":"Two teams each score 8 points. Then one team scores 3 more. What is the winning team's total?","o":["16","19","10","11"],"a":3,"e":"Two steps: doubles 8 + 8 = 16 is the tie. Winning team: 8 + 3 = 11. The winning team has 11.","d":"h"},{"t":"A student wrote 8 + 9 = 16. What should the student do to fix it?","o":["Subtract 1 from 16","Add 1 more to get 17","Start over with 8 + 8","Change to 9 + 9"],"a":1,"e":"Error analysis: 8 + 9 = 17. The student got 16 (which is 8 + 8). They need to add 1 more.","d":"h"},{"t":"I am a doubles fact. My answer is between 10 and 15. What could I be?","o":["5 + 5 or 6 + 6","4 + 4 or 8 + 8","6 + 6 or 7 + 7","3 + 3 or 9 + 9"],"a":2,"e":"Check: 6 + 6 = 12 (between 10 and 15). 7 + 7 = 14 (between 10 and 15). Both work!","d":"h"},{"t":"Lily had 6 coins. She found 6 more. Then she spent 4 coins. How many does she have now?","o":["10","7","6","8"],"a":3,"e":"Two steps: 6 + 6 = 12 (doubles!). Then 12 - 4 = 8. Lily has 8 coins.","d":"h"},{"t":"True or false: 5 + 6 and 6 + 5 give different answers because the numbers switched.","o":["True, switching changes the answer","False, both equal 11","True, 5 + 6 = 12","False, both equal 12"],"a":1,"e":"Addition can be done in any order. 5 + 6 = 11 and 6 + 5 = 11. Same answer!","d":"h"},{"t":"Which two doubles facts have answers that are 4 apart?","o":["3 + 3 and 5 + 5","4 + 4 and 5 + 5","2 + 2 and 3 + 3","6 + 6 and 7 + 7"],"a":0,"e":"Check: 3 + 3 = 6 and 5 + 5 = 10. 10 - 6 = 4. They are 4 apart!","d":"e"},{"t":"Ben says 5 + 4 = 10 because double 5 is 10. What did Ben forget?","o":["He should subtract 1 since 4 is one less than 5","He should add 1 more","He used the wrong doubles fact","He should use make a 10"],"a":0,"e":"Error analysis: 5 + 4 is doubles minus 1. Double 5 = 10, then subtract 1 = 9. Ben forgot to subtract 1.","d":"h"},{"t":"Each of 3 kids has 5 crayons. Is this a doubles problem? Why or why not?","o":["Yes, because 5 + 5 = 10","No, there are 3 groups, not 2","Yes, because 3 + 3 = 6","No, because 5 is odd"],"a":1,"e":"Doubles means 2 equal groups. 3 kids with 5 each is 3 groups, so it is not a doubles problem.","d":"h"},{"t":"What is the missing number? Double __ = 14. Then add 3 to that number. What do you get?","o":["7 and 10","6 and 9","8 and 11","7 and 9"],"a":0,"e":"Double 7 = 14. Then 7 + 3 = 10. The answers are 7 and 10.","d":"h"},{"t":"Ava solved 7 + 8 by thinking 7 + 7 + 1. Nora solved it by thinking 8 + 8 - 1. Who is correct?","o":["Only Ava","Only Nora","Both are correct","Neither is correct"],"a":2,"e":"Both strategies work! 7 + 7 + 1 = 15 and 8 + 8 - 1 = 15. Doubles plus 1 and doubles minus 1 both give 15.","d":"h"},{"t":"A student wrote: double 6 = 11. Then they wrote 6 + 7 = 12. How many errors did they make?","o":["0 errors","1 error","2 errors","3 errors"],"a":2,"e":"Error analysis: double 6 = 12 (not 11), and 6 + 7 = 13 (not 12). That is 2 errors.","d":"h"},{"t":"__ + __ = 12. The two numbers are 2 apart. What could they be?","o":["4 and 8","5 and 7","6 and 6","3 and 9"],"a":1,"e":"Open reasoning: 5 + 7 = 12, and 7 - 5 = 2. They are 2 apart!","d":"h"},{"t":"Sam has some stickers. He gets the same number again and now has 16. How many did he start with?","o":["6","9","7","8"],"a":3,"e":"Think: __ + __ = 16, same number. That means double __ = 16. 8 + 8 = 16. Sam started with 8.","d":"h"},{"t":"Which is greater: double 6 plus 3 OR double 4 plus 5?","o":["Double 6 plus 3","Double 4 plus 5","They are equal","Cannot tell"],"a":0,"e":"Compare: double 6 + 3 = 12 + 3 = 15. Double 4 + 5 = 8 + 5 = 13. 15 > 13. Double 6 plus 3 is greater.","d":"h"},{"t":"A puzzle says: I am a number. Double me, then take away 2. You get 10. What number am I?","o":["5","7","8","6"],"a":3,"e":"Work backwards: 10 + 2 = 12. Now half of 12 is 6. Double 6 = 12, minus 2 = 10. The number is 6.","d":"h"}],"quiz":[{"t":"What is 6 + 6? (Doubles fact)","o":["10","11","12","13"],"a":2,"e":"6+6 is a doubles fact = 12. Memorize it!"},{"t":"What is 4 + 4? (Doubles fact)","o":["6","7","8","9"],"a":2,"e":"4+4 is a doubles fact = 8."},{"t":"What is 9 + 9? (Doubles fact)","o":["16","17","18","19"],"a":2,"e":"9+9 = 18. Nine doubled is eighteen!"},{"t":"What is 5 + 6? Use the near-doubles strategy.","o":["9","10","11","12"],"a":2,"e":"5+5=10, then +1 more = 11. Near double of 5!"},{"t":"What is 7 + 8? Use the near-doubles strategy.","o":["13","14","15","16"],"a":2,"e":"7+7=14, then +1 more = 15."},{"t":"What is 8 + 9? Use the near-doubles strategy.","o":["15","16","17","18"],"a":2,"e":"8+8=16, then +1 more = 17."}]},{"points":["Find what you need to REACH 10 from the bigger number","Break the smaller number to reach 10 first","Example: 8+6 → 8+2=10, then +4 more = 14"],"examples":[{"c":"#e74c3c","tag":"Make a Ten","p":"8 + 5 = ?","s":"Step 1: How many does 8 need to reach 10? → 2\nStep 2: Break 5 into 2 + 3\nStep 3: 8 + 2 = 10, then 10 + 3 = 13","a":"8 + 5 = 13 ✅","vis":"tenframe:8"},{"c":"#e74c3c","tag":"Make a Ten","p":"9 + 6 = ?","s":"Step 1: How many does 9 need to reach 10? → 1\nStep 2: Break 6 into 1 + 5\nStep 3: 9 + 1 = 10, then 10 + 5 = 15","a":"9 + 6 = 15 ✅","vis":"tenframe:9"},{"c":"#e74c3c","tag":"Make a Ten","p":"7 + 5 = ?","s":"Step 1: How many does 7 need to reach 10? → 3\nStep 2: Break 5 into 3 + 2\nStep 3: 7 + 3 = 10, then 10 + 2 = 12","a":"7 + 5 = 12 ✅","vis":"tenframe:7"}],"practice":[{"q":"8 + 4 = ?","a":"12","h":"8 needs 2 to reach 10. Then add 2 more = 12","e":"🔵"},{"q":"9 + 5 = ?","a":"14","h":"9 needs 1 to reach 10. Then add 4 more = 14","e":"🟡"},{"q":"7 + 4 = ?","a":"11","h":"7 needs 3 to reach 10. Then add 1 more = 11","e":"🟢"}],"qBank":[{"t":"Use the make-ten strategy. What is 9 + 4?","o":["11","12","13","14"],"a":2,"e":"9+1=10, then +3=13.","d":"e"},{"t":"Use the make-ten strategy. What is 8 + 5?","o":["13","11","12","14"],"a":0,"e":"8+2=10, then +3=13.","d":"e"},{"t":"Use the make-ten strategy. What is 7 + 4?","o":["11","9","10","12"],"a":0,"e":"7+3=10, then +1=11.","d":"e"},{"t":"Use the make-ten strategy. What is 9 + 7?","o":["14","15","16","17"],"a":2,"e":"9+1=10, then +6=16.","d":"e"},{"t":"Use the make-ten strategy. What is 8 + 6?","o":["12","13","14","15"],"a":2,"e":"8+2=10, then +4=14.","d":"e"},{"t":"Use the make-ten strategy. What is 7 + 6?","o":["13","11","12","14"],"a":0,"e":"7+3=10, then +3=13.","d":"e"},{"t":"Use the make-ten strategy. What is 6 + 5?","o":["11","9","10","12"],"a":0,"e":"6+4=10, then +1=11.","d":"e"},{"t":"Use the make-ten strategy. What is 9 + 8?","o":["17","15","16","18"],"a":0,"e":"9+1=10, then +7=17.","d":"e"},{"t":"Use the make-ten strategy. What is 6 + 8?","o":["12","13","15","14"],"a":3,"e":"6+4=10, then +4=14.","d":"e"},{"t":"Use the make-ten strategy. What is 7 + 5?","o":["10","11","12","13"],"a":2,"e":"7+3=10, then +2=12.","d":"e"},{"t":"Use the make-ten strategy. What is 8 + 4?","o":["12","10","11","13"],"a":0,"e":"8+2=10, then +2=12.","d":"e"},{"t":"Use the make-ten strategy. What is 9 + 5?","o":["14","12","13","15"],"a":0,"e":"9+1=10, then +4=14.","d":"e"},{"t":"Use the make-ten strategy. What is 6 + 6?","o":["10","11","13","12"],"a":3,"e":"6+4=10, then +2=12.","d":"e"},{"t":"Use the make-ten strategy. What is 7 + 8?","o":["13","14","16","15"],"a":3,"e":"7+3=10, then +5=15.","d":"e"},{"t":"Use the make-ten strategy. What is 8 + 3?","o":["9","11","10","12"],"a":1,"e":"8 needs 2 to reach 10. Then 10+1=11.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 3?","o":["12","10","11","13"],"a":0,"e":"9 needs 1 to reach 10. Then 10+2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 7?","o":["12","14","13","15"],"a":1,"e":"7 needs 3 to reach 10. Then 10+4=14.","d":"m"},{"t":"Use the make-ten strategy. What is 5 + 8?","o":["13","11","12","14"],"a":0,"e":"5+5=10, then +3=13. Or 8+2=10, +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 4 + 9?","o":["11","12","13","14"],"a":2,"e":"9+1=10, then +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 7?","o":["11","12","13","14"],"a":2,"e":"6+4=10, then +3=13.","d":"m"},{"t":"Why do we \"make ten\" first?","o":["It looks cool","10 is easy to add to","It takes longer","We always must start at 10"],"a":1,"e":"Adding to 10 is easy! Once you reach 10, you just add the rest.","d":"e"},{"t":"Use the make-ten strategy. What is 8 + 7?","o":["13","14","16","15"],"a":3,"e":"8+2=10, then +5=15.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 6?","o":["13","14","16","15"],"a":3,"e":"9+1=10, then +5=15.","d":"m"},{"t":"Use the make-ten strategy. What is 5 + 7?","o":["10","11","13","12"],"a":3,"e":"5+5=10, then +2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 3 + 9?","o":["10","11","12","13"],"a":2,"e":"9+1=10, then +2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 4 + 8?","o":["10","11","12","13"],"a":2,"e":"8+2=10, then +2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 8 + 8?","o":["14","15","16","17"],"a":2,"e":"8+2=10, then +6=16.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 9?","o":["14","15","16","17"],"a":2,"e":"9+1=10, then +6=16.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 9?","o":["13","14","15","16"],"a":2,"e":"9+1=10, then +5=15.","d":"m"},{"t":"Use the make-ten strategy. What is 5 + 9?","o":["12","13","14","15"],"a":2,"e":"9+1=10, then +4=14.","d":"m"},{"t":"What number goes with 9 to make 10?","o":["2","0","3","1"],"a":3,"e":"9 + 1 = 10. The number 1 goes with 9 to make 10.","d":"m"},{"t":"What number goes with 8 to make 10?","o":["3","1","2","4"],"a":2,"e":"8 + 2 = 10. The number 2 goes with 8 to make 10.","d":"m"},{"t":"What number goes with 7 to make 10?","o":["4","2","3","1"],"a":2,"e":"7 + 3 = 10. The number 3 goes with 7 to make 10.","d":"m"},{"t":"What number goes with 6 to make 10?","o":["3","5","4","6"],"a":2,"e":"6 + 4 = 10. The number 4 goes with 6 to make 10.","d":"m"},{"t":"What number goes with 5 to make 10?","o":["4","6","5","3"],"a":2,"e":"5 + 5 = 10. The number 5 goes with 5 to make 10.","d":"m"},{"t":"What is 10 + 3?","o":["12","14","13","11"],"a":2,"e":"When you add to 10, just put the number after the 1. 10 + 3 = 13.","d":"e"},{"t":"What is 10 + 5?","o":["14","16","50","15"],"a":3,"e":"10 + 5 = 15. Adding to 10 is easy!","d":"e"},{"t":"What is 10 + 7?","o":["18","17","16","71"],"a":1,"e":"10 + 7 = 17.","d":"e"},{"t":"What is 10 + 1?","o":["12","9","10","11"],"a":3,"e":"10 + 1 = 11.","d":"e"},{"t":"What is 10 + 9?","o":["20","18","91","19"],"a":3,"e":"10 + 9 = 19.","d":"e"},{"t":"What number goes with 4 to make 10?","o":["5","7","4","6"],"a":3,"e":"4 + 6 = 10. The number 6 goes with 4.","d":"m"},{"t":"What number goes with 3 to make 10?","o":["6","8","7","5"],"a":2,"e":"3 + 7 = 10. The number 7 goes with 3.","d":"m"},{"t":"What number goes with 2 to make 10?","o":["7","9","6","8"],"a":3,"e":"2 + 8 = 10. The number 8 goes with 2.","d":"m"},{"t":"What number goes with 1 to make 10?","o":["8","10","9","7"],"a":2,"e":"1 + 9 = 10. The number 9 goes with 1.","d":"m"},{"t":"What is 10 + 2?","o":["11","20","13","12"],"a":3,"e":"10 + 2 = 12.","d":"e"},{"t":"What is 10 + 4?","o":["40","13","14","15"],"a":2,"e":"10 + 4 = 14.","d":"e"},{"t":"What is 10 + 6?","o":["60","17","15","16"],"a":3,"e":"10 + 6 = 16.","d":"e"},{"t":"What is 10 + 8?","o":["80","19","17","18"],"a":3,"e":"10 + 8 = 18.","d":"e"},{"t":"What number goes with 10 to make 10?","o":["1","10","0","5"],"a":2,"e":"10 + 0 = 10. You need 0 more to make 10.","d":"m"},{"t":"What is 10 + 0?","o":["0","11","1","10"],"a":3,"e":"10 + 0 = 10. Adding zero changes nothing.","d":"e"},{"t":"What is 8 + 5? Think: 8 + 2 = 10, then 10 + 3 = ?","o":["12","14","11","13"],"a":3,"e":"Make a 10: Break 5 into 2 and 3. 8 + 2 = 10. Then 10 + 3 = 13.","d":"h"},{"t":"What is 9 + 4?","o":["14","12","11","13"],"a":3,"e":"Make a 10: 9 needs 1 more to make 10. Break 4 into 1 and 3. 9 + 1 = 10, then 10 + 3 = 13.","d":"e"},{"t":"__ + 6 = 10. What is the missing number?","o":["5","3","4","6"],"a":2,"e":"Think: what plus 6 makes 10? 4 + 6 = 10. The missing number is 4.","d":"h"},{"t":"Which strategy helps solve 7 + 5?","o":["Count by 2s","Make a 10 first","Use doubles of 7","Subtract 5 from 7"],"a":1,"e":"Make a 10: 7 + 3 = 10, then 10 + 2 = 12. Break apart 5 into 3 and 2.","d":"m"},{"t":"Kai has 9 toy trucks. He gets 6 more. How many does he have?","o":["14","16","13","15"],"a":3,"e":"Make a 10: 9 + 1 = 10, then 10 + 5 = 15. Break 6 into 1 and 5.","d":"h"},{"t":"What is 7 + 6? Use make a 10.","o":["14","12","11","13"],"a":3,"e":"Make a 10: 7 + 3 = 10, then 10 + 3 = 13. Break 6 into 3 and 3.","d":"m"},{"t":"8 + __ = 13. What is the missing number?","o":["6","4","3","5"],"a":3,"e":"Make a 10: 8 + 2 = 10, then 10 + ? = 13, so ? = 3. That means 2 + 3 = 5. The missing number is 5.","d":"h"},{"t":"A jar has 6 red marbles and 8 blue marbles. How many marbles in all?","o":["15","12","13","14"],"a":3,"e":"Make a 10: 8 + 2 = 10, then 10 + 4 = 14. Break 6 into 2 and 4.","d":"h"},{"t":"What is 9 + 7? Use make a 10.","o":["15","17","14","16"],"a":3,"e":"Make a 10: 9 + 1 = 10, then 10 + 6 = 16. Break 7 into 1 and 6.","d":"m"},{"t":"Which shows how to make a 10 for 8 + 6?","o":["8 + 8 = 16","8 + 2 + 4 = 14","8 + 6 + 2 = 16","6 + 6 = 12"],"a":1,"e":"Break 6 into 2 and 4. Now: 8 + 2 = 10, then 10 + 4 = 14. That is make a 10!","d":"h"},{"t":"What is 6 + 5? Use make a 10.","o":["12","10","13","11"],"a":3,"e":"Make a 10: 6 + 4 = 10, then 10 + 1 = 11. Break 5 into 4 and 1.","d":"m"},{"t":"Ana has 7 stickers. She finds 4 more. How many does she have now?","o":["12","10","13","11"],"a":3,"e":"Make a 10: 7 + 3 = 10, then 10 + 1 = 11. Break 4 into 3 and 1.","d":"h"},{"t":"9 + __ = 15. What is the missing number?","o":["5","7","4","6"],"a":3,"e":"Make a 10: 9 + 1 = 10, then 10 + 5 = 15. So 1 + 5 = 6. The missing number is 6.","d":"h"},{"t":"What is 8 + 7? Use make a 10.","o":["14","16","13","15"],"a":3,"e":"Make a 10: 8 + 2 = 10, then 10 + 5 = 15. Break 7 into 2 and 5.","d":"m"},{"t":"Which number is easiest to make a 10 with?","o":["5","3","9","6"],"a":2,"e":"9 only needs 1 more to make 10. That makes it the easiest to use with make a 10.","d":"e"},{"t":"What is 5 + 8?","o":["14","12","11","13"],"a":3,"e":"Make a 10: 8 + 2 = 10, then 10 + 3 = 13. Break 5 into 2 and 3.","d":"e"},{"t":"7 + __ = 12. What is the missing number?","o":["6","4","3","5"],"a":3,"e":"Make a 10: 7 + 3 = 10, then 10 + 2 = 12. So 3 + 2 = 5. The missing number is 5.","d":"h"},{"t":"There are 9 birds in a tree. 5 more land. How many birds now?","o":["13","15","12","14"],"a":3,"e":"Make a 10: 9 + 1 = 10, then 10 + 4 = 14. Break 5 into 1 and 4.","d":"h"},{"t":"What is 6 + 7? Use make a 10.","o":["14","12","11","13"],"a":3,"e":"Make a 10: 6 + 4 = 10, then 10 + 3 = 13. Break 7 into 4 and 3.","d":"h"},{"t":"__ + 8 = 10. What is the missing number?","o":["3","1","4","2"],"a":3,"e":"Think: what plus 8 makes 10? 2 + 8 = 10. The missing number is 2.","d":"h"},{"t":"Mia has 8 grapes. Her mom gives her 7 more. She eats 3. How many does Mia have now?","o":["11","13","10","12"],"a":3,"e":"Two steps: 8 + 7 = 15 (make a 10: 8 + 2 = 10, + 5 = 15). Then 15 - 3 = 12.","d":"h"},{"t":"A student solved 9 + 5 and got 13. What mistake did the student make?","o":["They made a 10, then added too many","They forgot to break apart 5","They added 9 + 4 instead","They counted wrong by 1"],"a":2,"e":"Error analysis: 9 + 5 = 14, not 13. The student may have added 9 + 4 = 13 instead of 9 + 5.","d":"h"},{"t":"Tom says you cannot use make a 10 for 6 + 3 because the answer is less than 10. Is Tom correct?","o":["No, you can always make a 10","Yes, make a 10 works best when the sum is more than 10","No, 6 + 3 equals 10","Yes, but only because 3 is too small"],"a":1,"e":"Tom is correct! 6 + 3 = 9, which is less than 10. Make a 10 is most helpful when the sum is over 10.","d":"h"},{"t":"__ + 7 = 15. What is the missing number? Then add 3 more to 15. What do you get?","o":["8 and 18","7 and 18","8 and 17","9 and 18"],"a":0,"e":"Make a 10: 7 + 3 = 10, 10 + 5 = 15, so missing is 8. Then 15 + 3 = 18. Answers: 8 and 18.","d":"h"},{"t":"Which two problems BOTH equal 14?","o":["8 + 5 and 9 + 4","8 + 6 and 9 + 5","7 + 6 and 8 + 5","9 + 6 and 7 + 7"],"a":1,"e":"Check: 8 + 6 = 14 and 9 + 5 = 14. Both equal 14! (8 + 5 = 13, not 14.)","d":"e"},{"t":"A student wrote: 7 + 6 = 14. They said 7 + 3 = 10, then 10 + 4 = 14. What went wrong?","o":["They broke apart 6 into 3 and 4 instead of 3 and 3","They should have started with 6","Nothing, the answer is correct","They added to 10 wrong"],"a":0,"e":"Error analysis: 6 = 3 + 3, not 3 + 4. Correct: 7 + 3 = 10, 10 + 3 = 13. The answer is 13, not 14.","d":"h"},{"t":"Leo has 9 apples. Kai has 8 apples. They put them together and give 5 to a friend. How many are left?","o":["11","13","10","12"],"a":3,"e":"Two steps: 9 + 8 = 17 (make a 10: 9 + 1 = 10, + 7 = 17). Then 17 - 5 = 12.","d":"h"},{"t":"For 8 + 5, show two different ways to make a 10.","o":["8+2+3 or 5+5+3","8+2+3 only","5+5+3 only","Neither works"],"a":0,"e":"Way 1: 8 + 2 = 10, then + 3 = 13. Way 2: 5 + 5 = 10, then + 3 = 13. Both make a 10!","d":"h"},{"t":"A puzzle says: I added a number to 9 and got 16. What number did I add?","o":["6","8","5","7"],"a":3,"e":"Make a 10: 9 + 1 = 10, then 10 + ? = 16, so ? = 6. Total added: 1 + 6 = 7.","d":"h"},{"t":"Which problem does NOT need make a 10? Why?","o":["9 + 6","8 + 5","10 + 4","7 + 8"],"a":2,"e":"10 + 4 already has a 10! You just add 4 more to get 14. No need to make a 10 first.","d":"e"},{"t":"Sara solved 8 + 6 using make a 10. She wrote 8 + 2 = 10, then 10 + 3 = 13. Did she break apart 6 correctly?","o":["Yes, 2 + 3 = 6","No, 2 + 3 = 5, not 6. She should write 10 + 4 = 14","No, she should have used 8 + 8","Yes, the answer is 13"],"a":1,"e":"Error analysis: 6 breaks into 2 and 4, not 2 and 3. Correct: 8 + 2 = 10, then 10 + 4 = 14.","d":"h"},{"t":"There are 7 red cubes and 9 blue cubes. Then 8 green cubes are added. How many cubes in all? Use make a 10 to start.","o":["22","25","26","24"],"a":3,"e":"First: 7 + 9 = 16 (make a 10: 9 + 1 = 10, + 6 = 16). Then 16 + 8 = 24.","d":"h"},{"t":"What is the same about 9 + 4 and 8 + 5?","o":["They both use doubles","They both equal 13","They both equal 14","They both start with make 10 + 3"],"a":1,"e":"Check: 9 + 4 = 13 and 8 + 5 = 13. They both equal 13 even though the numbers are different!","d":"h"},{"t":"__ + __ = 16. One number is 2 more than the other. What are they?","o":["6 and 10","7 and 9","8 and 8","5 and 11"],"a":1,"e":"Open reasoning: 7 + 9 = 16, and 9 - 7 = 2. They are 2 apart!","d":"h"},{"t":"A student solved 7 + 8 and got 16. Explain what went wrong.","o":["They added 1 too many — the answer is 15","They subtracted instead","They used the wrong numbers","They forgot to make a 10"],"a":0,"e":"Error analysis: 7 + 8 = 15, not 16. The student added 1 too many when making a 10.","d":"h"},{"t":"Nora had 6 pencils. She got 9 more. Then she gave away 4. How many does she have now?","o":["10","12","13","11"],"a":3,"e":"Two steps: 6 + 9 = 15 (make a 10: 9 + 1 = 10, + 5 = 15). Then 15 - 4 = 11.","d":"h"},{"t":"If 9 + 6 = 15, what is 9 + 7?","o":["15","17","14","16"],"a":3,"e":"Think: related fact. 9 + 7 is 1 more than 9 + 6. So 15 + 1 = 16.","d":"h"},{"t":"Which is greater: 8 + 7 or 9 + 5? How do you know?","o":["8 + 7, because 15 > 14","9 + 5, because 9 is bigger","They are equal, both are 14","They are equal, both are 15"],"a":0,"e":"Make a 10: 8 + 7 = 15 and 9 + 5 = 14. 15 > 14, so 8 + 7 is greater.","d":"h"},{"t":"Fill in both blanks: 8 + __ = 10 + __. The answer is 13.","o":["5 and 3","4 and 3","6 and 3","5 and 4"],"a":0,"e":"Make a 10: 8 + 5 = 13. Also 10 + 3 = 13. So blanks are 5 and 3.","d":"h"},{"t":"Jada says every make-a-10 problem must start with 9 or 8. Is she right?","o":["Yes, only 9 and 8 work","No, you can start with 7 too, like 7 + 5","No, you can start with any number","Yes, other numbers are too small"],"a":2,"e":"Make a 10 works with any number! For example: 6 + 7: 6 + 4 = 10, + 3 = 13. Or 5 + 8: 5 + 5 = 10, + 3 = 13.","d":"h"}],"quiz":[{"t":"Use the make-ten strategy. What is 9 + 4?","o":["11","12","13","14"],"a":2,"e":"9 needs 1 to reach 10. Then 10+3=13."},{"t":"Use the make-ten strategy. What is 8 + 3?","o":["9","11","10","12"],"a":1,"e":"8 needs 2 to reach 10. Then 10+1=11."},{"t":"Use the make-ten strategy. What is 7 + 6?","o":["11","12","13","14"],"a":2,"e":"7 needs 3 to reach 10. Then 10+3=13."},{"t":"Use the make-ten strategy. What is 8 + 5?","o":["11","12","13","14"],"a":2,"e":"8 needs 2 to reach 10. Then 10+3=13."},{"t":"Use the make-ten strategy. What is 6 + 8?","o":["12","13","14","15"],"a":2,"e":"6 needs 4 to reach 10. Then 10+4=14."},{"t":"Use the make-ten strategy. What is 9 + 3?","o":["12","10","11","13"],"a":0,"e":"9 needs 1 to reach 10. Then 10+2=12."}]},{"points":["A fact family uses the SAME 3 numbers to make 4 facts","2 addition facts + 2 subtraction facts = 1 fact family","If you know 3+7=10, you also know 10-7=3!"],"examples":[{"c":"#e74c3c","tag":"Fact Family: 3, 7, 10","p":"4 related facts:","s":"[ 3 + 7 = 10 ]\n[ 7 + 3 = 10 ]\n[ 10 − 3 = 7 ]\n[ 10 − 7 = 3 ]","a":"All 4 use the same 3 numbers! ✅"},{"c":"#e74c3c","tag":"Fact Family: 5, 8, 13","p":"4 related facts:","s":"[ 5 + 8 = 13 ]\n[ 8 + 5 = 13 ]\n[ 13 − 5 = 8 ]\n[ 13 − 8 = 5 ]","a":"The 3 numbers are 5, 8, and 13 ✅"},{"c":"#e74c3c","tag":"Missing Number","p":"8 + __ = 15","s":"Think: what is 15 − 8?\n[ 8 + 7 = 15 ]\n[ 15 − 8 = 7 ]","a":"8 + 7 = 15  (and 15 − 8 = 7) ✅"}],"practice":[{"q":"4 + 9 = 13. So 13 - 9 = ?","a":"4","h":"Fact families! Use the same 3 numbers: 4, 9, 13","e":"🏠"},{"q":"6 + 7 = 13. So 13 - 6 = ?","a":"7","h":"Fact families! 6, 7, and 13 belong together","e":"🏠"},{"q":"8 + __ = 12","a":"4","h":"Think: 12 - 8 = ? Count back from 12!","e":"🔢"}],"qBank":[{"t":"Which number sentence belongs in the fact family for 3, 7, and 10?","o":["3+8=10","7+3=10","10+3=7","7-3=10"],"a":1,"e":"7+3=10 uses numbers 3,7,10.","d":"m"},{"t":"If 5 + 8 = 13, what is 13 − 8?","o":["4","5","6","7"],"a":1,"e":"Fact family! 13-8=5.","d":"m"},{"t":"What is the missing number? 6 + ___ = 14","o":["7","8","9","10"],"a":1,"e":"14-6=8, so 6+8=14.","d":"h"},{"t":"If 4 + 9 = 13, what is 13 − 4?","o":["8","9","10","11"],"a":1,"e":"Fact family! 13-4=9.","d":"m"},{"t":"The numbers 2, 8, and 10 form a fact family. How many facts are in every fact family?","o":["2","3","4","5"],"a":2,"e":"Every family has 4 facts: 2+8=10, 8+2=10, 10-2=8, 10-8=2.","d":"m"},{"t":"If 7 + 6 = 13, what is 13 − 7?","o":["4","5","6","7"],"a":2,"e":"Fact family! 13-7=6.","d":"m"},{"t":"What is the missing number? 9 + ___ = 17","o":["6","7","8","9"],"a":2,"e":"17-9=8, so 9+8=17.","d":"h"},{"t":"Which fact is in family 5,9,14?","o":["5+8=13","9+5=14","5+5=10","14-4=10"],"a":1,"e":"9+5=14 uses numbers 5,9,14.","d":"e"},{"t":"If 8 + 7 = 15, what is 15 − 8?","o":["6","7","8","9"],"a":1,"e":"Fact family! 15-8=7.","d":"m"},{"t":"What is the missing number? ___ + 6 = 11","o":["4","5","6","7"],"a":1,"e":"11-6=5, so 5+6=11.","d":"e"},{"t":"What are the three numbers in the fact family for 8 + 5 = 13?","o":["8,5,13","8,5,12","7,5,13","8,4,13"],"a":0,"e":"8, 5, and 13 are the three numbers in this fact family.","d":"m"},{"t":"If 9 + 6 = 15, what is 15 − 6?","o":["7","8","9","10"],"a":2,"e":"Fact family! 15-6=9.","d":"m"},{"t":"What is the missing number? 7 + ___ = 16","o":["7","8","9","10"],"a":2,"e":"16-7=9, so 7+9=16.","d":"h"},{"t":"Which shows a fact family?","o":["3+4=7 and 7-3=4","3+4=7 and 5+2=7","3+4=7 and 4-3=1","3+3=6 and 3+4=7"],"a":0,"e":"3+4=7 and 7-3=4 use the same 3 numbers: 3, 4, and 7.","d":"e"},{"t":"If 6 + 8 = 14, what is 14 − 6?","o":["6","7","8","9"],"a":2,"e":"Fact family! 14-6=8.","d":"m"},{"t":"What is the missing number? ___ + 9 = 18","o":["7","8","9","10"],"a":2,"e":"18-9=9, so 9+9=18.","d":"e"},{"t":"The fact family for 4 + 7 = 11 has how many subtraction facts?","o":["1","2","3","4"],"a":1,"e":"Every fact family has exactly 2 subtraction facts.","d":"h"},{"t":"If 5 + 7 = 12, what is 12 − 5?","o":["5","6","7","8"],"a":2,"e":"Fact family! 12-5=7.","d":"m"},{"t":"What is the missing number? 8 + ___ = 13","o":["3","4","5","6"],"a":2,"e":"13-8=5, so 8+5=13.","d":"h"},{"t":"Which number sentence does NOT belong in the fact family for 6, 7, and 13?","o":["6+7=13","7+6=13","13-6=7","13-7=5"],"a":3,"e":"13-7=6, not 5. All others use 6,7,13 correctly.","d":"m"},{"t":"If 3 + 9 = 12, what is 12 − 3?","o":["7","8","9","10"],"a":2,"e":"Fact family! 12-3=9.","d":"m"},{"t":"What is the missing number? ___ + 8 = 15","o":["5","6","7","8"],"a":2,"e":"15-8=7, so 7+8=15.","d":"e"},{"t":"Which addition fact belongs to the fact family with 5, 6, and 11?","o":["5+7=12","6+5=11","5+5=10","6+6=12"],"a":1,"e":"6+5=11 uses numbers 5,6,11.","d":"m"},{"t":"If 7 + 8 = 15, what is 15 − 7?","o":["6","7","8","9"],"a":2,"e":"Fact family! 15-7=8.","d":"m"},{"t":"What is the missing number? 6 + ___ = 15","o":["7","8","9","10"],"a":2,"e":"15-6=9, so 6+9=15.","d":"h"},{"t":"How many number sentences are in every fact family?","o":["2","3","4","5"],"a":2,"e":"2 addition + 2 subtraction = 4 total facts.","d":"e"},{"t":"If 9 + 8 = 17, what is 17 − 9?","o":["7","8","9","10"],"a":1,"e":"Fact family! 17-9=8.","d":"m"},{"t":"What is the missing number? ___ + 7 = 12","o":["3","4","5","6"],"a":2,"e":"12-7=5, so 5+7=12.","d":"e"},{"t":"What are the three numbers in the fact family for 9 + 7 = 16?","o":["9,7,16","9,7,15","8,7,16","9,6,16"],"a":0,"e":"9, 7, and 16 are the three numbers.","d":"m"},{"t":"If 4 + 6 = 10, what is 10 − 4?","o":["4","5","6","7"],"a":2,"e":"Fact family! 10-4=6.","d":"m"},{"t":"If 3 + 5 = 8, what is 5 + 3?","o":["7","9","8","6"],"a":2,"e":"Fact family: 3 + 5 and 5 + 3 both equal 8. You can add in any order!","d":"e"},{"t":"If 2 + 6 = 8, what is 6 + 2?","o":["9","4","8","7"],"a":2,"e":"Fact family: 2 + 6 = 8 and 6 + 2 = 8. Same numbers, same answer.","d":"e"},{"t":"If 4 + 3 = 7, what is 7 - 3?","o":["3","5","4","6"],"a":2,"e":"Fact family: If 4 + 3 = 7, then 7 - 3 = 4. Addition and subtraction are related.","d":"e"},{"t":"If 5 + 4 = 9, what is 9 - 4?","o":["4","6","3","5"],"a":3,"e":"Fact family: If 5 + 4 = 9, then 9 - 4 = 5.","d":"e"},{"t":"If 1 + 7 = 8, what is 8 - 7?","o":["2","0","7","1"],"a":3,"e":"Fact family: If 1 + 7 = 8, then 8 - 7 = 1.","d":"e"},{"t":"If 6 + 3 = 9, what is 3 + 6?","o":["8","10","12","9"],"a":3,"e":"You can add in any order. 6 + 3 = 9 and 3 + 6 = 9.","d":"e"},{"t":"If 2 + 5 = 7, what is 7 - 2?","o":["4","3","5","6"],"a":2,"e":"Fact family: If 2 + 5 = 7, then 7 - 2 = 5.","d":"e"},{"t":"If 8 + 2 = 10, what is 10 - 2?","o":["7","9","6","8"],"a":3,"e":"Fact family: If 8 + 2 = 10, then 10 - 2 = 8.","d":"m"},{"t":"If 3 + 4 = 7, what is 7 - 4?","o":["4","2","3","5"],"a":2,"e":"Fact family: If 3 + 4 = 7, then 7 - 4 = 3.","d":"e"},{"t":"If 6 + 4 = 10, what is 4 + 6?","o":["9","11","10","8"],"a":2,"e":"Add in any order: 6 + 4 = 10 and 4 + 6 = 10.","d":"e"},{"t":"If 9 + 1 = 10, what is 10 - 9?","o":["2","0","9","1"],"a":3,"e":"Fact family: If 9 + 1 = 10, then 10 - 9 = 1.","d":"m"},{"t":"If 5 + 2 = 7, what is 7 - 5?","o":["3","1","4","2"],"a":3,"e":"Fact family: If 5 + 2 = 7, then 7 - 5 = 2.","d":"e"},{"t":"If 7 + 3 = 10, what is 10 - 7?","o":["4","2","7","3"],"a":3,"e":"Fact family: If 7 + 3 = 10, then 10 - 7 = 3.","d":"m"},{"t":"If 1 + 8 = 9, what is 8 + 1?","o":["10","7","8","9"],"a":3,"e":"Add in any order: 1 + 8 = 9 and 8 + 1 = 9.","d":"e"},{"t":"If 4 + 5 = 9, what is 9 - 5?","o":["3","5","6","4"],"a":3,"e":"Fact family: If 4 + 5 = 9, then 9 - 5 = 4.","d":"e"},{"t":"If 3 + 7 = 10, what is 10 - 3?","o":["8","6","3","7"],"a":3,"e":"Fact family: If 3 + 7 = 10, then 10 - 3 = 7.","d":"m"},{"t":"If 2 + 4 = 6, what is 6 - 4?","o":["3","1","4","2"],"a":3,"e":"Fact family: If 2 + 4 = 6, then 6 - 4 = 2.","d":"e"},{"t":"If 6 + 2 = 8, what is 8 - 6?","o":["3","6","4","2"],"a":3,"e":"Fact family: If 6 + 2 = 8, then 8 - 6 = 2.","d":"e"},{"t":"If 5 + 5 = 10, what is 10 - 5?","o":["6","4","3","5"],"a":3,"e":"Fact family: 5 + 5 = 10, so 10 - 5 = 5. Doubles make special fact families!","d":"m"},{"t":"If 1 + 6 = 7, what is 7 - 1?","o":["5","7","8","6"],"a":3,"e":"Fact family: If 1 + 6 = 7, then 7 - 1 = 6.","d":"e"},{"t":"3 + __ = 10. What is the missing number? Use a related fact to help.","o":["8","6","5","7"],"a":3,"e":"Think: related fact. 10 - 3 = 7. So 3 + 7 = 10. The missing number is 7.","d":"h"},{"t":"Which number sentence belongs to the same fact family as 6 + 8 = 14?","o":["6 + 6 = 12","14 - 8 = 6","8 + 8 = 16","14 + 6 = 20"],"a":1,"e":"Fact family: 6 + 8 = 14, 8 + 6 = 14, 14 - 6 = 8, and 14 - 8 = 6. They all use 6, 8, and 14.","d":"m"},{"t":"If 9 + 5 = 14, which subtraction fact do you also know?","o":["14 - 9 = 5","14 - 5 = 8","9 - 5 = 14","14 + 5 = 19"],"a":0,"e":"Fact family: If 9 + 5 = 14, then 14 - 9 = 5 and 14 - 5 = 9.","d":"e"},{"t":"__ - 4 = 7. What is the missing number?","o":["3","12","10","11"],"a":3,"e":"Think: related fact. 7 + 4 = 11. So 11 - 4 = 7. The missing number is 11.","d":"h"},{"t":"How many facts are in the fact family for 3, 5, and 8?","o":["2","3","4","5"],"a":2,"e":"There are 4 facts: 3 + 5 = 8, 5 + 3 = 8, 8 - 3 = 5, 8 - 5 = 3.","d":"e"},{"t":"Ella has some books. She gives 6 away and has 9 left. How many did she start with?","o":["3","16","14","15"],"a":3,"e":"Think: related fact. 9 + 6 = 15. Ella started with 15 books.","d":"h"},{"t":"Which strategy helps solve 13 - 7?","o":["Count by 10s","Think: 7 + __ = 13","Use doubles of 13","Skip count by 7s"],"a":1,"e":"Use a related addition fact. Think: 7 + ? = 13. 7 + 6 = 13, so 13 - 7 = 6.","d":"e"},{"t":"If 7 + 6 = 13, what is 13 - 6?","o":["8","6","9","7"],"a":3,"e":"Fact family: If 7 + 6 = 13, then 13 - 6 = 7.","d":"m"},{"t":"8 + __ = 15. What is the missing number?","o":["6","8","9","7"],"a":3,"e":"Think: related fact. 15 - 8 = 7. So 8 + 7 = 15. The missing number is 7.","d":"h"},{"t":"Which number sentence does NOT belong in the fact family for 5, 9, and 14?","o":["5 + 9 = 14","14 - 5 = 9","9 + 5 = 14","9 - 5 = 4"],"a":3,"e":"9 - 5 = 4 uses different numbers (4, not 14). It does not belong in the 5, 9, 14 family.","d":"m"},{"t":"A boy had 12 crayons. He lost some and has 5 left. How many did he lose?","o":["6","8","9","7"],"a":3,"e":"Think: related fact. 5 + ? = 12. 5 + 7 = 12. He lost 7 crayons.","d":"h"},{"t":"If 8 + 4 = 12, which is also true?","o":["12 - 4 = 8","12 + 4 = 8","8 - 4 = 12","4 - 8 = 12"],"a":0,"e":"Fact family: 8 + 4 = 12, so 12 - 4 = 8 and 12 - 8 = 4.","d":"e"},{"t":"14 - __ = 6. What is the missing number?","o":["7","9","6","8"],"a":3,"e":"Think: related fact. 6 + ? = 14. 6 + 8 = 14. So 14 - 8 = 6.","d":"h"},{"t":"How many facts are in the fact family for 6, 6, and 12?","o":["4","1","3","2"],"a":3,"e":"Doubles are special! 6 + 6 = 12 (only one addition) and 12 - 6 = 6 (only one subtraction). Just 2 facts!","d":"m"},{"t":"__ + 9 = 16. What is the missing number?","o":["6","8","5","7"],"a":3,"e":"Think: related fact. 16 - 9 = 7. So 7 + 9 = 16.","d":"h"},{"t":"Which fact helps you solve 11 - 4?","o":["11 + 4 = 15","4 + 7 = 11","4 + 4 = 8","11 - 11 = 0"],"a":1,"e":"Think: 4 + ? = 11. 4 + 7 = 11. So 11 - 4 = 7.","d":"e"},{"t":"There are 15 kids. 8 are boys. How many are girls?","o":["6","8","9","7"],"a":3,"e":"Think: related fact. 8 + ? = 15. 8 + 7 = 15. There are 7 girls.","d":"e"},{"t":"5 + __ = 13. What is the missing number?","o":["7","9","6","8"],"a":3,"e":"Think: related fact. 13 - 5 = 8. So 5 + 8 = 13.","d":"h"},{"t":"If 6 + 7 = 13, which subtraction fact is in the same family?","o":["13 - 6 = 7","13 - 7 = 5","7 - 6 = 13","6 - 7 = 1"],"a":0,"e":"Fact family: 6 + 7 = 13, 7 + 6 = 13, 13 - 6 = 7, 13 - 7 = 6.","d":"m"},{"t":"Liam has 9 toy cars. His sister gives him more. Now he has 17. How many did she give?","o":["7","9","6","8"],"a":3,"e":"Think: related fact. 9 + ? = 17. 9 + 8 = 17. She gave him 8 cars.","d":"h"},{"t":"Ana picked 7 flowers. Together with Ben they have 15 flowers. How many did Ben pick? Then 4 flowers wilted. How many are left?","o":["8 and 11","7 and 11","8 and 12","9 and 11"],"a":0,"e":"Two steps: 7 + ? = 15, so Ben picked 8. Then 15 - 4 = 11 flowers left.","d":"h"},{"t":"A student wrote the fact family for 5, 8, and 13 as: 5 + 8 = 13, 8 + 5 = 13, 13 - 5 = 7. What mistake did they make?","o":["13 - 5 = 8, not 7","They need more facts","5 + 8 is wrong","The family should use 12"],"a":0,"e":"Error analysis: 13 - 5 = 8, not 7. The student subtracted wrong. The correct fact is 13 - 5 = 8.","d":"h"},{"t":"If 6 + 9 = 15, which number sentence is NOT in the same fact family?","o":["9 + 6 = 15","15 - 9 = 6","15 - 6 = 9","9 - 6 = 3"],"a":3,"e":"9 - 6 = 3 uses different numbers. The fact family for 6, 9, 15 does not include 3.","d":"m"},{"t":"__ + __ = 14. Use the fact family to write a subtraction fact. Which pair works?","o":["5 + 9 = 14, so 14 - 9 = 5","5 + 8 = 14, so 14 - 8 = 6","6 + 9 = 14, so 14 - 9 = 6","4 + 9 = 14, so 14 - 9 = 5"],"a":0,"e":"5 + 9 = 14 is correct. The related subtraction fact is 14 - 9 = 5.","d":"h"},{"t":"Mia says: if I know 8 + 7 = 15, I also know 15 - 7 without counting. What is 15 - 7?","o":["9","7","6","8"],"a":3,"e":"Fact family: 8 + 7 = 15, so 15 - 7 = 8. Use the related fact — no counting needed!","d":"h"},{"t":"A student wrote: 12 - 5 = 6. Use a fact family to check. Is this correct?","o":["Yes, 5 + 6 = 12","No, 5 + 6 = 11, not 12. The answer should be 7","No, the answer should be 8","Yes, 6 + 6 = 12"],"a":1,"e":"Error analysis: check with addition. 5 + 6 = 11, not 12. So 12 - 5 is not 6. Correct: 5 + 7 = 12, so 12 - 5 = 7.","d":"m"},{"t":"Tom has 16 stickers. He gives some to 2 friends. He gives 7 to one and keeps 4 for himself. How many did the second friend get?","o":["4","6","3","5"],"a":3,"e":"Two steps: Tom gave away 16 - 4 = 12 total. First friend got 7. Second friend: 12 - 7 = 5.","d":"h"},{"t":"Which fact family has only 2 facts instead of 4?","o":["3, 5, 8","4, 4, 8","6, 7, 13","5, 9, 14"],"a":1,"e":"When both addends are the same (doubles), there are only 2 unique facts: 4 + 4 = 8 and 8 - 4 = 4.","d":"e"},{"t":"I know 7 + 8 = 15. Without adding, what is 8 + 7?","o":["16","14","13","15"],"a":3,"e":"Addition works in any order. 7 + 8 = 15, so 8 + 7 = 15 too. This is the order property.","d":"h"},{"t":"Leo says the fact family for 4, 9, and 13 has 5 facts. Is he right?","o":["Yes, there are 5 facts","No, there are only 4 facts","No, there are only 3 facts","No, there are only 2 facts"],"a":1,"e":"A fact family with two different addends always has exactly 4 facts: 2 addition and 2 subtraction.","d":"h"},{"t":"If 6 + __ = 14, then 14 - 6 = __. Fill in both blanks.","o":["7 and 7","9 and 9","8 and 8","7 and 8"],"a":2,"e":"Think: 6 + 8 = 14, and 14 - 6 = 8. Both blanks are 8. That is the fact family connection!","d":"h"},{"t":"A student says 11 - 5 = 7 because 5 + 7 = 12. What TWO mistakes did they make?","o":["Wrong addition fact AND wrong subtraction","Only the subtraction is wrong","Only the addition is wrong","No mistakes were made"],"a":0,"e":"Error analysis: 5 + 7 = 12 (not 11), AND 11 - 5 = 6 (not 7). Two errors: wrong addition fact and wrong answer.","d":"h"},{"t":"Sara had some beads. She lost 8 and has 6 left. She finds 3 more. How many does she have now?","o":["11","8","10","9"],"a":3,"e":"Step 1: ? - 8 = 6, so she had 14. Step 2: she has 6 now, finds 3 more: 6 + 3 = 9.","d":"h"},{"t":"Which number can replace the box? 5 + box = 12, and 12 - box = 5.","o":["6","8","9","7"],"a":3,"e":"The box is the same in both! 5 + 7 = 12, and 12 - 7 = 5. The box is 7. Fact families show this.","d":"h"},{"t":"Kai wrote four facts: 3 + 9 = 12, 9 + 3 = 12, 12 - 3 = 9, 12 - 9 = 4. Which fact has an error?","o":["3 + 9 = 12","9 + 3 = 12","12 - 3 = 9","12 - 9 = 4"],"a":3,"e":"Error analysis: 12 - 9 = 3, not 4. The last fact should be 12 - 9 = 3.","d":"h"},{"t":"If you know 9 + 7 = 16, name two subtraction facts you also know.","o":["16 - 9 = 7 and 16 - 7 = 9","16 - 9 = 8 and 16 - 7 = 8","9 - 7 = 2 and 16 - 9 = 6","16 - 7 = 8 and 16 - 9 = 7"],"a":0,"e":"Fact family: 9 + 7 = 16 gives us 16 - 9 = 7 and 16 - 7 = 9.","d":"h"},{"t":"__ - 6 = 9. Then use that answer to find __ + 3. What are both answers?","o":["15 and 18","14 and 17","16 and 19","13 and 16"],"a":0,"e":"Step 1: related fact. 9 + 6 = 15. Step 2: 15 + 3 = 18. Answers: 15 and 18.","d":"h"},{"t":"Can 3, 5, and 9 be a fact family? Why or why not?","o":["Yes, 3 + 5 = 9","No, because 3 + 5 = 8, not 9","Yes, 9 - 3 = 5","No, because 9 - 5 = 3"],"a":1,"e":"Check: 3 + 5 = 8, not 9. The three numbers in a fact family must work in addition. 3, 5, and 9 do not.","d":"m"},{"t":"A jar has red and blue cubes. There are 16 cubes total. If you remove all 9 red cubes, 7 blue are left. Write the fact family.","o":["9+7=16, 7+9=16, 16-9=7, 16-7=9","9+7=16, 16-7=8, 16-9=6","9+7=15, 7+9=15, 15-9=7","Only 9+7=16"],"a":0,"e":"The numbers are 9, 7, and 16. Fact family: 9+7=16, 7+9=16, 16-9=7, 16-7=9.","d":"h"},{"t":"Maya says knowing one addition fact gives you three more facts for free. Is she right?","o":["Yes, you get 1 more addition and 2 subtraction facts","No, you only get 1 subtraction fact","No, you have to memorize each one","Yes, but only for doubles"],"a":0,"e":"Correct! From 6 + 8 = 14, you also know 8 + 6 = 14, 14 - 6 = 8, and 14 - 8 = 6. Three more facts for free!","d":"e"}],"quiz":[{"t":"Which fact belongs in the family 4, 6, 10?","o":["4+7=11","6+4=10","5+5=10","6+5=11"],"a":1,"e":"The family 4, 6, 10 gives us: 4+6=10, 6+4=10, 10-4=6, 10-6=4."},{"t":"If 5 + 8 = 13, what is 13 - 8?","o":["4","5","6","7"],"a":1,"e":"Fact families! 5+8=13 and 13-8=5 use the same numbers."},{"t":"How many facts are in every fact family?","o":["2","3","4","5"],"a":2,"e":"Every fact family has exactly 4 facts: 2 addition + 2 subtraction."},{"t":"What is the missing number? 8 + ___ = 15","o":["5","6","7","8"],"a":2,"e":"15 - 8 = 7. So 8 + 7 = 15."},{"t":"If 6 + 9 = 15, which is also true?","o":["6+9=14","15-9=6","15+6=9","9-6=15"],"a":1,"e":"15-9=6 is in the same fact family as 6+9=15."},{"t":"The 3 numbers in the fact family for 7+4=11 are?","o":["7, 4, 11","7, 4, 12","6, 4, 11","7, 5, 11"],"a":0,"e":"7, 4, and 11 are the three numbers used in this fact family."}]}],"unitQuiz":[{"t":"Use the count-on strategy. What is 9 + 3?","o":["12","10","11","13"],"a":0,"e":"Start at 9, count on 3: 10,11,12.","d":"e"},{"t":"Use the count-back strategy. What is 12 − 5?","o":["5","6","7","8"],"a":2,"e":"Start at 12, count back 5: 11,10,9,8,7.","d":"e"},{"t":"What is 6 + 6? (Doubles fact)","o":["10","11","13","12"],"a":3,"e":"6+6=12. Doubles fact!","d":"e"},{"t":"What is 5 + 6? Use the near-doubles strategy.","o":["11","9","10","12"],"a":0,"e":"5+5=10, +1=11.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 4?","o":["11","13","12","14"],"a":1,"e":"9+1=10, +3=13.","d":"m"},{"t":"Which number sentence belongs in the fact family for 3, 7, and 10?","o":["3+8=10","7+3=10","10+3=7","7-3=10"],"a":1,"e":"7+3=10 uses the numbers 3,7,10.","d":"h"},{"t":"What is 8 + 8? (Doubles fact)","o":["14","15","16","17"],"a":2,"e":"8+8=16.","d":"e"},{"t":"Use the count-on strategy. What is 14 + 3?","o":["17","15","16","18"],"a":0,"e":"14,15,16,17.","d":"m"},{"t":"What is 7 + 8? Use the near-doubles strategy.","o":["13","15","14","16"],"a":1,"e":"7+7=14, +1=15.","d":"m"},{"t":"Use the make-ten strategy. What is 8 + 6?","o":["12","13","14","15"],"a":2,"e":"8+2=10, +4=14.","d":"m"},{"t":"If 5 + 8 = 13, what is 13 − 8?","o":["4","5","6","7"],"a":1,"e":"Fact family: 13-8=5.","d":"h"},{"t":"Use the count-back strategy. What is 16 − 4?","o":["12","10","11","13"],"a":0,"e":"16,15,14,13,12.","d":"m"},{"t":"What is 4 + 4? (Doubles fact)","o":["6","7","9","8"],"a":3,"e":"4+4=8.","d":"e"},{"t":"What is 4 + 5? Use the near-doubles strategy.","o":["7","8","9","10"],"a":2,"e":"4+4=8, +1=9.","d":"e"},{"t":"Use the make-ten strategy. What is 7 + 6?","o":["11","12","14","13"],"a":3,"e":"7+3=10, +3=13.","d":"m"},{"t":"Use the count-on strategy. What is 6 + 5?","o":["9","11","10","12"],"a":1,"e":"6,7,8,9,10,11.","d":"m"},{"t":"What is 9 + 9? (Doubles fact)","o":["18","16","17","19"],"a":0,"e":"9+9=18.","d":"e"},{"t":"What is 8 + 9? Use the near-doubles strategy.","o":["15","16","17","18"],"a":2,"e":"8+8=16, +1=17.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 7?","o":["11","13","12","14"],"a":1,"e":"6+4=10, +3=13.","d":"m"},{"t":"What is 17 − 8?","o":["9","7","8","10"],"a":0,"e":"17-8=9. Check: 8+9=17.","d":"e"},{"t":"What is the missing number? 8 + ___ = 15","o":["5","6","7","8"],"a":2,"e":"15-8=7, so 8+7=15.","d":"h"},{"t":"What is 3 + 3? (Doubles fact)","o":["4","6","5","7"],"a":1,"e":"3+3=6.","d":"e"},{"t":"Use the count-back strategy. What is 15 − 7?","o":["6","7","9","8"],"a":3,"e":"15,14,13,12,11,10,9,8. Answer: 8.","d":"h"},{"t":"What is 9 + 10? Use the near-doubles strategy.","o":["17","18","19","20"],"a":2,"e":"9+9=18, +1=19.","d":"h"},{"t":"Use the make-ten strategy. What is 5 + 7?","o":["10","11","13","12"],"a":3,"e":"5+5=10, then +2 more = 12.","d":"h"},{"t":"Use the count-on strategy. What is 8 + 4?","o":["10","11","12","13"],"a":2,"e":"8,9,10,11,12.","d":"h"},{"t":"If 7 + 5 = 12, what is 12 − 7?","o":["5","3","4","6"],"a":0,"e":"Fact family: 12-7=5.","d":"h"},{"t":"What is 7 + 7? (Doubles fact)","o":["12","13","15","14"],"a":3,"e":"7+7=14.","d":"e"},{"t":"Use the count-back strategy. What is 11 − 3?","o":["6","7","8","9"],"a":2,"e":"11,10,9,8.","d":"h"},{"t":"What is 6 + 7? Use the near-doubles strategy.","o":["11","12","14","13"],"a":3,"e":"6+6=12, +1=13.","d":"h"}],"testBank":[{"t":"Use the count-on strategy. What is 6 + 3?","o":["7","8","9","10"],"a":2,"e":"Start at 6, count on 3: 7,8,9.","d":"e"},{"t":"Use the count-on strategy. What is 8 + 4?","o":["12","10","11","13"],"a":0,"e":"Start at 8, count on 4: 9,10,11,12.","d":"e"},{"t":"Use the count-on strategy. What is 7 + 5?","o":["12","10","11","13"],"a":0,"e":"Start at 7, count on 5: 8,9,10,11,12.","d":"e"},{"t":"Use the count-on strategy. What is 9 + 3?","o":["12","10","11","13"],"a":0,"e":"Start at 9, count on 3: 10,11,12.","d":"e"},{"t":"Use the count-on strategy. What is 5 + 4?","o":["9","7","8","10"],"a":0,"e":"Start at 5, count on 4: 6,7,8,9.","d":"e"},{"t":"Use the count-on strategy. What is 11 + 3?","o":["12","13","15","14"],"a":3,"e":"Start at 11, count on 3: 12,13,14.","d":"e"},{"t":"Use the count-on strategy. What is 14 + 2?","o":["14","16","15","17"],"a":1,"e":"Start at 14, count on 2: 15,16.","d":"e"},{"t":"Use the count-on strategy. What is 7 + 4?","o":["9","10","11","12"],"a":2,"e":"Start at 7, count on 4: 8,9,10,11.","d":"e"},{"t":"Use the count-back strategy. What is 10 − 3?","o":["5","6","8","7"],"a":3,"e":"Start at 10, count back 3: 9,8,7.","d":"e"},{"t":"Use the count-back strategy. What is 13 − 4?","o":["7","8","10","9"],"a":3,"e":"Start at 13, count back 4: 12,11,10,9.","d":"e"},{"t":"Use the count-back strategy. What is 15 − 5?","o":["10","8","9","11"],"a":0,"e":"Start at 15, count back 5: 14,13,12,11,10.","d":"e"},{"t":"Use the count-back strategy. What is 12 − 3?","o":["7","9","8","10"],"a":1,"e":"Start at 12, count back 3: 11,10,9.","d":"e"},{"t":"Use the count-back strategy. What is 17 − 6?","o":["9","10","12","11"],"a":3,"e":"Start at 17, count back 6: 16,15,14,13,12,11.","d":"e"},{"t":"Use the count-back strategy. What is 14 − 5?","o":["7","8","9","10"],"a":2,"e":"Start at 14, count back 5: 13,12,11,10,9.","d":"e"},{"t":"Use the count-back strategy. What is 11 − 4?","o":["7","5","6","8"],"a":0,"e":"Start at 11, count back 4: 10,9,8,7.","d":"e"},{"t":"Use the count-back strategy. What is 16 − 7?","o":["7","8","9","10"],"a":2,"e":"Start at 16, count back 7: 15,14,13,12,11,10,9.","d":"e"},{"t":"Which strategy works best to solve 8 + 3?","o":["Count back from 11","Count on from 8","Start at 3","Subtract"],"a":1,"e":"To add, start at the bigger number and count on.","d":"e"},{"t":"Which strategy works best to solve 14 − 4?","o":["Count on from 14","Count back from 14","Add 4 to 14","Double 7"],"a":1,"e":"To subtract, start at the bigger number and count back.","d":"e"},{"t":"Use the count-on strategy. What is 12 + 4?","o":["14","15","16","17"],"a":2,"e":"Start at 12, count on 4: 13,14,15,16.","d":"e"},{"t":"Use the count-back strategy. What is 18 − 5?","o":["13","11","12","14"],"a":0,"e":"Start at 18, count back 5: 17,16,15,14,13.","d":"e"},{"t":"Use the count-on strategy. What is 6 + 6?","o":["10","11","13","12"],"a":3,"e":"Start at 6, count on 6: 7,8,9,10,11,12.","d":"e"},{"t":"Use the count-back strategy. What is 20 − 4?","o":["14","15","16","17"],"a":2,"e":"Start at 20, count back 4: 19,18,17,16.","d":"h"},{"t":"Use the count-on strategy. What is 9 + 5?","o":["14","12","13","15"],"a":0,"e":"Start at 9, count on 5: 10,11,12,13,14.","d":"m"},{"t":"What does count ON mean?","o":["Subtract","Count forward to add","Count backward","Guess"],"a":1,"e":"Count ON means count forward starting from the bigger number to add.","d":"e"},{"t":"Use the count-on strategy. What is 13 + 3?","o":["14","15","17","16"],"a":3,"e":"Start at 13, count on 3: 14,15,16.","d":"m"},{"t":"Use the count-back strategy. What is 19 − 6?","o":["11","13","12","14"],"a":1,"e":"Start at 19, count back 6: 18,17,16,15,14,13.","d":"m"},{"t":"Use the count-on strategy. What is 10 + 5?","o":["13","14","15","16"],"a":2,"e":"Start at 10, count on 5: 11,12,13,14,15.","d":"m"},{"t":"Use the count-back strategy. What is 16 − 4?","o":["10","11","13","12"],"a":3,"e":"Start at 16, count back 4: 15,14,13,12.","d":"m"},{"t":"Use the count-on strategy. What is 15 + 3?","o":["16","17","18","19"],"a":2,"e":"Start at 15, count on 3: 16,17,18.","d":"m"},{"t":"Use the count-back strategy. What is 13 − 6?","o":["5","6","7","8"],"a":2,"e":"Start at 13, count back 6: 12,11,10,9,8,7.","d":"m"},{"t":"What is 3 + 3? (This is a doubles fact!)","o":["4","5","6","7"],"a":2,"e":"3 doubled = 6.","d":"e"},{"t":"What is 4 + 4? (This is a doubles fact!)","o":["6","7","8","9"],"a":2,"e":"4 doubled = 8.","d":"e"},{"t":"What is 5 + 5? (This is a doubles fact!)","o":["8","9","10","11"],"a":2,"e":"5 doubled = 10.","d":"e"},{"t":"What is 6 + 6? (This is a doubles fact!)","o":["10","11","12","13"],"a":2,"e":"6 doubled = 12.","d":"m"},{"t":"What is 7 + 7? (This is a doubles fact!)","o":["12","13","14","15"],"a":2,"e":"7 doubled = 14.","d":"m"},{"t":"What is 8 + 8? (This is a doubles fact!)","o":["14","15","16","17"],"a":2,"e":"8 doubled = 16.","d":"m"},{"t":"What is 9 + 9? (This is a doubles fact!)","o":["16","17","18","19"],"a":2,"e":"9 doubled = 18.","d":"m"},{"t":"What is 3 + 4? Use the near-doubles strategy.","o":["5","6","7","8"],"a":2,"e":"3+3=6, +1=7.","d":"e"},{"t":"What is 4 + 5? Use the near-doubles strategy.","o":["7","8","9","10"],"a":2,"e":"4+4=8, +1=9.","d":"e"},{"t":"What is 5 + 6? Use the near-doubles strategy.","o":["11","9","10","12"],"a":0,"e":"5+5=10, +1=11.","d":"m"},{"t":"What is 6 + 7? Use the near-doubles strategy.","o":["11","12","14","13"],"a":3,"e":"6+6=12, +1=13.","d":"m"},{"t":"What is 7 + 8? Use the near-doubles strategy.","o":["13","15","14","16"],"a":1,"e":"7+7=14, +1=15.","d":"m"},{"t":"What is 8 + 9? Use the near-doubles strategy.","o":["15","16","17","18"],"a":2,"e":"8+8=16, +1=17.","d":"m"},{"t":"What is 9 + 10? Use the near-doubles strategy.","o":["17","18","19","20"],"a":2,"e":"9+9=18, +1=19.","d":"m"},{"t":"What is 2 + 2? (This is a doubles fact!)","o":["2","3","4","5"],"a":2,"e":"2 doubled = 4.","d":"e"},{"t":"Which is a doubles fact?","o":["3+4=7","6+6=12","5+6=11","7+8=15"],"a":1,"e":"6+6=12 uses the same number twice — that is a double!","d":"e"},{"t":"What is 10 + 11? Use the near-doubles strategy.","o":["19","20","21","22"],"a":2,"e":"10+10=20, +1=21.","d":"m"},{"t":"What is 1 + 1? (This is a doubles fact!)","o":["1","2","3","4"],"a":1,"e":"1 doubled = 2.","d":"e"},{"t":"Near double strategy: 5 + 6. Think 5+5=10 then?","o":["Add 0","Add 1","Add 2","Subtract 1"],"a":1,"e":"Near double: use 5+5=10 then add 1 more to get 11.","d":"h"},{"t":"What is 10 + 10? (This is a doubles fact!)","o":["15","18","20","22"],"a":2,"e":"10 doubled = 20.","d":"m"},{"t":"Which helps solve 7+8?","o":["7+7=14","8+8=16","7+9=16","6+8=14"],"a":0,"e":"7 is a near double of 8. Use 7+7=14 then +1=15.","d":"e"},{"t":"What is 11 + 12? Use the near-doubles strategy.","o":["21","22","23","24"],"a":2,"e":"11+11=22, +1=23.","d":"m"},{"t":"What is 15 + 15? (This is a doubles fact!)","o":["25","28","30","32"],"a":2,"e":"15 doubled = 30.","d":"m"},{"t":"What is 4 + 3? Use the near-doubles strategy.","o":["5","6","7","8"],"a":2,"e":"4+4=8, but 3+4 is near double: 3+3=6, +1=7.","d":"e"},{"t":"What is the double of 12?","o":["20","22","24","26"],"a":2,"e":"12+12=24.","d":"e"},{"t":"What is 6 + 5? Use the near-doubles strategy.","o":["9","10","11","12"],"a":2,"e":"5+5=10, +1=11. Same as 5+6!","d":"m"},{"t":"Which strategy for 8+9?","o":["Count back","Doubles","Near doubles","Skip count by 5"],"a":2,"e":"8+9 is a near double. 8+8=16, +1=17.","d":"e"},{"t":"What is the double of 20?","o":["30","35","40","45"],"a":2,"e":"20+20=40.","d":"e"},{"t":"What is 14 + 15? Use the near-doubles strategy.","o":["27","28","29","30"],"a":2,"e":"14+14=28, +1=29.","d":"m"},{"t":"What is 11 + 11? (This is a doubles fact!)","o":["20","21","22","23"],"a":2,"e":"11 doubled = 22.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 4?","o":["11","12","13","14"],"a":2,"e":"9+1=10, then +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 8 + 5?","o":["13","11","12","14"],"a":0,"e":"8+2=10, then +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 4?","o":["11","9","10","12"],"a":0,"e":"7+3=10, then +1=11.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 7?","o":["14","15","16","17"],"a":2,"e":"9+1=10, then +6=16.","d":"m"},{"t":"Use the make-ten strategy. What is 8 + 6?","o":["12","13","14","15"],"a":2,"e":"8+2=10, then +4=14.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 6?","o":["13","11","12","14"],"a":0,"e":"7+3=10, then +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 5?","o":["11","9","10","12"],"a":0,"e":"6+4=10, then +1=11.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 8?","o":["17","15","16","18"],"a":0,"e":"9+1=10, then +7=17.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 8?","o":["12","13","15","14"],"a":3,"e":"6+4=10, then +4=14.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 5?","o":["10","11","12","13"],"a":2,"e":"7+3=10, then +2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 8 + 4?","o":["12","10","11","13"],"a":0,"e":"8+2=10, then +2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 5?","o":["14","12","13","15"],"a":0,"e":"9+1=10, then +4=14.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 6?","o":["10","11","13","12"],"a":3,"e":"6+4=10, then +2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 8?","o":["13","14","16","15"],"a":3,"e":"7+3=10, then +5=15.","d":"m"},{"t":"Use the make-ten strategy. What is 8 + 3?","o":["9","11","10","12"],"a":1,"e":"8 needs 2 to reach 10. Then 10+1=11.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 3?","o":["12","10","11","13"],"a":0,"e":"9 needs 1 to reach 10. Then 10+2=12.","d":"m"},{"t":"Use the make-ten strategy. What is 7 + 7?","o":["12","14","13","15"],"a":1,"e":"7 needs 3 to reach 10. Then 10+4=14.","d":"m"},{"t":"Use the make-ten strategy. What is 5 + 8?","o":["13","11","12","14"],"a":0,"e":"5+5=10, then +3=13. Or 8+2=10, +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 4 + 9?","o":["11","12","13","14"],"a":2,"e":"9+1=10, then +3=13.","d":"m"},{"t":"Use the make-ten strategy. What is 6 + 7?","o":["11","12","13","14"],"a":2,"e":"6+4=10, then +3=13.","d":"m"},{"t":"Why do we \"make ten\" first?","o":["It looks cool","10 is easy to add to","It takes longer","We always must start at 10"],"a":1,"e":"Adding to 10 is easy! Once you reach 10, you just add the rest.","d":"e"},{"t":"Use the make-ten strategy. What is 8 + 7?","o":["13","14","16","15"],"a":3,"e":"8+2=10, then +5=15.","d":"m"},{"t":"Use the make-ten strategy. What is 9 + 6?","o":["13","14","16","15"],"a":3,"e":"9+1=10, then +5=15.","d":"h"},{"t":"Use the make-ten strategy. What is 5 + 7?","o":["10","11","13","12"],"a":3,"e":"5+5=10, then +2=12.","d":"h"},{"t":"Use the make-ten strategy. What is 3 + 9?","o":["10","11","12","13"],"a":2,"e":"9+1=10, then +2=12.","d":"h"},{"t":"Use the make-ten strategy. What is 4 + 8?","o":["10","11","12","13"],"a":2,"e":"8+2=10, then +2=12.","d":"h"},{"t":"Use the make-ten strategy. What is 8 + 8?","o":["14","15","16","17"],"a":2,"e":"8+2=10, then +6=16.","d":"h"},{"t":"Use the make-ten strategy. What is 7 + 9?","o":["14","15","16","17"],"a":2,"e":"9+1=10, then +6=16.","d":"h"},{"t":"Use the make-ten strategy. What is 6 + 9?","o":["13","14","15","16"],"a":2,"e":"9+1=10, then +5=15.","d":"h"},{"t":"Use the make-ten strategy. What is 5 + 9?","o":["12","13","14","15"],"a":2,"e":"9+1=10, then +4=14.","d":"h"},{"t":"Which number sentence belongs in the fact family for 3, 7, and 10?","o":["3+8=10","7+3=10","10+3=7","7-3=10"],"a":1,"e":"7+3=10 uses numbers 3,7,10.","d":"h"},{"t":"If 5 + 8 = 13, what is 13 − 8?","o":["4","5","6","7"],"a":1,"e":"Fact family! 13-8=5.","d":"h"},{"t":"What is the missing number? 6 + ___ = 14","o":["7","8","9","10"],"a":1,"e":"14-6=8, so 6+8=14.","d":"h"},{"t":"If 4 + 9 = 13, what is 13 − 4?","o":["8","9","10","11"],"a":1,"e":"Fact family! 13-4=9.","d":"h"},{"t":"The numbers 2, 8, and 10 form a fact family. How many facts are in every fact family?","o":["2","3","4","5"],"a":2,"e":"Every family has 4 facts: 2+8=10, 8+2=10, 10-2=8, 10-8=2.","d":"h"},{"t":"If 7 + 6 = 13, what is 13 − 7?","o":["4","5","6","7"],"a":2,"e":"Fact family! 13-7=6.","d":"h"},{"t":"What is the missing number? 9 + ___ = 17","o":["6","7","8","9"],"a":2,"e":"17-9=8, so 9+8=17.","d":"h"},{"t":"Which fact is in family 5,9,14?","o":["5+8=13","9+5=14","5+5=10","14-4=10"],"a":1,"e":"9+5=14 uses numbers 5,9,14.","d":"h"},{"t":"If 8 + 7 = 15, what is 15 − 8?","o":["6","7","8","9"],"a":1,"e":"Fact family! 15-8=7.","d":"h"},{"t":"What is the missing number? ___ + 6 = 11","o":["4","5","6","7"],"a":1,"e":"11-6=5, so 5+6=11.","d":"h"},{"t":"Start at 4. Count up 3. What number do you land on?","o":["6","8","7","5"],"a":2,"e":"Count up from 4: 5, 6, 7. You land on 7.","d":"e"},{"t":"What is 6 + 6?","o":["11","13","10","12"],"a":3,"e":"Use doubles: 6 + 6 = 12.","d":"e"},{"t":"What number goes with 8 to make 10?","o":["3","1","2","4"],"a":2,"e":"8 + 2 = 10. The number 2 goes with 8 to make 10.","d":"h"},{"t":"If 4 + 5 = 9, what is 5 + 4?","o":["8","10","9","7"],"a":2,"e":"Fact family: 4 + 5 = 9 and 5 + 4 = 9. Same answer!","d":"h"},{"t":"What is 9 - 3?","o":["5","7","6","12"],"a":2,"e":"Count back 3 from 9: 8, 7, 6. The answer is 6.","d":"e"},{"t":"What is double 4?","o":["6","4","10","8"],"a":3,"e":"Double 4 means 4 + 4 = 8.","d":"e"},{"t":"What is 10 + 6?","o":["60","17","15","16"],"a":3,"e":"10 + 6 = 16. Adding to 10 is easy!","d":"e"},{"t":"If 3 + 7 = 10, what is 10 - 7?","o":["4","2","7","3"],"a":3,"e":"Fact family: If 3 + 7 = 10, then 10 - 7 = 3.","d":"h"},{"t":"Count back 2 from 8. What number do you get?","o":["5","7","6","10"],"a":2,"e":"Count back from 8: 7, 6. You get 6.","d":"e"},{"t":"What is 7 + 7?","o":["13","15","12","14"],"a":3,"e":"Use doubles: 7 + 7 = 14.","d":"e"},{"t":"A cat has 9 treats. It gets 4 more. How many treats does the cat have now?","o":["14","12","11","13"],"a":3,"e":"Make a 10: 9 + 1 = 10, then 10 + 3 = 13. The cat has 13 treats.","d":"h"},{"t":"What is 7 + 8? Use a doubles fact to help.","o":["14","16","13","15"],"a":3,"e":"Doubles plus 1: 7 + 7 = 14, add 1 more = 15.","d":"h"},{"t":"__ + 5 = 12. What is the missing number?","o":["6","8","5","7"],"a":3,"e":"Think: related fact. 12 - 5 = 7. So 7 + 5 = 12.","d":"h"},{"t":"Which strategy helps you solve 8 + 5?","o":["Count by 2s","Use doubles of 8","Make a 10 first","Subtract 5 from 8"],"a":2,"e":"Make a 10: 8 + 2 = 10, then 10 + 3 = 13.","d":"h"},{"t":"If 9 + 6 = 15, what is 15 - 9?","o":["5","7","8","6"],"a":3,"e":"Fact family: If 9 + 6 = 15, then 15 - 9 = 6.","d":"h"},{"t":"There are 13 ducks. 4 swim away. How many are left?","o":["8","10","17","9"],"a":3,"e":"Count back 4 from 13: 12, 11, 10, 9. There are 9 ducks left.","d":"h"},{"t":"__ + __ = 14. Both numbers are the same. What are they?","o":["6 and 6","8 and 8","5 and 5","7 and 7"],"a":3,"e":"Think: what double equals 14? 7 + 7 = 14. Both numbers are 7.","d":"h"},{"t":"Which number sentence belongs to the same fact family as 8 + 5 = 13?","o":["13 - 5 = 8","13 - 5 = 7","8 + 8 = 16","5 + 5 = 10"],"a":0,"e":"Fact family: 8, 5, 13. So 13 - 5 = 8 is in the same family.","d":"h"},{"t":"9 - __ = 5. What is the missing number?","o":["3","5","2","4"],"a":3,"e":"Think: 5 + ? = 9. Count up: 6, 7, 8, 9. That is 4 steps. The missing number is 4.","d":"h"},{"t":"Ben has 6 red blocks and 7 blue blocks. How many blocks in all?","o":["14","12","11","13"],"a":3,"e":"Make a 10: 6 + 4 = 10, then 10 + 3 = 13. Or doubles plus 1: 6 + 6 = 12, + 1 = 13.","d":"h"},{"t":"Kai had 14 toy trucks. He gave 6 to his brother and 3 to his friend. How many does Kai have left?","o":["4","6","3","5"],"a":3,"e":"Two steps: 14 - 6 = 8, then 8 - 3 = 5. Count back each time. Kai has 5 left.","d":"h"},{"t":"A student wrote: double 8 = 15. Then they said 8 + 9 = 16. How many errors are there?","o":["0","1","2","3"],"a":2,"e":"Error analysis: double 8 = 16 (not 15), and 8 + 9 = 17 (not 16). That is 2 errors.","d":"h"},{"t":"If 7 + 9 = 16, what are the two subtraction facts in the same family?","o":["16-7=9 and 16-9=7","16-7=8 and 16-9=6","9-7=2 and 16-7=8","7-9=2 and 16-9=8"],"a":0,"e":"Fact family: 7+9=16, 9+7=16, 16-7=9, 16-9=7.","d":"h"},{"t":"Emma has 8 stickers. She finds 7 more, then gives 6 away. How many does she have now?","o":["10","8","11","9"],"a":3,"e":"Two steps: 8 + 7 = 15 (doubles plus 1). Then 15 - 6 = 9. Emma has 9 stickers.","d":"h"},{"t":"A student solved 9 + 4 using make a 10: 9 + 1 = 10, then 10 + 4 = 14. What went wrong?","o":["They should have added 10 + 3, not 10 + 4","They started at the wrong number","Nothing, the answer is 14","They should use doubles instead"],"a":0,"e":"Error analysis: After using 1 from the 4, only 3 is left. Correct: 10 + 3 = 13, not 10 + 4 = 14.","d":"h"},{"t":"__ + __ = 13. Both numbers are greater than 4. One is 3 more than the other. What are they?","o":["4 and 9","6 and 7","5 and 8","3 and 10"],"a":2,"e":"Open reasoning: 5 + 8 = 13, both > 4, and 8 - 5 = 3. They are 3 apart!","d":"h"},{"t":"Leo says 15 - 8 = 6 because 8 + 6 = 14. What TWO things did Leo get wrong?","o":["Wrong addition fact AND wrong subtraction","Only the addition is wrong","Only the subtraction is wrong","Nothing is wrong"],"a":0,"e":"Error analysis: 8 + 6 = 14 (not 15), so the addition fact is wrong. And 15 - 8 = 7, not 6.","d":"h"},{"t":"Which is greater: 9 + 6 or double 7 plus 1?","o":["9 + 6, because 15 > 14","Double 7 plus 1, because 15 > 14","They are equal, both are 15","They are equal, both are 14"],"a":2,"e":"Check: 9 + 6 = 15. Double 7 = 14, plus 1 = 15. They are equal! Both are 15.","d":"h"},{"t":"I am a number. Add me to myself and you get 12. Then subtract 5. What do you get?","o":["6 and 1","5 and 7","7 and 8","6 and 7"],"a":3,"e":"Double ? = 12, so the number is 6. Then 12 - 5 = 7. Answers: 6 and 7.","d":"h"},{"t":"Can 4, 8, and 11 be a fact family? Explain.","o":["Yes, 4 + 8 = 11","No, because 4 + 8 = 12, not 11","Yes, 11 - 8 = 4","No, because 11 - 4 = 8"],"a":1,"e":"Check: 4 + 8 = 12, not 11. The numbers do not work together. 4, 8, and 11 cannot be a fact family.","d":"h"}]});

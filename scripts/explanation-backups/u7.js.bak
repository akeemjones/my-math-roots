acity=\"0.6\"/><rect x=\"10\" y=\"22\" width=\"120\" height=\"12\" fill=\"#fff8e7\" stroke=\"#c8a000\" stroke-width=\"0.8\" rx=\"1\"/><line x1=\"22\" y1=\"22\" x2=\"22\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"46\" y1=\"22\" x2=\"46\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"70\" y1=\"22\" x2=\"70\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"94\" y1=\"22\" x2=\"94\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"118\" y1=\"22\" x2=\"118\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"10\" y1=\"22\" x2=\"10\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"10\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">0\"</text><line x1=\"34\" y1=\"22\" x2=\"34\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"34\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">1\"</text><line x1=\"58\" y1=\"22\" x2=\"58\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"58\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">2\"</text><line x1=\"82\" y1=\"22\" x2=\"82\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"82\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">3\"</text><line x1=\"106\" y1=\"22\" x2=\"106\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"106\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">4\"</text><line x1=\"130\" y1=\"22\" x2=\"130\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"130\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">5\"</text></svg>","o":["1 inch","3 inches","10 inches","1 foot"],"a":1,"e":"A standard crayon is about 3 inches long."}]},{"points":["SHORT hand = HOURS (moves slowly)","LONG hand = MINUTES (moves faster)","Each number on the clock = 5 minutes","60 minutes = 1 hour"],"examples":[{"c":"#1abc9c","tag":"O'clock & Half Past","p":"Special positions:","s":"Long hand at 12 = on the hour (3:00)\nLong hand at 6 = half past (3:30)\nLong hand at 3 = quarter past (3:15)\nLong hand at 9 = quarter to (3:45)","a":"Remember these 4 key positions! ✅","vis":"clock:3:0"},{"c":"#1abc9c","tag":"Reading Minutes","p":"Each number = 5 minutes:","s":"Minute hand at 1 = 5 min\nMinute hand at 2 = 10 min\nMinute hand at 3 = 15 min\nMinute hand at 6 = 30 min\nMinute hand at 9 = 45 min","a":"Multiply number by 5 to get minutes ✅","vis":"clock:3:15"},{"c":"#1abc9c","tag":"Examples","p":"Clock readings:","s":"Short on 4, long on 12 → 4:00\nShort on 7, long on 6 → 7:30\nShort on 9, long on 3 → 9:15","a":"Short hand = hour, long hand = minutes ✅","vis":"clock:4:0"},{"c":"#1abc9c","tag":"Try It! Interactive Clock","p":"Move the sliders to set the hands:","s":"<div style=\"text-align:center;padding:4px\"><svg id=\"iclock\" width=\"240\" height=\"240\" viewBox=\"0 0 100 100\" style=\"display:block;margin:6px auto\"><circle cx=\"50\" cy=\"50\" r=\"46\" fill=\"#f0f0f0\" stroke=\"#ddd\" stroke-width=\"1\"/><circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"#fffef5\" stroke=\"#888\" stroke-width=\"1.5\"/><line x1=\"69.5\" y1=\"16.2\" x2=\"72.0\" y2=\"11.9\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"67.5\" y=\"19.7\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">1</text><line x1=\"83.8\" y1=\"30.5\" x2=\"88.1\" y2=\"28.0\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"80.3\" y=\"32.5\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">2</text><line x1=\"89.0\" y1=\"50.0\" x2=\"94.0\" y2=\"50.0\" stroke=\"#555\" stroke-width=\"2\"/><text x=\"85.0\" y=\"50.0\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">3</text><line x1=\"83.8\" y1=\"69.5\" x2=\"88.1\" y2=\"72.0\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"80.3\" y=\"67.5\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">4</text><line x1=\"69.5\" y1=\"83.8\" x2=\"72.0\" y2=\"88.1\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"67.5\" y=\"80.3\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">5</text><line x1=\"50.0\" y1=\"89.0\" x2=\"50.0\" y2=\"94.0\" stroke=\"#555\" stroke-width=\"2\"/><text x=\"50.0\" y=\"85.0\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">6</text><line x1=\"30.5\" y1=\"83.8\" x2=\"28.0\" y2=\"88.1\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"32.5\" y=\"80.3\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">7</text><line x1=\"16.2\" y1=\"69.5\" x2=\"11.9\" y2=\"72.0\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"19.7\" y=\"67.5\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">8</text><line x1=\"11.0\" y1=\"50.0\" x2=\"6.0\" y2=\"50.0\" stroke=\"#555\" stroke-width=\"2\"/><text x=\"15.0\" y=\"50.0\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">9</text><line x1=\"16.2\" y1=\"30.5\" x2=\"11.9\" y2=\"28.0\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"19.7\" y=\"32.5\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">10</text><line x1=\"30.5\" y1=\"16.2\" x2=\"28.0\" y2=\"11.9\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"32.5\" y=\"19.7\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">11</text><line x1=\"50.0\" y1=\"11.0\" x2=\"50.0\" y2=\"6.0\" stroke=\"#555\" stroke-width=\"2\"/><text x=\"50.0\" y=\"15.0\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"9\" font-weight=\"bold\" fill=\"#333\">12</text><line id=\"ic-mh\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"12\" stroke=\"#333\" stroke-width=\"2.5\" stroke-linecap=\"round\" transform=\"rotate(0,50,50)\"/><line id=\"ic-hh\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"24\" stroke=\"#2980b9\" stroke-width=\"4.5\" stroke-linecap=\"round\" transform=\"rotate(90,50,50)\"/><circle cx=\"50\" cy=\"50\" r=\"3.5\" fill=\"#e74c3c\"/></svg><div id=\"ic-dt\" style=\"font-size:28px;font-weight:bold;color:#2980b9;margin:4px 0\">3:00</div><div style=\"font-size:11px;color:#666;margin-bottom:10px\">&#128309; Short hand (blue) = hours &nbsp;|&nbsp; &#11035; Long hand = minutes</div><div style=\"display:flex;gap:20px;justify-content:center;flex-wrap:wrap\"><label style=\"font-size:13px;font-weight:bold;color:#333\">&#x23F0; Hour<br><input id=\"ic-hs\" type=\"range\" min=\"1\" max=\"12\" value=\"3\" style=\"width:120px;margin-top:4px\" oninput=\"(function(){var h=+document.getElementById(&#39;ic-hs&#39;).value;var m=+document.getElementById(&#39;ic-ms&#39;).value;var ha=(h%12+m/60)*30;var ma=m*6;document.getElementById(&#39;ic-hh&#39;).setAttribute(&#39;transform&#39;,&#39;rotate(&#39;+ha+&#39;,50,50)&#39;);document.getElementById(&#39;ic-mh&#39;).setAttribute(&#39;transform&#39;,&#39;rotate(&#39;+ma+&#39;,50,50)&#39;);document.getElementById(&#39;ic-dt&#39;).textContent=h+&#39;:&#39;+(m<10?&#39;0&#39;:&#39;&#39;)+m;}).call(this)\"></label><label style=\"font-size:13px;font-weight:bold;color:#333\">&#8987; Minute<br><input id=\"ic-ms\" type=\"range\" min=\"0\" max=\"59\" step=\"1\" value=\"0\" style=\"width:120px;margin-top:4px\" oninput=\"(function(){var h=+document.getElementById(&#39;ic-hs&#39;).value;var m=+document.getElementById(&#39;ic-ms&#39;).value;var ha=(h%12+m/60)*30;var ma=m*6;document.getElementById(&#39;ic-hh&#39;).setAttribute(&#39;transform&#39;,&#39;rotate(&#39;+ha+&#39;,50,50)&#39;);document.getElementById(&#39;ic-mh&#39;).setAttribute(&#39;transform&#39;,&#39;rotate(&#39;+ma+&#39;,50,50)&#39;);document.getElementById(&#39;ic-dt&#39;).textContent=h+&#39;:&#39;+(m<10?&#39;0&#39;:&#39;&#39;)+m;}).call(this)\"></label></div></div>","a":"Short hand = hour, Long hand = minutes &#x2705;"}],"practice":[{"q":"Long hand at 12, short hand at 6. What time?","a":"6:00","h":"Long at 12 = on the hour. Short at 6 = 6 o'clock!","e":"🕐"},{"q":"Half past 9 = ?","a":"9:30","h":"Half past = 30 minutes past. So 9:30!","e":"⏰"},{"q":"Long hand pointing to 6 = how many minutes?","a":"30 minutes","h":"6 on the clock face always means 30 minutes!","e":"🕕"}],"qBank":[{"t":"Short on 4, long on 12. Time?<svg width=\"180\" height=\"180\" viewBox=\"0 0 90 90\" style=\"display:block;margin:6px auto;border-radius:50%;background:#fffdf5\"><circle cx=\"45\" cy=\"45\" r=\"39\" fill=\"#f0f0f0\" stroke=\"#bbb\" stroke-width=\"1\"/><circle cx=\"45\" cy=\"45\" r=\"38\" fill=\"#fffdf5\" stroke=\"#888\" stroke-width=\"1.5\"/><line x1=\"61.50\" y1=\"16.42\" x2=\"64.00\" y2=\"12.09\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"57.50\" y=\"23.35\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"8\" font-weight=\"bold\" fill=\"#333\">1</text><line x1=\"73.58\" y1=\"28.50\" x2=\"77.91\" y2=\"26.00\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"66.65\" y=\"32.50\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"8\" font-weight=\"bold\" fill=\"#333\">2</text><line x1=\"78.00\" y1=\"45.00\" x2=\"83.00\" y2=\"45.00\" stroke=\"#555\" stroke-width=\"2\"/><text x=\"70.00\" y=\"45.00\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"8\" font-weight=\"bold\" fill=\"#333\">3</text><line x1=\"73.58\" y1=\"61.50\" x2=\"77.91\" y2=\"64.00\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"66.65\" y=\"57.50\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"8\" font-weight=\"bold\" fill=\"#333\">4</text><line x1=\"61.50\" y1=\"73.58\" x2=\"64.00\" y2=\"77.91\" stroke=\"#555\" stroke-width=\"1\"/><text x=\"57.50\" y=\"66.65\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"8\" font-weight=\"bold\" fill=\"#333\">5</text><line x1=\"45.00\" y1=\"78.00\" x2=\"45.00\" y2=\"83.00\" stroke=\"#555\" stroke-width=\"2\"/><text x=\"45.00\" y=\"70.00\" 
t-size=\"5\" fill=\"#444\">3\"</text><line x1=\"78\" y1=\"22\" x2=\"78\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"78\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">4\"</text><line x1=\"95\" y1=\"22\" x2=\"95\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"95\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">5\"</text><line x1=\"112\" y1=\"22\" x2=\"112\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"112\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">6\"</text><line x1=\"129\" y1=\"22\" x2=\"129\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"129\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">7\"</text><line x1=\"146\" y1=\"22\" x2=\"146\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"146\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">8\"</text><line x1=\"163\" y1=\"22\" x2=\"163\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"163\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">9\"</text></svg>","o":["5 in","6 in","7 in","8 in"],"a":2,"e":"The pencil ends at 7, so it is 7 inches long."},{"t":"What is the best unit to measure the length of a room?","o":["Inches","Yards","Meters","Feet"],"a":3,"e":"Feet are used for bigger lengths like rooms."},{"t":"A book is 8 inches long. A notebook is 6 inches long. How much longer is the book?<svg width=\"368\" height=\"128\" viewBox=\"0 0 184 64\" style=\"display:block;margin:6px auto;border-radius:6px;background:#f9f9f9\"><rect x=\"10\" y=\"8\" width=\"128\" height=\"10\" fill=\"#8e44ad\" rx=\"3\" opacity=\"0.85\"/><text x=\"74\" y=\"15\" text-anchor=\"middle\" font-size=\"5\" fill=\"white\" font-weight=\"bold\">book  8\"</text><line x1=\"138\" y1=\"8\" x2=\"138\" y2=\"34\" stroke=\"#8e44ad\" stroke-width=\"0.7\" stroke-dasharray=\"2,2\" opacity=\"0.6\"/><rect x=\"10\" y=\"-4\" width=\"96\" height=\"10\" fill=\"#e67e22\" rx=\"3\" opacity=\"0.85\"/><text x=\"58\" y=\"3\" text-anchor=\"middle\" font-size=\"5\" fill=\"white\" font-weight=\"bold\">notebook  6\"</text><line x1=\"106\" y1=\"-4\" x2=\"106\" y2=\"34\" stroke=\"#e67e22\" stroke-width=\"0.7\" stroke-dasharray=\"2,2\" opacity=\"0.6\"/><rect x=\"10\" y=\"22\" width=\"160\" height=\"12\" fill=\"#fff8e7\" stroke=\"#c8a000\" stroke-width=\"0.8\" rx=\"1\"/><line x1=\"18\" y1=\"22\" x2=\"18\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"34\" y1=\"22\" x2=\"34\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"50\" y1=\"22\" x2=\"50\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"66\" y1=\"22\" x2=\"66\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"82\" y1=\"22\" x2=\"82\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"98\" y1=\"22\" x2=\"98\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"114\" y1=\"22\" x2=\"114\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"130\" y1=\"22\" x2=\"130\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"146\" y1=\"22\" x2=\"146\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"162\" y1=\"22\" x2=\"162\" y2=\"28\" stroke=\"#aaa\" stroke-width=\"0.6\"/><line x1=\"10\" y1=\"22\" x2=\"10\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"10\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">0\"</text><line x1=\"26\" y1=\"22\" x2=\"26\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"26\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">1\"</text><line x1=\"42\" y1=\"22\" x2=\"42\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"42\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">2\"</text><line x1=\"58\" y1=\"22\" x2=\"58\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"58\" y=\"40\" text-anchor=\"middle\" font-size=\"5\" fill=\"#444\">3\"</text><line x1=\"74\" y1=\"22\" x2=\"74\" y2=\"34\" stroke=\"#555\" stroke-width=\"0.8\"/><text x=\"74\" y=\"40\" te